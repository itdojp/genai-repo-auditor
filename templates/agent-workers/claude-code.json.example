{
  "id": "claude-code",
  "display_name": "Claude Code",
  "description": "Experimental CLI worker profile. It is listed for adapter contract planning and is not executed by GenAI Repo Auditor until separately tested.",
  "profile_status": "experimental",
  "executable": "claude",
  "supports_exec": true,
  "supports_goal": false,
  "supports_json_events": false,
  "default_model": "operator-selected",
  "default_effort": "operator-selected",
  "sandbox_modes": ["operator-managed"],
  "network_default": false,
  "command_templates": {
    "exec": "claude --print --model {model}"
  }
}

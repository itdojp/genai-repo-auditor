{
  "schema_version": "1",
  "profile": "supply-chain",
  "profile_version": "1.0.0",
  "description": "Plan local provenance, target generation, and an optional offline Syft adapter without scanner execution.",
  "stages": [
    {
      "id": "recon",
      "command": [
        "gra-recon",
        "--run",
        "{run}"
      ],
      "depends_on": [],
      "required_inputs": [
        "context.json",
        "{target_repo_dir}"
      ],
      "outputs": [
        "{reports_dir}/AUDIT_SUMMARY.md",
        "{reports_dir}/THREAT_MODEL.md",
        "{reports_dir}/ATTACK_SURFACE.md",
        "{reports_dir}/agent-surface.json",
        "{reports_dir}/provenance-posture.json"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "syft-plan",
      "command": [
        "gra-scan",
        "--run",
        "{run}",
        "--tool",
        "syft",
        "--plan"
      ],
      "depends_on": [
        "recon"
      ],
      "required_inputs": [
        "context.json",
        "{target_repo_dir}"
      ],
      "outputs": [],
      "skippable": true,
      "skip_reason": "Syft planning is optional and never invokes the external scanner.",
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "targets",
      "command": [
        "gra-targets",
        "--run",
        "{run}",
        "--generate"
      ],
      "depends_on": [
        "recon"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/ATTACK_SURFACE.md",
        "{reports_dir}/agent-surface.json",
        "{reports_dir}/provenance-posture.json"
      ],
      "outputs": [
        "{reports_dir}/targets.json"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    }
  ]
}

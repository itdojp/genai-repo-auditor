{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "profile_version", "description", "stages"],
  "properties": {
    "schema_version": {"const": "1"},
    "profile": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "profile_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string", "minLength": 1, "maxLength": 240},
    "stages": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "command", "depends_on", "required_inputs", "outputs", "skippable", "skip_reason", "network_allowed", "mutation"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
          "command": {
            "type": "array",
            "enum": [
              ["gra-recon", "--run", "{run}"],
              ["gra-targets", "--run", "{run}", "--generate"]
            ]
          },
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "required_inputs": {"type": "array", "items": {"type": "string"}},
          "outputs": {"type": "array", "items": {"type": "string"}},
          "skippable": {"type": "boolean"},
          "skip_reason": {"type": ["string", "null"]},
          "network_allowed": {"const": false},
          "mutation": {"const": "local-artifacts-only"}
        }
      }
    }
  }
}

{
  "schema_version": "1",
  "profile": "full",
  "profile_version": "1.0.0",
  "description": "Run the complete approved local workflow with scanner planning and no publication mutation.",
  "stages": [
    {
      "id": "recon",
      "command": [
        "gra-recon",
        "--run",
        "{run}"
      ],
      "depends_on": [],
      "required_inputs": [
        "context.json",
        "{target_repo_dir}"
      ],
      "outputs": [
        "{reports_dir}/AUDIT_SUMMARY.md",
        "{reports_dir}/THREAT_MODEL.md",
        "{reports_dir}/ATTACK_SURFACE.md",
        "{reports_dir}/agent-surface.json",
        "{reports_dir}/provenance-posture.json"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "syft-plan",
      "command": [
        "gra-scan",
        "--run",
        "{run}",
        "--tool",
        "syft",
        "--plan"
      ],
      "depends_on": [
        "recon"
      ],
      "required_inputs": [
        "context.json",
        "{target_repo_dir}"
      ],
      "outputs": [],
      "skippable": true,
      "skip_reason": "Syft planning is optional and never invokes the external scanner.",
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "gitleaks-plan",
      "command": [
        "gra-scan",
        "--run",
        "{run}",
        "--tool",
        "gitleaks",
        "--plan"
      ],
      "depends_on": [
        "recon"
      ],
      "required_inputs": [
        "context.json",
        "{target_repo_dir}"
      ],
      "outputs": [],
      "skippable": true,
      "skip_reason": "Gitleaks planning is optional and never invokes the external scanner.",
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "targets",
      "command": [
        "gra-targets",
        "--run",
        "{run}",
        "--generate"
      ],
      "depends_on": [
        "recon"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/ATTACK_SURFACE.md",
        "{reports_dir}/agent-surface.json",
        "{reports_dir}/provenance-posture.json"
      ],
      "outputs": [
        "{reports_dir}/targets.json"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "chains",
      "command": [
        "gra-chains",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "targets"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json",
        "{reports_dir}/targets.json"
      ],
      "outputs": [
        "{reports_dir}/chains.json",
        "{reports_dir}/ATTACK_CHAINS.md"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "proofs",
      "command": [
        "gra-proofs",
        "--run",
        "{run}",
        "--all-critical-high"
      ],
      "depends_on": [
        "chains"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json",
        "{reports_dir}/chains.json"
      ],
      "outputs": [
        "{reports_dir}/proofs.json",
        "{reports_dir}/PROOFS.md"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "adversarial-validation",
      "command": [
        "gra-adversarial-validate",
        "--run",
        "{run}",
        "--all-critical-high"
      ],
      "depends_on": [
        "proofs"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json",
        "{reports_dir}/chains.json",
        "{reports_dir}/proofs.json"
      ],
      "outputs": [
        "{reports_dir}/validation.json",
        "{reports_dir}/VALIDATION.md"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "report-validation",
      "command": [
        "gra-validate-report",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "adversarial-validation"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json"
      ],
      "outputs": [],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "metrics",
      "command": [
        "gra-metrics",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "report-validation"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json"
      ],
      "outputs": [
        "{reports_dir}/metrics.json",
        "{reports_dir}/METRICS.md"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "evidence-graph",
      "command": [
        "gra-evidence-graph",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "metrics"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json",
        "{reports_dir}/metrics.json"
      ],
      "outputs": [
        "{reports_dir}/evidence-graph.json",
        "{reports_dir}/EVIDENCE_GRAPH.md"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "dashboard",
      "command": [
        "gra-dashboard",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "evidence-graph"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json",
        "{reports_dir}/metrics.json",
        "{reports_dir}/evidence-graph.json"
      ],
      "outputs": [
        "{reports_dir}/dashboard.html"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    },
    {
      "id": "sarif",
      "command": [
        "gra-sarif",
        "--run",
        "{run}"
      ],
      "depends_on": [
        "report-validation"
      ],
      "required_inputs": [
        "context.json",
        "{reports_dir}/findings.json"
      ],
      "outputs": [
        "{reports_dir}/findings.sarif"
      ],
      "skippable": false,
      "skip_reason": null,
      "network_allowed": false,
      "mutation": "local-artifacts-only"
    }
  ]
}

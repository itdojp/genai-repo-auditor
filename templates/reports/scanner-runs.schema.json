{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Scanner Runs",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "repo", "generated_at", "source", "safety", "summary", "runs"],
  "properties": {
    "schema_version": {"const": "1"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "generated_at": {"type": "string"},
    "source": {"const": "local-scanner-execution"},
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_safe", "raw_scanner_bodies_copied", "secret_values_copied", "review_only"],
      "properties": {
        "public_safe": {"const": true},
        "raw_scanner_bodies_copied": {"const": false},
        "secret_values_copied": {"const": false},
        "review_only": {"const": true}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_count", "by_status", "by_adapter", "total_duration_ms", "maximum_duration_ms", "result_count", "normalized_leads_count", "redaction_count"],
      "properties": {
        "run_count": {"type": "integer", "minimum": 0, "maximum": 1000},
        "by_status": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "by_adapter": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "total_duration_ms": {"type": "integer", "minimum": 0},
        "maximum_duration_ms": {"type": "integer", "minimum": 0},
        "result_count": {"type": "integer", "minimum": 0},
        "normalized_leads_count": {"type": "integer", "minimum": 0},
        "redaction_count": {"type": "integer", "minimum": 0}
      }
    },
    "runs": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adapter_id", "tool_version", "image_digest", "status", "scanner_status", "started_at", "ended_at", "duration_ms", "scanner_exit_code", "result_count", "normalized_leads_count", "redaction_count", "sandbox_profile", "runtime", "network_accessed", "result_classification", "finding_status", "normalized_result_ref", "scanner_index_ref"],
        "properties": {
          "id": {"type": "string", "pattern": "^scan-[0-9a-f-]{36}$"},
          "adapter_id": {"type": "string"},
          "tool_version": {"type": "string"},
          "image_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "status": {"enum": ["succeeded", "failed"]},
          "scanner_status": {"type": "string"},
          "started_at": {"type": "string"},
          "ended_at": {"type": "string"},
          "duration_ms": {"type": "integer", "minimum": 0},
          "scanner_exit_code": {"type": ["integer", "null"]},
          "result_count": {"type": "integer", "minimum": 0},
          "normalized_leads_count": {"type": "integer", "minimum": 0},
          "redaction_count": {"type": "integer", "minimum": 0},
          "sandbox_profile": {"enum": ["container", "gvisor"]},
          "runtime": {"enum": ["docker", "podman", "unknown"]},
          "network_accessed": {"const": false},
          "result_classification": {"enum": ["scanner-leads", "posture-evidence", "sbom-data"]},
          "finding_status": {"const": "review-only"},
          "normalized_result_ref": {"type": ["string", "null"]},
          "scanner_index_ref": {"type": ["string", "null"]}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Evidence Graph",
  "type": "object",
  "required": ["schema_version", "run_id", "repo", "generated_at", "source", "safety", "summary", "nodes", "edges"],
  "properties": {
    "schema_version": {"const": "1"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "branch": {"type": ["string", "null"]},
    "commit": {"type": ["string", "null"]},
    "generated_at": {"type": "string"},
    "source": {"enum": ["local-report-artifacts"]},
    "safety": {
      "type": "object",
      "required": ["local_artifacts_only", "raw_evidence_copied", "secret_values_copied", "bounded_summaries_only"],
      "properties": {
        "local_artifacts_only": {"const": true},
        "raw_evidence_copied": {"const": false},
        "secret_values_copied": {"const": false},
        "bounded_summaries_only": {"const": true}
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "node_count",
        "edge_count",
        "node_counts",
        "edge_counts",
        "missing_optional_artifacts",
        "high_critical_issue_recommended_findings",
        "high_critical_with_supporting_evidence",
        "high_critical_with_challenging_evidence"
      ],
      "properties": {
        "node_count": {"type": "integer", "minimum": 0},
        "edge_count": {"type": "integer", "minimum": 0},
        "node_counts": {"type": "object"},
        "edge_counts": {"type": "object"},
        "missing_optional_artifacts": {"type": "array", "items": {"type": "string"}},
        "high_critical_issue_recommended_findings": {"type": "integer", "minimum": 0},
        "high_critical_with_supporting_evidence": {"type": "integer", "minimum": 0},
        "high_critical_with_challenging_evidence": {"type": "integer", "minimum": 0}
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "ref_id", "label", "path", "summary"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["target", "scanner_lead", "finding", "chain", "proof", "validation", "trace", "remediation_candidate", "patch_validation", "issue_plan_entry", "metric"]},
          "ref_id": {"type": "string"},
          "label": {"type": "string"},
          "severity": {"type": "string"},
          "status": {"type": "string"},
          "path": {"type": "string"},
          "summary": {"type": "string", "maxLength": 200}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "type", "reason", "path"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "type": {"enum": ["produced", "supports", "challenges", "invalidates", "depends_on", "member_of", "validated_by", "publication_candidate", "not_applicable"]},
          "reason": {"type": "string", "maxLength": 200},
          "path": {"type": "string"}
        }
      }
    }
  }
}

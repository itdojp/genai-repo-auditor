{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Targets",
  "type": "object",
  "required": ["run_id", "repo", "commit", "generated_at", "targets"],
  "properties": {
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "branch": {"type": ["string", "null"]},
    "commit": {"type": "string"},
    "generated_at": {"type": "string"},
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "title", "risk", "priority", "status", "scope", "entry_points", "trust_boundaries", "sinks", "review_questions", "recommended_mode"],
        "properties": {
          "id": {"type": "string", "pattern": "^TGT-(?:[A-Z][A-Z0-9]*-)?[0-9]{3,}$"},
          "category": {"type": "string"},
          "title": {"type": "string"},
          "risk": {"enum": ["critical", "high", "medium", "low", "informational"]},
          "priority": {"type": "integer", "minimum": 0, "maximum": 100},
          "status": {"enum": ["queued", "in_progress", "reviewed", "skipped", "needs_human_review"]},
          "scope": {"type": "string"},
          "entry_points": {"type": "array", "items": {"type": "string"}},
          "trust_boundaries": {"type": "array", "items": {"type": "string"}},
          "sinks": {"type": "array", "items": {"type": "string"}},
          "attack_class": {"type": "string"},
          "security_invariants": {"type": "array", "items": {"type": "string"}},
          "attacker_model": {"type": "string"},
          "max_files": {"type": "integer", "minimum": 1, "maximum": 20},
          "expected_output": {"enum": ["finding-or-no-finding-with-coverage"]},
          "chain_relevance": {"enum": ["none", "possible-link", "candidate-chain-step"]},
          "coverage": {
            "type": "object",
            "properties": {
              "review_depth": {"enum": ["none", "shallow", "medium", "deep"]},
              "files_reviewed": {"type": "array", "items": {"type": "string"}},
              "files_skipped": {"type": "array", "items": {"type": "string"}},
              "commands_run": {"type": "array", "items": {"type": "string"}},
              "unresolved_questions": {"type": "array", "items": {"type": "string"}},
              "gapfill_recommended": {"type": "boolean"},
              "gapfill_reason": {"type": "string"}
            }
          },
          "review_questions": {"type": "array", "items": {"type": "string"}},
          "candidate_files": {"type": "array", "items": {"type": "string"}},
          "recommended_mode": {"enum": ["exec", "goal"]},
          "notes": {"type": "string"},
          "taxonomies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "id", "label"],
              "properties": {
                "name": {"type": "string"},
                "id": {"type": "string"},
                "label": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}

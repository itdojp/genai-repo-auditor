        "schema_version": {
          "const": "1"
        },
        "policy": {
          "enum": [
            "strict",
            "risk-weighted"
          ]
        },
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total",
            "by_source"
          ],
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Run State",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "repo",
    "commit",
    "generated_at",
    "source",
    "status",
    "pause_reason",
    "resume_target",
    "resume_condition",
    "paused_at",
    "paused_by",
    "final_reconcile",
    "block_reason",
    "blocked_at",
    "blocked_by",
    "resumed_at",
    "resumed_by"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "commit": {"type": "string"},
    "generated_at": {"type": "string"},
    "source": {"enum": ["gra-run-state"]},
    "status": {"enum": ["active", "paused", "blocked"]},
    "pause_reason": {"type": ["string", "null"]},
    "resume_target": {"type": ["string", "null"]},
    "resume_condition": {"type": ["string", "null"]},
    "paused_at": {"type": ["string", "null"]},
    "paused_by": {"type": ["string", "null"]},
    "final_reconcile": {"type": ["string", "null"]},
    "block_reason": {"type": ["string", "null"]},
    "blocked_at": {"type": ["string", "null"]},
    "blocked_by": {"type": ["string", "null"]},
    "resumed_at": {"type": ["string", "null"]},
    "resumed_by": {"type": ["string", "null"]}
  }
}

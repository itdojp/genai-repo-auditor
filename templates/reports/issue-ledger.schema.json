{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Issue Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "repo",
    "commit",
    "generated_at",
    "source",
    "findings",
    "warnings"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "commit": {"type": "string"},
    "generated_at": {"type": "string"},
    "source": {"enum": ["gra-issues"]},
    "plan_written": {"type": "boolean"},
    "publication_plan_status": {
      "enum": [
        "written",
        "rewritten",
        "not-written-preview",
        "not-written-direct-apply",
        "verified-existing-plan-preview",
        "verified-existing-plan-applied"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "fingerprint",
          "publication_status",
          "issue_number",
          "state",
          "url",
          "title",
          "labels",
          "body_hash",
          "published_at",
          "source_plan",
          "plan_sha256",
          "drift"
        ],
        "properties": {
          "finding_id": {"type": "string"},
          "fingerprint": {"type": "string"},
          "previous_fingerprint": {"type": "string"},
          "publication_status": {
            "enum": ["not-selected", "pending", "dry-run", "published", "duplicate"]
          },
          "issue_number": {"type": ["integer", "null"], "minimum": 1},
          "state": {"type": ["string", "null"]},
          "url": {"type": ["string", "null"]},
          "title": {"type": "string"},
          "labels": {"type": "array", "items": {"type": "string"}},
          "body_hash": {"type": ["string", "null"]},
          "current_body_hash": {"type": ["string", "null"]},
          "duplicate_decision_file": {"type": "string"},
          "published_at": {"type": ["string", "null"]},
          "source_plan": {"type": ["string", "null"]},
          "plan_sha256": {"type": ["string", "null"]},
          "selection_reason": {"type": "string"},
          "duplicate_detected": {"type": "boolean"},
          "drift": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  }
}

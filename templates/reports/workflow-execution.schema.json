{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Workflow Execution",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "repo", "generated_at", "source", "profile", "profile_version", "status", "requested_range", "requested_skips", "resume", "safety", "summary", "stages"],
  "properties": {
    "schema_version": {"const": "1"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "generated_at": {"type": "string"},
    "source": {"const": "gra-run-execution"},
    "profile": {"type": "string"},
    "profile_version": {"type": "string"},
    "status": {"enum": ["running", "paused", "blocked", "succeeded"]},
    "requested_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "until"],
      "properties": {
        "from": {"type": ["string", "null"]},
        "until": {"type": ["string", "null"]}
      }
    },
    "requested_skips": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "resume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "stage"],
      "properties": {
        "available": {"type": "boolean"},
        "stage": {"type": ["string", "null"]}
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_artifacts_only", "raw_prompts_copied", "raw_findings_copied", "raw_evidence_copied", "credentials_copied", "private_reasoning_copied", "issue_publication_included"],
      "properties": {
        "local_artifacts_only": {"const": true},
        "raw_prompts_copied": {"const": false},
        "raw_findings_copied": {"const": false},
        "raw_evidence_copied": {"const": false},
        "credentials_copied": {"const": false},
        "private_reasoning_copied": {"const": false},
        "issue_publication_included": {"const": false}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_count", "by_status", "total_duration_ms", "maximum_duration_ms", "failed_count", "skipped_by_scope_count", "blocked_dependency_count", "absent_stage_count", "absence_reasons"],
      "properties": {
        "stage_count": {"type": "integer", "minimum": 1, "maximum": 64},
        "by_status": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pending", "running", "succeeded", "failed", "blocked_dependency", "external_prerequisite", "skipped_by_scope", "out_of_range"],
          "properties": {
            "pending": {"type": "integer", "minimum": 0},
            "running": {"type": "integer", "minimum": 0},
            "succeeded": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "blocked_dependency": {"type": "integer", "minimum": 0},
            "external_prerequisite": {"type": "integer", "minimum": 0},
            "skipped_by_scope": {"type": "integer", "minimum": 0},
            "out_of_range": {"type": "integer", "minimum": 0}
          }
        },
        "total_duration_ms": {"type": "integer", "minimum": 0},
        "maximum_duration_ms": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "skipped_by_scope_count": {"type": "integer", "minimum": 0},
        "blocked_dependency_count": {"type": "integer", "minimum": 0},
        "absent_stage_count": {"type": "integer", "minimum": 0},
        "absence_reasons": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "depends_on", "attempt", "started_at", "ended_at", "duration_ms", "exit_code", "error_category", "absence_reason", "blocked_by", "output_artifact_refs"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["pending", "running", "succeeded", "failed", "blocked_dependency", "external_prerequisite", "skipped_by_scope", "out_of_range"]},
          "depends_on": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "attempt": {"type": "integer", "minimum": 0},
          "started_at": {"type": ["string", "null"]},
          "ended_at": {"type": ["string", "null"]},
          "duration_ms": {"type": "integer", "minimum": 0},
          "exit_code": {"type": ["integer", "null"]},
          "error_category": {"enum": [null, "stage_exit", "interrupted", "missing_or_unsafe_output"]},
          "absence_reason": {"enum": [null, "interrupted", "operator_scoped_skip", "external_prerequisite", "outside_selected_range", "blocked_by_dependency", "range_continuation", "workflow_paused", "workflow_blocked", "not_started"]},
          "blocked_by": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "output_artifact_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    }
  }
}

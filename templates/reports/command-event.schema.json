{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Command Event",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "repo",
    "command",
    "phase",
    "target_id",
    "started_at",
    "ended_at",
    "duration_ms",
    "exit_code",
    "model",
    "effort",
    "artifact_paths",
    "source"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "run_id": {"type": "string"},
    "repo": {"type": "string"},
    "command": {"enum": ["gra-research", "gra-gapfill", "gra-validate-report"]},
    "phase": {"enum": ["exec", "goal", "generate", "validate", "list"]},
    "target_id": {"type": ["string", "null"]},
    "started_at": {"type": "string"},
    "ended_at": {"type": "string"},
    "duration_ms": {"type": "integer", "minimum": 0},
    "exit_code": {"type": "integer"},
    "model": {"type": ["string", "null"]},
    "effort": {"type": ["string", "null"]},
    "artifact_paths": {"type": "array", "items": {"type": "string"}},
    "source": {"enum": ["genai-repo-auditor"]}
  }
}

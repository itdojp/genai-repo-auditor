{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Workflow Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "repo", "generated_at", "source", "profile", "profile_version", "definition_sha256", "plan_fingerprint", "reports_dir", "status", "requested_from", "requested_until", "requested_skips", "resume_stage", "command_implementations", "external_input_artifacts", "stages"],
  "properties": {
    "schema_version": {"const": "1"}, "run_id": {"type": "string"}, "repo": {"type": "string"},
    "generated_at": {"type": "string"}, "source": {"const": "gra-run-checkpoint"},
    "profile": {"type": "string"}, "profile_version": {"type": "string"},
    "definition_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "plan_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reports_dir": {"type": "string", "minLength": 1, "maxLength": 240},
    "status": {"enum": ["running", "paused", "blocked", "succeeded"]},
    "requested_from": {"type": ["string", "null"]}, "requested_until": {"type": ["string", "null"]},
    "requested_skips": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "resume_stage": {"type": ["string", "null"]},
    "command_implementations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["command", "sha256"], "properties": {"command": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
    "external_input_artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "stages": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/stage"}}
  },
  "$defs": {
    "artifact": {"type": "object", "additionalProperties": false, "required": ["path", "size", "sha256"], "properties": {"path": {"type": "string"}, "size": {"type": "integer", "minimum": 0, "maximum": 33554432}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
    "stage": {"type": "object", "additionalProperties": false, "required": ["id", "status", "attempt", "started_at", "ended_at", "exit_code", "error_category", "output_artifacts"], "properties": {"id": {"type": "string"}, "status": {"enum": ["pending", "running", "succeeded", "failed", "blocked_dependency", "external_prerequisite", "skipped_by_scope", "out_of_range"]}, "attempt": {"type": "integer", "minimum": 0}, "started_at": {"type": ["string", "null"]}, "ended_at": {"type": ["string", "null"]}, "exit_code": {"type": ["integer", "null"]}, "error_category": {"enum": [null, "stage_exit", "interrupted", "missing_or_unsafe_output", "provider_error"]}, "output_artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}, "provider_error": {"anyOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["class", "retryable", "retry_after_seconds", "resume_recommended", "source"], "properties": {"class": {"enum": ["rate_limit", "usage_limit", "authentication", "authorization", "service_unavailable", "timeout", "invalid_request", "model_unavailable", "response_contract", "unknown_provider_error"]}, "retryable": {"type": "boolean"}, "retry_after_seconds": {"type": ["integer", "null"], "minimum": 1, "maximum": 86400}, "resume_recommended": {"type": "boolean"}, "source": {"const": "sanitized_stderr_classifier"}}}]}, "provider_failure_history": {"anyOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["count", "retryable_count", "resume_recommended_count", "by_class", "last_error", "recovered"], "properties": {"count": {"type": "integer", "minimum": 1, "maximum": 1000000}, "retryable_count": {"type": "integer", "minimum": 0, "maximum": 1000000}, "resume_recommended_count": {"type": "integer", "minimum": 0, "maximum": 1000000}, "by_class": {"type": "object", "additionalProperties": false, "minProperties": 1, "properties": {"rate_limit": {"type": "integer", "minimum": 1, "maximum": 1000000}, "usage_limit": {"type": "integer", "minimum": 1, "maximum": 1000000}, "authentication": {"type": "integer", "minimum": 1, "maximum": 1000000}, "authorization": {"type": "integer", "minimum": 1, "maximum": 1000000}, "service_unavailable": {"type": "integer", "minimum": 1, "maximum": 1000000}, "timeout": {"type": "integer", "minimum": 1, "maximum": 1000000}, "invalid_request": {"type": "integer", "minimum": 1, "maximum": 1000000}, "model_unavailable": {"type": "integer", "minimum": 1, "maximum": 1000000}, "response_contract": {"type": "integer", "minimum": 1, "maximum": 1000000}, "unknown_provider_error": {"type": "integer", "minimum": 1, "maximum": 1000000}}}, "last_error": {"type": "object", "additionalProperties": false, "required": ["class", "retryable", "retry_after_seconds", "resume_recommended", "source"], "properties": {"class": {"enum": ["rate_limit", "usage_limit", "authentication", "authorization", "service_unavailable", "timeout", "invalid_request", "model_unavailable", "response_contract", "unknown_provider_error"]}, "retryable": {"type": "boolean"}, "retry_after_seconds": {"type": ["integer", "null"], "minimum": 1, "maximum": 86400}, "resume_recommended": {"type": "boolean"}, "source": {"const": "sanitized_stderr_classifier"}}}, "recovered": {"type": "boolean"}}}]}}, "allOf": [{"if": {"required": ["provider_error"], "properties": {"provider_error": {"type": "object"}}}, "then": {"properties": {"status": {"const": "failed"}, "error_category": {"const": "provider_error"}}}}, {"if": {"required": ["error_category"], "properties": {"error_category": {"const": "provider_error"}}}, "then": {"required": ["provider_error"], "properties": {"provider_error": {"type": "object"}}}}, {"if": {"required": ["provider_error"], "properties": {"provider_error": {"type": "object"}}}, "then": {"required": ["provider_failure_history"], "properties": {"provider_failure_history": {"type": "object"}}}}]}
  }
}

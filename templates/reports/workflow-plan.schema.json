{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Workflow Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "repo", "generated_at", "source", "profile", "profile_version", "definition_ref", "definition_sha256", "reports_dir", "mode", "safety", "summary", "stages"],
  "properties": {
    "schema_version": {"const": "1"}, "run_id": {"type": "string"}, "repo": {"type": "string"},
    "generated_at": {"type": "string"}, "source": {"const": "gra-run-plan"},
    "profile": {"type": "string"}, "profile_version": {"type": "string"},
    "definition_ref": {"type": "string"}, "definition_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reports_dir": {"type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001F\\u007F])[^\\\\]+$"},
    "mode": {"const": "plan"},
    "safety": {"type": "object", "additionalProperties": false, "required": ["commands_executed", "network_allowed", "github_mutation_allowed", "raw_payloads_copied"], "properties": {"commands_executed": {"const": false}, "network_allowed": {"const": false}, "github_mutation_allowed": {"const": false}, "raw_payloads_copied": {"const": false}}},
    "summary": {"type": "object", "additionalProperties": false, "required": ["stage_count", "planned_count", "skipped_by_scope_count"], "properties": {"stage_count": {"type": "integer", "minimum": 1, "maximum": 64}, "planned_count": {"type": "integer", "minimum": 0}, "skipped_by_scope_count": {"type": "integer", "minimum": 0}}},
    "stages": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["id", "status", "depends_on", "required_inputs", "outputs", "command", "skip_reason", "network_allowed", "mutation"], "properties": {"id": {"type": "string"}, "status": {"enum": ["planned", "skipped_by_scope"]}, "depends_on": {"type": "array", "items": {"type": "string"}}, "required_inputs": {"type": "array", "items": {"type": "string"}}, "outputs": {"type": "array", "items": {"type": "string"}}, "command": {"type": "array", "items": {"type": "string"}}, "skip_reason": {"type": ["string", "null"]}, "network_allowed": {"const": false}, "mutation": {"const": "local-artifacts-only"}}}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor Findings",
  "type": "object",
  "required": [
    "run_id",
    "repo",
    "commit",
    "generated_at",
    "findings"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "commit": {
      "type": "string"
    },
    "visibility": {
      "type": [
        "string",
        "null"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "fingerprint",
          "title",
          "severity",
          "confidence",
          "status",
          "category",
          "affected_locations",
          "entry_point",
          "trust_boundary",
          "source_to_sink",
          "root_cause",
          "evidence",
          "impact",
          "validation_status",
          "minimal_remediation",
          "regression_test_idea",
          "issue_title",
          "issue_body_file",
          "issue_recommended",
          "labels"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "Critical",
              "High",
              "Medium",
              "Low",
              "Informational"
            ]
          },
          "confidence": {
            "enum": [
              "High",
              "Medium",
              "Low"
            ]
          },
          "status": {
            "enum": [
              "Confirmed",
              "Probable",
              "Potential",
              "Informational",
              "Invalid",
              "Needs human review"
            ]
          },
          "category": {
            "type": "string"
          },
          "affected_locations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "file"
              ],
              "properties": {
                "file": {
                  "type": "string"
                },
                "line": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "end_line": {
                  "type": [
                    "integer",
                    "null"
                  ]
                }
              }
            }
          },
          "entry_point": {
            "type": "string"
          },
          "trust_boundary": {
            "type": "string"
          },
          "source_to_sink": {
            "type": "string"
          },
          "root_cause": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "validation_status": {
            "type": "string"
          },
          "minimal_remediation": {
            "type": "string"
          },
          "regression_test_idea": {
            "type": "string"
          },
          "issue_title": {
            "type": "string"
          },
          "issue_body_file": {
            "type": "string"
          },
          "issue_recommended": {
            "type": "boolean"
          },
          "public_disclosure_risk": {
            "enum": [
              "Low",
              "Medium",
              "High"
            ]
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "lifecycle": {
            "enum": [
              "Candidate",
              "Probable",
              "Confirmed",
              "Invalid",
              "Accepted Risk",
              "Informational",
              "Needs human review"
            ]
          },
          "bug_existence": {
            "enum": [
              "Confirmed",
              "Probable",
              "Potential",
              "Invalid",
              "Not assessed"
            ]
          },
          "attacker_reachability": {
            "enum": [
              "Confirmed",
              "Probable",
              "Potential",
              "Invalid",
              "Not assessed"
            ]
          },
          "boundary_crossing": {
            "enum": [
              "Confirmed",
              "Probable",
              "Potential",
              "Invalid",
              "Not assessed"
            ]
          },
          "impact_assessment": {
            "enum": [
              "Confirmed",
              "Probable",
              "Potential",
              "Invalid",
              "Not assessed"
            ]
          },
          "chain_membership": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^CHAIN-[0-9]{3,}$"
            }
          },
          "assessment_notes": {
            "type": "object",
            "properties": {
              "bug_existence": {
                "type": "string"
              },
              "attacker_reachability": {
                "type": "string"
              },
              "boundary_crossing": {
                "type": "string"
              },
              "impact_assessment": {
                "type": "string"
              }
            }
          },
          "scanner_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tool": {
                  "type": "string"
                },
                "rule_id": {
                  "type": "string"
                },
                "result_id": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              }
            }
          },
          "variant_of": {
            "type": [
              "string",
              "null"
            ]
          },
          "cwe": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "owasp": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "safe_validation_methods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "taxonomies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "id",
                "label"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          },
          "external_source": {
            "type": "object",
            "required": [
              "source",
              "external_id",
              "input_index",
              "imported_at"
            ],
            "properties": {
              "source": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
              },
              "source_version": {
                "type": "string"
              },
              "external_id": {
                "type": "string"
              },
              "input_index": {
                "type": "integer",
                "minimum": 0
              },
              "imported_at": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "no_findings": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "rationale",
        "source_stage",
        "recorded_at",
        "recorded_by",
        "target_metadata",
        "safety"
      ],
      "properties": {
        "schema_version": {
          "const": "1"
        },
        "status": {
          "enum": [
            "no-confirmed-findings"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "source_stage": {
          "enum": [
            "manual-review",
            "other",
            "recon",
            "scanner-triage",
            "target-queue",
            "validation"
          ]
        },
        "recorded_at": {
          "type": "string"
        },
        "recorded_by": {
          "const": "gra-no-findings"
        },
        "reviewer": {
          "type": "string"
        },
        "target_metadata": {
          "type": "object",
          "required": [
            "run_id",
            "repo",
            "commit",
            "visibility"
          ],
          "properties": {
            "run_id": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "branch": {
              "type": [
                "string",
                "null"
              ]
            },
            "commit": {
              "type": "string"
            },
            "visibility": {
              "type": "string"
            }
          }
        },
        "safety": {
          "type": "object",
          "required": [
            "no_finding_bodies",
            "issue_bodies_created",
            "raw_evidence_copied",
            "safe_for_public_summary_after_review"
          ],
          "properties": {
            "no_finding_bodies": {
              "const": true
            },
            "issue_bodies_created": {
              "const": false
            },
            "raw_evidence_copied": {
              "const": false
            },
            "safe_for_public_summary_after_review": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}

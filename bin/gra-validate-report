#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any, Dict, List

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from version import auditor_version
from taxonomies import (  # noqa: E402
    TaxonomyAliasError,
    TaxonomyProfileError,
    load_taxonomy_aliases,
    load_taxonomy_profiles,
    taxonomy_label_map,
)
from run_events import append_command_event, reports_dir as configured_reports_dir, start_command_event  # noqa: E402
from validators.common import load_schema as load_schema_from_root  # noqa: E402
from validators.advanced import ADVANCED_VALIDATOR_ORDER  # noqa: E402
from validators.registry import ValidationContext, report_validator_registry  # noqa: E402

def find_findings(run: Path) -> Path:
    candidates = [configured_reports_dir(run) / "findings.json"]
    for p in candidates:
        if p.exists():
            return p
    raise FileNotFoundError(f"findings.json not found under {run}")


def infer_run_dir(findings_path: Path) -> Path:
    for candidate in findings_path.parents:
        if not (candidate / "context.json").is_file():
            continue
        reports = configured_reports_dir(candidate)
        if findings_path == reports / "findings.json":
            return candidate
    return findings_path.parent.parent


def load_schema(name: str) -> Dict[str, Any]:
    """Backward-compatible schema loader for remaining in-file validators."""

    return load_schema_from_root(LAB_ROOT, name)


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate GenAI Repo Auditor report contract")
    parser.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    parser.add_argument("--run", help="Run directory")
    parser.add_argument("--findings", help="Path to findings.json")
    args = parser.parse_args()

    if not args.run and not args.findings:
        parser.error("one of --run or --findings is required")

    try:
        if args.run:
            run_dir = Path(args.run).resolve()
            path = Path(args.findings).resolve() if args.findings else find_findings(run_dir)
        else:
            path = Path(args.findings).resolve()
            run_dir = infer_run_dir(path)
    except (FileNotFoundError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2
    started_at, started_perf = start_command_event()

    def finish(exit_code: int) -> int:
        append_command_event(
            run_dir,
            command="gra-validate-report",
            phase="validate",
            target_id=None,
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            input_artifact_paths=[path],
            output_artifact_paths=[],
        )
        return exit_code

    errors: List[str] = []
    try:
        data: Dict[str, Any] = json.loads(path.read_text(encoding="utf-8"))
    except Exception as e:
        print(f"ERROR: invalid JSON: {e}", file=sys.stderr)
        return finish(1)

    taxonomy_profiles: dict[str, dict[str, Any]] = {}
    taxonomy_labels: dict[tuple[str, str], str] = {}
    taxonomy_aliases: dict[str, Any] = {}
    taxonomy_profiles_loaded = True
    try:
        taxonomy_profiles = load_taxonomy_profiles()
        taxonomy_labels = taxonomy_label_map(taxonomy_profiles)
        taxonomy_aliases = load_taxonomy_aliases()
    except (TaxonomyProfileError, TaxonomyAliasError) as exc:
        taxonomy_profiles_loaded = False
        errors.append(f"taxonomy profiles/aliases: {exc}")

    validation_context = ValidationContext(
        lab_root=LAB_ROOT,
        run_dir=run_dir,
        findings_path=path,
        findings_data=data,
        errors=errors,
        taxonomy_profiles=taxonomy_profiles,
        taxonomy_labels=taxonomy_labels,
        taxonomy_aliases=taxonomy_aliases,
        taxonomy_profiles_loaded=taxonomy_profiles_loaded,
    )
    validator_registry = report_validator_registry()
    validation_results = validator_registry.run(
        validation_context,
        ["findings", "targets", "scanner_index", *ADVANCED_VALIDATOR_ORDER, "run_manifest"],
    )
    findings = validation_context.findings
    scanner_index_validated = validation_results["scanner_index"]
    scanner_readiness_validated = validation_results["scanner_readiness"]
    dependencies_validated = validation_results["dependencies"]
    chains_validated = validation_results["chains"]
    adversarial_validation_validated = validation_results["adversarial_validation"]
    proofs_validated = validation_results["proofs"]
    remediation_candidates_validated = validation_results["remediation_candidates"]
    patch_validations_validated = validation_results["patch_validations"]
    novelty_validated = validation_results["novelty_ledger"]
    traces_validated = validation_results["traces"]
    metrics_validated = validation_results["metrics"]
    workflow_profile_validated = validation_results["workflow_profile"]
    workflow_execution_validated = validation_results["workflow_execution"]
    benchmark_validated = validation_results["benchmark"]
    evidence_graph_validated = validation_results["evidence_graph"]
    imported_findings_validated = validation_results["imported_findings"]
    issue_ledger_validated = validation_results["issue_ledger"]
    duplicate_decisions_validated = validation_results["duplicate_decisions"]
    run_state_validated = validation_results["run_state"]
    command_events_validated = validation_results["command_events"]
    run_manifest_validated = validation_results["run_manifest"]

    if errors:
        for e in errors:
            print(f"ERROR: {e}", file=sys.stderr)
        print(f"Validation failed: {len(errors)} error(s)", file=sys.stderr)
        return finish(1)

    print(f"OK: {path}")
    print(f"Findings: {len(findings)}")
    if validation_results["targets"]:
        print("Targets: validated")
    if scanner_index_validated:
        print("Scanner index: validated")
    if scanner_readiness_validated:
        print("Scanner readiness: validated")
    if dependencies_validated:
        print("Dependencies: validated")
    if chains_validated:
        print("Chains: validated")
    if adversarial_validation_validated:
        print("Adversarial validations: validated")
    if proofs_validated:
        print("Proofs: validated")
    if remediation_candidates_validated:
        print("Remediation candidates: validated")
    if patch_validations_validated:
        print("Patch validations: validated")
    if novelty_validated:
        print("Known findings novelty ledger: validated")
    if traces_validated:
        print("Traces: validated")
    if metrics_validated:
        print("Metrics: validated")
    if workflow_profile_validated:
        print("Workflow profile: validated")
    if workflow_execution_validated:
        print("Workflow execution: validated")
    if benchmark_validated:
        print("Benchmark: validated")
    if evidence_graph_validated:
        print("Evidence graph: validated")
    if imported_findings_validated:
        print("Imported findings: validated")
    if issue_ledger_validated:
        print("Issue ledger: validated")
    if duplicate_decisions_validated:
        print("Duplicate decisions: validated")
    if run_state_validated:
        print("Run state: validated")
    if command_events_validated:
        print("Command events: validated")
    if run_manifest_validated:
        print("Run manifest: validated")
    return finish(0)


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path
from typing import Any

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import env_from_context, find_finding, load_context, load_findings, load_json, render_template, run_codex_exec, safe_run_artifact_destination, slug, utc_now, write_run_artifact_json, write_run_artifact_text
from run_events import append_command_event, reports_dir as configured_reports_dir, start_command_event

HIGH_SEVERITIES = {'Critical', 'High'}
PROOFABLE_STATUSES = {'Confirmed', 'Probable', 'Potential'}


def require_findings_file(run_dir: Path) -> None:
    findings_path = configured_reports_dir(run_dir) / 'findings.json'
    if not findings_path.exists():
        raise FileNotFoundError(f'findings.json not found: {findings_path}')


def subject_record(finding_id: str, finding: dict[str, Any]) -> dict[str, Any]:
    return {
        'finding_id': finding_id,
        'finding': finding,
    }


def select_findings(run_dir: Path, args: argparse.Namespace) -> tuple[str, list[dict[str, Any]]]:
    if args.finding:
        require_findings_file(run_dir)
        finding = find_finding(run_dir, args.finding)
        return args.finding, [subject_record(args.finding, finding)]

    require_findings_file(run_dir)
    subjects: list[dict[str, Any]] = []
    for finding in load_findings(run_dir):
        severity = str(finding.get('severity') or '')
        status = str(finding.get('status') or '')
        finding_id = str(finding.get('id') or '')
        if finding_id and severity in HIGH_SEVERITIES and status in PROOFABLE_STATUSES:
            subjects.append(subject_record(finding_id, finding))
    return 'critical-high', subjects


def render_proofs_markdown(run_dir: Path, proofs_data: dict[str, Any]) -> None:
    reports = configured_reports_dir(run_dir)

    def bullet_list(value: Any) -> list[str]:
        if not isinstance(value, list):
            return []
        return [f'- {item}' for item in value]

    def command_bullets(value: Any) -> list[str]:
        if not isinstance(value, list):
            return []
        bullets: list[str] = []
        for item in value:
            if not isinstance(item, dict):
                continue
            argv = item.get('argv')
            if not isinstance(argv, list):
                continue
            argv_text = ' '.join(str(arg) for arg in argv if isinstance(arg, str))
            if not argv_text:
                continue
            metadata = (
                f"read_only={item.get('read_only')}, network={item.get('network')}, "
                f"requires_credentials={item.get('requires_credentials')}, cwd_scope={item.get('cwd_scope')}"
            )
            bullets.append(f'- `{argv_text}` ({metadata})')
        return bullets

    lines = [
        '# Safe Local Proofs',
        '',
        'Local/private by default. This report is for benign defensive validation only.',
        'It must not include exploit payloads, credential extraction, live-service probing, or weaponized steps.',
        '',
        f"Run ID: `{proofs_data.get('run_id', '')}`",
        f"Repository: `{proofs_data.get('repo', '')}`",
        f"Generated at: `{proofs_data.get('generated_at', '')}`",
        '',
        '| ID | Finding | Type | Status | Safe by design | Evidence |',
        '|---|---|---|---|---|---|',
    ]
    for proof in proofs_data.get('proofs') or []:
        if not isinstance(proof, dict):
            continue
        evidence = str(proof.get('evidence') or '').replace('|', '\\|').replace('\n', ' ')
        lines.append(
            '| '
            f"{proof.get('id', '')} | {proof.get('finding_id', '')} | {proof.get('proof_type', '')} | "
            f"{proof.get('status', '')} | {proof.get('safe_by_design', '')} | {evidence} |"
        )
        files_created = proof.get('files_created')
        if isinstance(files_created, list) and files_created:
            lines.extend(['', f"Files for {proof.get('id', '')}:", *bullet_list(files_created)])
        command_lines = command_bullets(proof.get('commands_run'))
        if command_lines:
            lines.extend(['', f"Commands for {proof.get('id', '')}:", *command_lines])
        limitations = proof.get('limitations')
        if isinstance(limitations, list) and limitations:
            lines.extend(['', f"Limitations for {proof.get('id', '')}:", *bullet_list(limitations)])
    lines.append('')
    write_run_artifact_text(run_dir, reports / 'PROOFS.md', '\n'.join(lines))


def ensure_proof_artifacts(run_dir: Path, ctx: dict[str, Any]) -> None:
    proofs_path = configured_reports_dir(run_dir) / 'proofs.json'
    if not proofs_path.exists():
        return
    safe_run_artifact_destination(run_dir, proofs_path)
    data = load_json(proofs_path, {}) or {}
    if not isinstance(data, dict):
        return
    data.setdefault('run_id', ctx.get('run_id', run_dir.name))
    data.setdefault('repo', ctx.get('repo', ''))
    data.setdefault('branch', ctx.get('branch', ''))
    data.setdefault('commit', ctx.get('commit', ''))
    data.setdefault('generated_at', utc_now())
    data.setdefault('proofs', [])
    write_run_artifact_json(run_dir, proofs_path, data)
    render_proofs_markdown(run_dir, data)


def main() -> int:
    p = argparse.ArgumentParser(description='Generate safe local proof artifacts for existing findings')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    subjects = p.add_mutually_exclusive_group(required=True)
    subjects.add_argument('--finding', help='Finding ID to validate, e.g. SEC-001')
    subjects.add_argument('--all-critical-high', action='store_true', help='Generate safe local proof artifacts for all Critical/High findings with Confirmed/Probable/Potential status')
    p.add_argument('--mode', choices=['exec', 'goal'], default='exec')
    p.add_argument('--model', default='gpt-5.5')
    p.add_argument('--effort', default='xhigh')
    p.add_argument('--network', action='store_true', help='Allow Codex sandbox network access. Not recommended.')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    reports = configured_reports_dir(run_dir)
    reports_ref = reports.relative_to(run_dir).as_posix()
    input_artifacts = [run_dir / 'context.json', reports / 'findings.json']
    output_artifacts: list[Path] = []
    event_subject_id = args.finding or ('critical-high' if args.all_critical_high else None)

    def finish(exit_code: int, *, status: str | None = None, error_category: str | None = None) -> int:
        append_command_event(
            run_dir,
            command='gra-proofs',
            phase='goal' if args.mode == 'goal' else 'proof',
            subject_id=event_subject_id,
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            status=status,
            error_category=error_category,
            model=args.model,
            effort=args.effort,
            network_allowed=args.network,
            sandbox_profile='workspace-write',
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            failure_mode='warn' if exit_code != 0 else 'block',
        )
        return exit_code

    try:
        safe_run_artifact_destination(run_dir, reports / 'proofs.json')
        safe_run_artifact_destination(run_dir, reports / 'PROOFS.md')
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return finish(2, error_category='output_validation')

    ctx = load_context(run_dir)
    try:
        selection_id, selected_findings = select_findings(run_dir, args)
    except (FileNotFoundError, KeyError) as exc:
        print(str(exc), file=sys.stderr)
        return finish(2, error_category='input_validation')
    event_subject_id = selection_id

    if not selected_findings:
        print('No matching findings selected for safe local proof generation.')
        empty_proofs = {
            'run_id': ctx.get('run_id', run_dir.name),
            'repo': ctx.get('repo', ''),
            'branch': ctx.get('branch', ''),
            'commit': ctx.get('commit', ''),
            'generated_at': utc_now(),
            'proofs': [],
        }
        proofs_json = reports / 'proofs.json'
        proofs_markdown = reports / 'PROOFS.md'
        write_run_artifact_json(run_dir, proofs_json, empty_proofs)
        render_proofs_markdown(run_dir, empty_proofs)
        output_artifacts.extend([proofs_json, proofs_markdown])
        return finish(0, status='skipped')

    selection_slug = slug(selection_id)
    subjects_path = reports / 'proofs' / f'{selection_slug}.subjects.json'
    subject_payload = {
        'run_id': ctx.get('run_id', run_dir.name),
        'repo': ctx.get('repo', ''),
        'branch': ctx.get('branch', ''),
        'commit': ctx.get('commit', ''),
        'generated_at': utc_now(),
        'selection': selection_id,
        'subjects': selected_findings,
    }
    write_run_artifact_json(run_dir, subjects_path, subject_payload)
    output_artifacts.append(subjects_path)

    env = env_from_context(run_dir, {
        'PROOF_SELECTION': selection_id,
        'PROOF_SUBJECTS_FILE': str(subjects_path.relative_to(run_dir)),
        'PROOFS_OUTPUT_JSON': f'{reports_ref}/proofs.json',
        'PROOFS_OUTPUT_MD': f'{reports_ref}/PROOFS.md',
        'PROOFS_DIR': f'{reports_ref}/proofs',
    })

    if args.mode == 'goal':
        prompt = run_dir / 'prompts' / 'goal' / f'safe-proof-{selection_slug}.goal.md'
        render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'goal' / 'safe-proof.goal.md', prompt, env)
        output_artifacts.append(prompt)
        print('Prepared supervised /goal safe local proof run.')
        print(f'Run directory: {run_dir}')
        print(f'Subjects file: {subjects_path}')
        print(f'Goal prompt: {prompt}')
        network_value = 'true' if args.network else 'false'
        print('\nStart Codex:')
        print(f'  codex --cd "{run_dir}" --skip-git-repo-check --model "{args.model}" --enable goals --sandbox workspace-write --ask-for-approval on-request -c \'model_reasoning_effort="{args.effort}"\' -c \'web_search="disabled"\' -c \'sandbox_workspace_write.network_access={network_value}\'')
        print('\nThen paste the contents of the goal prompt.')
        return finish(0)

    prompt = run_dir / 'prompts' / 'exec' / f'safe-proof-{selection_slug}.prompt.md'
    render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'exec' / 'safe-proof.prompt.md', prompt, env)
    output_artifacts.append(prompt)
    print(f'Running Codex safe local proof generation for {selection_id}')
    final_path = run_dir / f'codex-safe-proof-{selection_slug}-final.md'
    events_path = run_dir / f'codex-safe-proof-{selection_slug}-events.jsonl'
    stderr_path = run_dir / f'codex-safe-proof-{selection_slug}-stderr.txt'
    status = run_codex_exec(
        run_dir=run_dir,
        prompt_file=prompt,
        model=args.model,
        effort=args.effort,
        network=args.network,
        output_last=final_path,
        events_file=events_path,
        stderr_file=stderr_path,
    )
    ensure_proof_artifacts(run_dir, ctx)
    output_artifacts.extend([final_path, events_path, stderr_path, reports / 'proofs.json', reports / 'PROOFS.md'])
    print(f'Codex status: {status}')
    print(f'Proof subjects: {subjects_path}')
    print(f'Proof report: {reports / "PROOFS.md"}')
    print(f'Proof JSON: {reports / "proofs.json"}')
    return finish(status)


if __name__ == '__main__':
    raise SystemExit(main())

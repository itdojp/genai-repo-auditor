#!/usr/bin/env python3
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path
from typing import Any

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import env_from_context, find_finding, load_context, load_findings, load_json, render_template, run_codex_exec, slug, utc_now, write_json
from patch_validation import PatchValidationError, validate_selected_patches
from sandbox_profiles import PROFILE_IDS

HIGH_SEVERITIES = {'Critical', 'High'}
REMEDIABLE_STATUSES = {'Confirmed', 'Probable', 'Potential'}
REMEDIATION_DIR = Path('reports') / 'remediation'
REMEDIATION_JSON = REMEDIATION_DIR / 'remediation-candidates.json'
REMEDIATION_MD = REMEDIATION_DIR / 'REMEDIATION_CANDIDATES.md'


def require_findings_file(run_dir: Path) -> None:
    findings_path = run_dir / 'reports' / 'findings.json'
    if not findings_path.exists():
        raise FileNotFoundError(f'findings.json not found: {findings_path}')


def safe_subject_segment(finding_id: str) -> str:
    segment = re.sub(r'[^A-Za-z0-9_.-]+', '-', finding_id).strip('.-')
    if not segment:
        return 'finding'
    if segment in {'.', '..'} or '..' in segment.split('/'):
        return slug(finding_id)
    return segment


def candidate_id(index: int) -> str:
    return f'PATCH-{index:03d}'


def subject_record(index: int, finding_id: str, finding: dict[str, Any]) -> dict[str, Any]:
    subject_dir = REMEDIATION_DIR / safe_subject_segment(finding_id)
    return {
        'candidate_id': candidate_id(index),
        'finding_id': finding_id,
        'finding': finding,
        'output_dir': subject_dir.as_posix(),
        'patch_file': (subject_dir / 'patch.diff').as_posix(),
        'notes_file': (subject_dir / 'notes.md').as_posix(),
        'subject_file': (subject_dir / 'subject.json').as_posix(),
        'status': 'draft',
        'requires_human_review': True,
    }


def select_findings(run_dir: Path, args: argparse.Namespace) -> tuple[str, list[dict[str, Any]]]:
    require_findings_file(run_dir)
    if args.finding:
        finding = find_finding(run_dir, args.finding)
        return args.finding, [subject_record(1, args.finding, finding)]

    subjects: list[dict[str, Any]] = []
    for finding in load_findings(run_dir):
        severity = str(finding.get('severity') or '')
        status = str(finding.get('status') or '')
        finding_id = str(finding.get('id') or '')
        if finding_id and severity in HIGH_SEVERITIES and status in REMEDIABLE_STATUSES:
            subjects.append(subject_record(len(subjects) + 1, finding_id, finding))
    return 'critical-high', subjects


def write_subject_artifacts(run_dir: Path, ctx: dict[str, Any], selection_id: str, subjects: list[dict[str, Any]]) -> Path:
    for subject in subjects:
        subject_file = run_dir / str(subject['subject_file'])
        subject_file_payload = {
            'run_id': ctx.get('run_id', run_dir.name),
            'repo': ctx.get('repo', ''),
            'branch': ctx.get('branch', ''),
            'commit': ctx.get('commit', ''),
            'generated_at': utc_now(),
            **subject,
        }
        write_json(subject_file, subject_file_payload)

    selection_slug = slug(selection_id)
    subjects_path = run_dir / REMEDIATION_DIR / f'{selection_slug}.subjects.json'
    subject_payload = {
        'run_id': ctx.get('run_id', run_dir.name),
        'repo': ctx.get('repo', ''),
        'branch': ctx.get('branch', ''),
        'commit': ctx.get('commit', ''),
        'generated_at': utc_now(),
        'selection': selection_id,
        'subjects': subjects,
    }
    write_json(subjects_path, subject_payload)
    return subjects_path


def render_remediation_markdown(run_dir: Path, data: dict[str, Any]) -> None:
    lines = [
        '# Remediation Candidates',
        '',
        'Local/private by default. These are draft-only candidate patches for human review.',
        'The GenAI Repo Auditor does not apply these patches, push branches, open PRs, or create issues from this workflow.',
        '',
        f"Run ID: `{data.get('run_id', '')}`",
        f"Repository: `{data.get('repo', '')}`",
        f"Generated at: `{data.get('generated_at', '')}`",
        '',
        '| ID | Finding | Status | Patch file | Human review | Summary |',
        '|---|---|---|---|---|---|',
    ]
    for item in data.get('candidates') or []:
        if not isinstance(item, dict):
            continue
        summary = str(item.get('summary') or '').replace('|', '\\|').replace('\n', ' ')
        lines.append(
            '| '
            f"{item.get('id', '')} | {item.get('finding_id', '')} | {item.get('status', '')} | "
            f"{item.get('patch_file', '')} | {item.get('requires_human_review', '')} | {summary} |"
        )
        for label, key in [
            ('Files touched', 'files_touched'),
            ('Expected validation', 'expected_validation'),
            ('Limitations', 'limitations'),
        ]:
            values = item.get(key)
            if isinstance(values, list) and values:
                lines.extend(['', f"{label} for {item.get('id', '')}:"])
                lines.extend(f'- {value}' for value in values)
        notes_file = item.get('notes_file')
        if isinstance(notes_file, str) and notes_file.strip():
            lines.extend(['', f"Notes for {item.get('id', '')}: `{notes_file}`"])
    lines.append('')
    (run_dir / REMEDIATION_MD).write_text('\n'.join(lines), encoding='utf-8')


def ensure_remediation_artifacts(run_dir: Path, ctx: dict[str, Any]) -> None:
    remediation_path = run_dir / REMEDIATION_JSON
    if not remediation_path.exists():
        return
    data = load_json(remediation_path, {}) or {}
    if not isinstance(data, dict):
        return
    data.setdefault('schema_version', '1')
    data.setdefault('run_id', ctx.get('run_id', run_dir.name))
    data.setdefault('repo', ctx.get('repo', ''))
    data.setdefault('branch', ctx.get('branch', ''))
    data.setdefault('commit', ctx.get('commit', ''))
    data.setdefault('generated_at', utc_now())
    data.setdefault('candidates', [])
    write_json(remediation_path, data)
    render_remediation_markdown(run_dir, data)


def main() -> int:
    p = argparse.ArgumentParser(description='Generate draft-only remediation candidate artifacts for existing findings')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    subjects = p.add_mutually_exclusive_group(required=True)
    subjects.add_argument('--finding', help='Finding ID to remediate, e.g. SEC-001')
    subjects.add_argument('--all-critical-high', action='store_true', help='Generate draft remediation candidates for all Critical/High findings with Confirmed/Probable/Potential status')
    p.add_argument('--mode', choices=['exec', 'goal'], default='exec')
    p.add_argument('--validate', action='store_true', help='Validate existing remediation candidate patches in a disposable workspace instead of generating new candidates')
    p.add_argument('--sandbox-profile', choices=PROFILE_IDS, default='local-test', help='Sandbox profile for patch validation; default: local-test')
    p.add_argument('--build-command', action='append', default=[], help='Operator-approved build/syntax command to run in the disposable validation workspace; repeatable')
    p.add_argument('--test-command', action='append', default=[], help='Operator-approved targeted test command to run in the disposable validation workspace; repeatable')
    p.add_argument('--command-timeout', type=int, default=60, help='Timeout in seconds for each validation command; default: 60')
    p.add_argument('--max-changed-paths', type=int, default=20, help='Maximum changed files for bounded diff validation; default: 20')
    p.add_argument('--model', default='gpt-5.5')
    p.add_argument('--effort', default='xhigh')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    if args.command_timeout <= 0:
        print('--command-timeout must be greater than zero', file=sys.stderr)
        return 2
    if args.max_changed_paths <= 0:
        print('--max-changed-paths must be greater than zero', file=sys.stderr)
        return 2
    ctx = load_context(run_dir)
    try:
        selection_id, selected_subjects = select_findings(run_dir, args)
    except (FileNotFoundError, KeyError) as exc:
        print(str(exc), file=sys.stderr)
        return 2

    if not selected_subjects:
        print('No matching findings selected for remediation candidate workflow.')
        return 0

    if args.validate:
        try:
            results = validate_selected_patches(
                run_dir=run_dir,
                finding_id=args.finding,
                all_critical_high=bool(args.all_critical_high),
                sandbox_profile=args.sandbox_profile,
                build_commands=args.build_command,
                test_commands=args.test_command,
                command_timeout=args.command_timeout,
                max_changed_paths=args.max_changed_paths,
            )
        except PatchValidationError as exc:
            print(f'Patch validation failed to start: {exc}', file=sys.stderr)
            return 2
        failed = False
        print('Patch validation results:')
        for report, out_json, out_md in results:
            if report.get('final_status') == 'failed':
                failed = True
            print(
                f"- {report.get('patch_id')} / {report.get('finding_id')}: "
                f"final_status={report.get('final_status')}, patch_applied={report.get('patch_applied')}, "
                f"json={out_json}, markdown={out_md}"
            )
        return 1 if failed else 0

    selection_slug = slug(selection_id)
    subjects_path = write_subject_artifacts(run_dir, ctx, selection_id, selected_subjects)

    env = env_from_context(run_dir, {
        'REMEDIATION_SELECTION': selection_id,
        'REMEDIATION_SUBJECTS_FILE': str(subjects_path.relative_to(run_dir)),
        'REMEDIATION_OUTPUT_JSON': REMEDIATION_JSON.as_posix(),
        'REMEDIATION_OUTPUT_MD': REMEDIATION_MD.as_posix(),
        'REMEDIATION_DIR': REMEDIATION_DIR.as_posix(),
    })

    if args.mode == 'goal':
        prompt = run_dir / 'prompts' / 'goal' / f'remediate-{selection_slug}.goal.md'
        render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'goal' / 'remediate.goal.md', prompt, env)
        print('Prepared supervised /goal remediation candidate run.')
        print(f'Run directory: {run_dir}')
        print(f'Subjects file: {subjects_path}')
        print(f'Goal prompt: {prompt}')
        print('\nStart Codex:')
        print(f'  codex --cd "{run_dir}" --skip-git-repo-check --model "{args.model}" --enable goals --sandbox workspace-write --ask-for-approval on-request -c \'model_reasoning_effort="{args.effort}"\' -c \'web_search="disabled"\' -c \'sandbox_workspace_write.network_access=false\'')
        print('\nThen paste the contents of the goal prompt.')
        return 0

    prompt = run_dir / 'prompts' / 'exec' / f'remediate-{selection_slug}.prompt.md'
    render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'exec' / 'remediate.prompt.md', prompt, env)
    print(f'Running Codex remediation candidate generation for {selection_id}')
    status = run_codex_exec(
        run_dir=run_dir,
        prompt_file=prompt,
        model=args.model,
        effort=args.effort,
        network=False,
        output_last=run_dir / f'codex-remediate-{selection_slug}-final.md',
        events_file=run_dir / f'codex-remediate-{selection_slug}-events.jsonl',
        stderr_file=run_dir / f'codex-remediate-{selection_slug}-stderr.txt',
    )
    ensure_remediation_artifacts(run_dir, ctx)
    print(f'Codex status: {status}')
    print(f'Remediation subjects: {subjects_path}')
    print(f'Remediation report: {run_dir / REMEDIATION_MD}')
    print(f'Remediation JSON: {run_dir / REMEDIATION_JSON}')
    return status


if __name__ == '__main__':
    raise SystemExit(main())

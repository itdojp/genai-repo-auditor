#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from scanner_adapters import (  # noqa: E402
    ADAPTERS,
    NETWORK_POLICIES,
    ScannerAdapterError,
    build_scan_plan,
    list_adapters,
    planning_environment_path,
    validate_run_directory,
)
from sandbox_profiles import PROFILE_IDS  # noqa: E402
from version import auditor_version  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="List and safely plan approved local scanner adapters")
    parser.add_argument("--version", action="version", version=f"%(prog)s {auditor_version(LAB_ROOT)}")
    parser.add_argument("--run", required=True, type=Path, help="Run directory")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--list", action="store_true", help="List adapter capabilities and local binary readiness")
    mode.add_argument("--plan", action="store_true", help="Plan only; this is the default and never executes a scanner")
    parser.add_argument("--tool", help="Registered scanner adapter id")
    parser.add_argument("--sandbox-profile", choices=PROFILE_IDS, default="container", help="Declared execution sandbox for the plan")
    parser.add_argument("--network-policy", choices=NETWORK_POLICIES, default="disabled", help="Declared network policy; disabled by default")
    parser.add_argument("--json", action="store_true", help="Print the machine-readable contract")
    args = parser.parse_args()

    if args.list and args.tool:
        parser.error("--tool cannot be used with --list")
    if args.list and args.network_policy != "disabled":
        parser.error("--network-policy cannot enable network for --list")
    if args.list and args.sandbox_profile != "container":
        parser.error("--sandbox-profile is only used for planning")
    if not args.list and not args.tool:
        parser.error("--tool is required for planning")

    try:
        run_dir = validate_run_directory(args.run)
        if args.list:
            payload = list_adapters(path_env=planning_environment_path())
        else:
            payload = build_scan_plan(
                run_dir,
                adapter_id=args.tool,
                sandbox_profile=args.sandbox_profile,
                network_policy=args.network_policy,
                path_env=planning_environment_path(),
            )
    except (OSError, ValueError, ScannerAdapterError) as exc:
        print(f"gra-scan: {exc}", file=sys.stderr)
        return 2

    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False, sort_keys=True))
    elif args.list:
        print("Available scanner adapters (no scanner executed):")
        for adapter in payload["adapters"]:
            readiness = adapter["readiness"]
            print(
                f"- {adapter['id']}: executable={adapter['executable']} "
                f"available={'yes' if readiness['executable_available'] else 'no'} "
                f"network={'required' if adapter['network_required'] else 'disabled'} "
                f"classification={adapter['result_classification']}"
            )
    else:
        print("Scanner plan (scanner not executed):")
        print(f"Tool: {payload['adapter']['id']}")
        print(f"Sandbox profile: {payload['sandbox_profile']}")
        print(f"Network policy: {payload['network_policy']}")
        print(f"Command: {payload['command_display']}")
        print(f"Raw output: {payload['raw_output_path']}")
        print(
            "Binary readiness: "
            + ("available" if payload["adapter"]["readiness"]["executable_available"] else "missing")
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

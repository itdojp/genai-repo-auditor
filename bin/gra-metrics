#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from metrics import MetricsError, reports_dir, write_metrics  # noqa: E402
from run_events import (  # noqa: E402
    EventWriteError,
    append_command_event,
    local_artifact_paths,
    preflight_command_event,
    start_command_event,
)
from version import auditor_version  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate local advanced workflow metrics for a GenAI Repo Auditor run")
    parser.add_argument("--version", action="version", version=f"%(prog)s {auditor_version(LAB_ROOT)}")
    parser.add_argument("--run", required=True, help="Run directory containing local report artifacts")
    parser.add_argument("--out-json", help="Output JSON file. Default: reports/metrics.json")
    parser.add_argument("--out-md", help="Output Markdown file. Default: reports/METRICS.md")
    args = parser.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    try:
        reports = reports_dir(run_dir)
    except MetricsError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    json_path = Path(args.out_json).resolve() if args.out_json else reports / "metrics.json"
    md_path = Path(args.out_md).resolve() if args.out_md else reports / "METRICS.md"
    input_artifacts = [run_dir / "context.json", reports]
    output_artifacts = local_artifact_paths(run_dir, [json_path, md_path])

    def finish(exit_code: int, *, error_category: str | None = None) -> int:
        append_command_event(
            run_dir,
            command="gra-metrics",
            phase="metrics",
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            error_category=error_category,
            failure_mode="warn" if exit_code != 0 else "block",
        )
        return exit_code

    try:
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            event_fields={
                "command": "gra-metrics",
                "phase": "metrics",
                "started_at": started_at,
                "started_perf": started_perf,
                "exit_code": 0,
            },
            reserve_file=False,
        )
    except EventWriteError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    try:
        json_path, md_path, metrics = write_metrics(
            run_dir,
            out_json=Path(args.out_json) if args.out_json else None,
            out_md=Path(args.out_md) if args.out_md else None,
        )
    except (OSError, ValueError, MetricsError) as exc:
        print(str(exc), file=sys.stderr)
        return finish(2, error_category="reporting_failure")

    print(f"Wrote {json_path}")
    print(f"Wrote {md_path}")
    print(f"Findings: {metrics['findings']['total']}")
    print(f"Adversarial validations: {metrics['adversarial_validation']['total']}")
    print(f"Chains: {metrics['chains']['total']}")
    print(f"Proofs: {metrics['proofs']['total']}")
    print(f"Traces: {metrics['traces']['total']}")
    print(f"Gapfill current candidates: {metrics['gapfill']['current_run']['candidate_count']}")
    print(f"Gapfill cumulative targets: {metrics['gapfill']['cumulative']['generated_target_count']}")
    print(f"Workflow profile skipped by scope: {metrics['workflow_profile']['skipped_by_scope_count']}")
    print(f"Command events: {metrics['observability']['total_events']}")
    print(f"Validation retries: {metrics['observability']['validation_retry_count']}")
    print(f"Taxonomy normalizations: {metrics['observability']['taxonomy_normalization_count']}")
    print(f"Latest status artifacts: {metrics['artifacts']['latest_status_artifact_count']}")
    print(f"Archive artifacts: {metrics['artifacts']['archive_artifact_count']}")
    print(f"Manifest hygiene warnings: {metrics['artifacts']['manifest_hygiene_warnings']}")
    return finish(0)


if __name__ == "__main__":
    raise SystemExit(main())

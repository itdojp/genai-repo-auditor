#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sqlite3
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import load_context, load_json, load_targets_artifact, utc_now, write_run_artifact_json
from posture_artifacts import load_posture_artifacts
from run_events import (
    EventWriteError,
    append_command_event,
    local_artifact_paths,
    preflight_command_event,
    reports_dir,
    start_command_event,
)
from report_freshness import artifact_dependencies, initialize_freshness, preflight_artifact_dependencies, record_artifact

_failure_event: tuple[Path, str, float, list[Path], list[Path]] | None = None


def init(conn):
    conn.executescript('''
    create table if not exists runs (
      run_id text primary key,
      repo text,
      branch text,
      commit_hash text,
      visibility text,
      run_dir text,
      imported_at text
    );
    create table if not exists targets (
      run_id text,
      target_id text,
      category text,
      title text,
      risk text,
      priority integer,
      status text,
      data_json text,
      primary key (run_id, target_id)
    );
    create table if not exists findings (
      run_id text,
      finding_id text,
      fingerprint text,
      title text,
      severity text,
      confidence text,
      status text,
      category text,
      target_id text,
      issue_recommended integer,
      data_json text,
      primary key (run_id, finding_id)
    );
    create index if not exists idx_findings_fingerprint on findings(fingerprint);
    create index if not exists idx_findings_severity on findings(severity, status);
    create table if not exists scanner_results (
      run_id text,
      tool text,
      path text,
      format text,
      imported_at text,
      data_json text
    );
    create table if not exists issues (
      run_id text,
      finding_id text,
      fingerprint text,
      url text,
      data_json text,
      primary key (run_id, finding_id, url)
    );
    create table if not exists posture_artifacts (
      run_id text,
      artifact_type text,
      path text,
      status text,
      item_count integer,
      generated_at text,
      data_json text,
      primary key (run_id, artifact_type, path)
    );
    create index if not exists idx_posture_artifacts_type on posture_artifacts(artifact_type);
    ''')


def main() -> int:
    global _failure_event
    _failure_event = None
    p = argparse.ArgumentParser(description='Import a GenAI Repo Auditor run into a local SQLite store')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--db', help='SQLite path. Default: <lab>/runs/security-audit.sqlite')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    ctx = load_context(run_dir)
    try:
        reports = reports_dir(run_dir)
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    db_path = Path(args.db).resolve() if args.db else LAB_ROOT / 'runs' / 'security-audit.sqlite'
    import_state_path = reports / 'store-import-state.json'
    input_artifacts = [run_dir / 'context.json', reports]
    output_artifacts = local_artifact_paths(
        run_dir,
        [db_path, import_state_path, reports / 'report-freshness.json'],
    )
    try:
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            event_fields={
                'command': 'gra-store',
                'phase': 'store',
                'started_at': started_at,
                'started_perf': started_perf,
                'exit_code': 0,
            },
            reserve_file=False,
        )
    except EventWriteError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    _failure_event = (run_dir, started_at, started_perf, input_artifacts, output_artifacts)
    initialize_freshness(run_dir)
    freshness_dependencies = preflight_artifact_dependencies(
        run_dir,
        'store_import_state',
        artifact_dependencies(run_dir, 'store_import_state'),
    )
    db_path.parent.mkdir(parents=True, exist_ok=True)

    with sqlite3.connect(db_path) as conn:
        init(conn)
        run_id = str(ctx.get('run_id', run_dir.name))
        conn.execute('replace into runs(run_id, repo, branch, commit_hash, visibility, run_dir, imported_at) values (?, ?, ?, ?, ?, ?, ?)', (
            run_id, ctx.get('repo'), ctx.get('branch'), ctx.get('commit'), ctx.get('visibility'), str(run_dir), utc_now()
        ))

        targets_data = load_targets_artifact(run_dir, {}) or {}
        for t in targets_data.get('targets') or []:
            if not isinstance(t, dict):
                continue
            conn.execute('replace into targets(run_id, target_id, category, title, risk, priority, status, data_json) values (?, ?, ?, ?, ?, ?, ?, ?)', (
                run_id, t.get('id'), t.get('category'), t.get('title'), t.get('risk'), t.get('priority'), t.get('status'), json.dumps(t, ensure_ascii=False)
            ))

        findings_data = load_json(reports / 'findings.json', {}) or {}
        for f in findings_data.get('findings') or []:
            if not isinstance(f, dict):
                continue
            conn.execute('replace into findings(run_id, finding_id, fingerprint, title, severity, confidence, status, category, target_id, issue_recommended, data_json) values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)', (
                run_id, f.get('id'), f.get('fingerprint'), f.get('title'), f.get('severity'), f.get('confidence'), f.get('status'), f.get('category'), f.get('target_id'), 1 if f.get('issue_recommended') else 0, json.dumps(f, ensure_ascii=False)
            ))

        scanner_index = load_json(reports / 'scanner-results' / 'scanner-index.json', {}) or {}
        for r in scanner_index.get('results') or []:
            if not isinstance(r, dict):
                continue
            conn.execute('insert into scanner_results(run_id, tool, path, format, imported_at, data_json) values (?, ?, ?, ?, ?, ?)', (
                run_id, r.get('tool'), r.get('path'), r.get('format'), r.get('imported_at'), json.dumps(r, ensure_ascii=False)
            ))

        issue_ledger = load_json(reports / 'issue-ledger.json', {}) or {}
        ledger_items = [item for item in issue_ledger.get('findings') or [] if isinstance(item, dict) and item.get('url')]
        if ledger_items:
            for item in ledger_items:
                conn.execute('replace into issues(run_id, finding_id, fingerprint, url, data_json) values (?, ?, ?, ?, ?)', (
                    run_id, item.get('finding_id'), item.get('fingerprint'), item.get('url'), json.dumps(item, ensure_ascii=False)
                ))
        else:
            issues = load_json(run_dir / 'issues-created.json', {}) or {}
            for item in (issues.get('created') or []):
                if not isinstance(item, dict) or not item.get('url'):
                    continue
                conn.execute('replace into issues(run_id, finding_id, fingerprint, url, data_json) values (?, ?, ?, ?, ?)', (
                    run_id, item.get('id'), item.get('fingerprint'), item.get('url'), json.dumps(item, ensure_ascii=False)
                ))

        conn.execute('delete from posture_artifacts where run_id = ?', (run_id,))
        for artifact in load_posture_artifacts(run_dir):
            conn.execute('replace into posture_artifacts(run_id, artifact_type, path, status, item_count, generated_at, data_json) values (?, ?, ?, ?, ?, ?, ?)', (
                run_id,
                artifact.get('artifact_type'),
                artifact.get('path'),
                artifact.get('status'),
                artifact.get('item_count'),
                artifact.get('generated_at'),
                json.dumps(artifact.get('data'), ensure_ascii=False, sort_keys=True),
            ))

        imported_counts = {
            table: int(conn.execute(f'select count(*) from {table} where run_id = ?', (run_id,)).fetchone()[0])
            for table in ('targets', 'findings', 'scanner_results', 'issues', 'posture_artifacts')
        }

    write_run_artifact_json(
        run_dir,
        import_state_path,
        {
            'schema_version': '1',
            'run_id': run_id,
            'generated_at': utc_now(),
            'source': 'local-store-import',
            'database_location_recorded': False,
            'imported_counts': imported_counts,
        },
    )
    record_artifact(run_dir, 'store_import_state', freshness_dependencies)

    print('Imported run into local SQLite store')
    append_command_event(
        run_dir,
        command='gra-store',
        phase='store',
        started_at=started_at,
        started_perf=started_perf,
        exit_code=0,
        input_artifact_paths=input_artifacts,
        output_artifact_paths=output_artifacts,
    )
    _failure_event = None
    return 0


def run_cli() -> int:
    try:
        return main()
    except Exception as exc:  # noqa: BLE001 - convert post-preflight failures into structured events.
        if _failure_event is not None:
            run_dir, started_at, started_perf, input_artifacts, output_artifacts = _failure_event
            append_command_event(
                run_dir,
                command='gra-store',
                phase='store',
                started_at=started_at,
                started_perf=started_perf,
                exit_code=2,
                input_artifact_paths=input_artifacts,
                output_artifact_paths=[path for path in output_artifacts if path.is_file() and not path.is_symlink()],
                error_category='reporting_failure',
                failure_mode='warn',
            )
        print(str(exc), file=sys.stderr)
        return 2


if __name__ == '__main__':
    raise SystemExit(run_cli())

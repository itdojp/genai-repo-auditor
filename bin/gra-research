#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import (
    ensure_taxonomy_templates,
    env_from_context,
    find_target,
    load_context,
    load_targets,
    render_template,
    run_codex_exec,
    write_targets,
)
from run_state import paused_error
from run_events import append_command_event, start_command_event


def run_taxonomy_preflight(run_dir: Path, target_id: str) -> int:
    findings = run_dir / "reports" / "findings.json"
    targets = run_dir / "reports" / "targets.json"
    if not findings.exists() and not targets.exists():
        return 0
    log = run_dir / f"taxonomy-preflight-{target_id}.txt"
    with log.open("w", encoding="utf-8") as stdout:
        proc = subprocess.run(
            [sys.executable, str(LAB_ROOT / "bin" / "gra-taxonomy-preflight"), "--run", str(run_dir), "--fix"],
            stdout=stdout,
            stderr=subprocess.STDOUT,
            text=True,
            check=False,
        )
    print(f"Taxonomy preflight status: {proc.returncode}")
    print(f"Taxonomy preflight log: {log}")
    return proc.returncode


def main() -> int:
    p = argparse.ArgumentParser(description='Research one target from reports/targets.json using Codex')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--target', required=True, help='Target ID, e.g. TGT-001')
    p.add_argument('--mode', choices=['exec', 'goal'], default='exec')
    p.add_argument('--model', default='gpt-5.5')
    p.add_argument('--effort', default='xhigh')
    p.add_argument('--network', action='store_true', help='Allow Codex sandbox network access. Not recommended.')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    input_artifacts: list[Path] = []
    output_artifacts: list[Path] = []

    def finish(exit_code: int) -> int:
        append_command_event(
            run_dir,
            command="gra-research",
            phase=args.mode,
            target_id=args.target,
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            model=args.model,
            effort=args.effort,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
        )
        return exit_code

    ctx = load_context(run_dir)
    reports_root = run_dir / ctx.get('reports_dir', 'reports')
    input_artifacts.extend([run_dir / "context.json", reports_root / "targets.json"])
    ensure_taxonomy_templates(LAB_ROOT, run_dir)
    try:
        target = find_target(run_dir, args.target)
    except KeyError as e:
        print(str(e), file=sys.stderr)
        return finish(2)
    except (OSError, ValueError, UnicodeError):
        print('Invalid targets.json: expected bounded JSON in a regular non-symlink file', file=sys.stderr)
        return finish(2)
    pause_message = paused_error(run_dir, action=f"target research for {args.target}")
    if pause_message:
        print(pause_message, file=sys.stderr)
        return finish(5)

    target_json = run_dir / 'reports' / 'target-research' / f'{args.target}.target.json'
    target_json.parent.mkdir(parents=True, exist_ok=True)
    target_json.write_text(json.dumps(target, indent=2, ensure_ascii=False) + '\n', encoding='utf-8')
    output_artifacts.append(target_json)

    env = env_from_context(run_dir, {
        'TARGET_ID': args.target,
        'TARGET_CATEGORY': str(target.get('category', '')),
        'TARGET_SCOPE': str(target.get('scope', '')),
        'TARGET_FILE': str(target_json.relative_to(run_dir)),
    })

    if args.mode == 'goal':
        prompt = run_dir / 'prompts' / 'goal' / f'research-{args.target}.goal.md'
        render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'goal' / 'research-target.goal.md', prompt, env)
        output_artifacts.append(prompt)
        # Reserve the ID before handing the prepared goal to an operator. A
        # later deterministic queue rebalance retains non-queued work rather
        # than merging or deferring a target referenced by this prompt/seed.
        targets = load_targets(run_dir)
        for item in targets:
            if str(item.get('id')) == args.target:
                item['status'] = 'in_progress'
        try:
            write_targets(run_dir, targets)
        except (OSError, ValueError, UnicodeError) as exc:
            print(f'Invalid target queue: {exc}', file=sys.stderr)
            return finish(2)
        output_artifacts.append(reports_root / 'targets.json')
        print('Prepared supervised /goal target research run.')
        print(f'Run directory: {run_dir}')
        print(f'Target file: {target_json}')
        print(f'Goal prompt: {prompt}')
        network_value = 'true' if args.network else 'false'
        print('\nStart Codex:')
        print(f'  codex --cd "{run_dir}" --skip-git-repo-check --model "{args.model}" --enable goals --sandbox workspace-write --ask-for-approval on-request -c \'model_reasoning_effort="{args.effort}"\' -c \'web_search="disabled"\' -c \'sandbox_workspace_write.network_access={network_value}\'')
        print('\nThen paste the contents of the goal prompt.')
        return finish(0)

    prompt = run_dir / 'prompts' / 'exec' / f'research-{args.target}.prompt.md'
    render_template(LAB_ROOT, LAB_ROOT / 'prompts' / 'exec' / 'research-target.prompt.md', prompt, env)
    output_artifacts.append(prompt)

    # Mark in progress before execution.
    targets = load_targets(run_dir)
    for t in targets:
        if str(t.get('id')) == args.target:
            t['status'] = 'in_progress'
    try:
        write_targets(run_dir, targets)
    except (OSError, ValueError, UnicodeError) as exc:
        print(f'Invalid target queue: {exc}', file=sys.stderr)
        return finish(2)

    print(f'Running Codex target research for {args.target}: {target.get("title", "")}'.strip())
    final_path = run_dir / f'codex-research-{args.target}-final.md'
    events_path = run_dir / f'codex-research-{args.target}-events.jsonl'
    stderr_path = run_dir / f'codex-research-{args.target}-stderr.txt'
    status = run_codex_exec(
        run_dir=run_dir,
        prompt_file=prompt,
        model=args.model,
        effort=args.effort,
        network=args.network,
        output_last=final_path,
        events_file=events_path,
        stderr_file=stderr_path,
    )
    output_artifacts.extend([final_path, events_path, stderr_path])
    preflight_status = run_taxonomy_preflight(run_dir, args.target)
    output_artifacts.append(run_dir / f"taxonomy-preflight-{args.target}.txt")

    targets = load_targets(run_dir)
    for t in targets:
        if str(t.get('id')) == args.target:
            t['status'] = 'reviewed' if status == 0 and preflight_status == 0 else 'needs_human_review'
    try:
        write_targets(run_dir, targets)
    except (OSError, ValueError, UnicodeError) as exc:
        print(f'Invalid target queue after research: {exc}', file=sys.stderr)
        return finish(status if status != 0 else 1)

    print(f'Codex status: {status}')
    print(f'Research report: {run_dir / "reports" / "target-research" / (args.target + ".md")}')
    print(f'Findings: {run_dir / "reports" / "findings.json"}')
    output_artifacts.extend([run_dir / "reports" / "target-research" / (args.target + ".md"), run_dir / "reports" / "findings.json"])
    return finish(preflight_status if status == 0 and preflight_status != 0 else status)


if __name__ == '__main__':
    raise SystemExit(main())

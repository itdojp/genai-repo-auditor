#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from version import auditor_version  # noqa: E402
from external_findings import ExternalFindingImportError, import_external_findings  # noqa: E402
from run_events import (  # noqa: E402
    EventWriteError,
    append_command_event,
    preflight_command_event,
    reports_dir,
    start_command_event,
)


def main() -> int:
    parser = argparse.ArgumentParser(description="Import vendor-neutral external finding JSON into a GenAI Repo Auditor run")
    parser.add_argument("--version", action="version", version=f"%(prog)s {auditor_version(LAB_ROOT)}")
    parser.add_argument("--run", required=True, help="Run directory")
    parser.add_argument("--file", required=True, help="External finding JSON file")
    parser.add_argument(
        "--append-findings",
        action="store_true",
        help="Explicitly append normalized findings to reports/findings.json; default is review-only",
    )
    args = parser.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    input_artifacts = [run_dir / "context.json"]
    output_artifacts: list[Path] = []
    event_subject_id: str | None = None

    def finish(exit_code: int, *, error_category: str | None = None) -> int:
        append_command_event(
            run_dir,
            command="gra-import-findings",
            phase="import",
            subject_id=event_subject_id,
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            error_category=error_category,
            failure_mode="warn" if exit_code != 0 else "block",
        )
        return exit_code

    try:
        reports = reports_dir(run_dir)
        potential_outputs = [reports / "imported-findings.json", reports / "IMPORTED_FINDINGS.md"]
        if args.append_findings:
            potential_outputs.append(reports / "findings.json")
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=potential_outputs,
        )
    except (EventWriteError, OSError) as exc:
        print(str(exc), file=sys.stderr)
        return 2

    try:
        report = import_external_findings(run_dir, Path(args.file), append_findings=args.append_findings)
    except ExternalFindingImportError as exc:
        print(str(exc), file=sys.stderr)
        return finish(2, error_category="input_validation")

    event_subject_id = str(report.get("source") or "") or None
    output_artifacts.extend([reports / "imported-findings.json", reports / "IMPORTED_FINDINGS.md"])
    if args.append_findings:
        output_artifacts.append(reports / "findings.json")

    summary = report.get("summary") if isinstance(report.get("summary"), dict) else {}
    print(f"Wrote imported findings -> {reports / 'imported-findings.json'}")
    print(f"Wrote imported findings summary -> {reports / 'IMPORTED_FINDINGS.md'}")
    print(
        "Imported findings: "
        f"valid={summary.get('valid_count', 0)} "
        f"rejected={summary.get('rejected_count', 0)} "
        f"appended={summary.get('appended_count', 0)} "
        f"duplicate_skipped={summary.get('duplicate_skipped_count', 0)}"
    )
    if not args.append_findings:
        print(
            f"Review-only mode: {reports / 'findings.json'} was not modified. "
            "Use --append-findings to append normalized records."
        )
    return finish(0)


if __name__ == "__main__":
    raise SystemExit(main())

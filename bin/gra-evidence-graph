#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from evidence_graph import EvidenceGraphSafetyError, build_evidence_graph, write_evidence_graph  # noqa: E402
from version import auditor_version  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate a local evidence graph across audit artifacts")
    parser.add_argument("--version", action="version", version=f"%(prog)s {auditor_version(LAB_ROOT)}")
    parser.add_argument("--run", required=True, help="Run directory")
    args = parser.parse_args()

    run_dir = Path(args.run).resolve()
    try:
        graph = build_evidence_graph(run_dir)
        json_path, md_path = write_evidence_graph(run_dir, graph)
    except EvidenceGraphSafetyError as exc:
        parser.error(str(exc))
    summary = graph.get("summary") if isinstance(graph.get("summary"), dict) else {}
    print(f"Evidence graph JSON: {json_path}")
    print(f"Evidence graph Markdown: {md_path}")
    print(f"Nodes: {summary.get('node_count', 0)}")
    print(f"Edges: {summary.get('edge_count', 0)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

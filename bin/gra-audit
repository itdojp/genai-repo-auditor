#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="${BASH_SOURCE[0]%/*}"
if [[ "$SCRIPT_DIR" == "${BASH_SOURCE[0]}" ]]; then
  SCRIPT_DIR="."
fi
LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUNS_DIR="${GENAI_REPO_AUDITOR_RUNS_DIR:-$LAB_ROOT/runs}"

print_version() {
  local version="unknown"
  if [[ -r "$LAB_ROOT/VERSION" ]]; then
    IFS= read -r version < "$LAB_ROOT/VERSION" || version="unknown"
  fi
  if [[ -z "$version" ]]; then
    version="unknown"
  fi
  printf '%s %s\n' "${0##*/}" "$version"
}

REPO=""
BRANCH=""
MODE="exec"
MODEL="${GRA_MODEL:-${CODEX_MODEL:-gpt-5.5}}"
EFFORT="${GRA_REASONING_EFFORT:-${CODEX_REASONING_EFFORT:-xhigh}}"
DEPTH="1"
RUN_ID=""
CODEX_JSON="1"
NETWORK="0"
USE_LOCK="1"
ALLOW_INVALID_REPORT="0"

usage() {
  cat <<'USAGE'
Usage:
  gra-audit --repo OWNER/REPO [options]

Options:
  --repo OWNER/REPO       GitHub repository to audit. Required.
  --branch REF            Branch or ref to clone. Optional.
  --mode exec|goal|prepare
                         exec runs full audit non-interactively; goal prepares interactive /goal; prepare only creates a run directory. Default: exec
  --model MODEL           Codex model. Default: gpt-5.5
  --effort EFFORT         model_reasoning_effort. Default: xhigh
  --depth N               Clone depth. Default: 1
  --run-id ID             Override run id. Default: UTC timestamp + pid + random
  --runs-dir DIR          Override runs directory for this invocation
  --codex-json            Use codex exec --json and save event stream to codex-events.jsonl. Default: enabled
  --network               Allow Codex sandbox network access. Default: disabled
  --no-lock               Disable same-repo lock. Not recommended.
  --allow-invalid-report  Do not fail when findings.json is missing or report validation fails.
                          Not recommended for CI or batch automation.
  --version               Show version.
  -h, --help              Show help.

Examples:
  gra-audit --repo acme/api --mode exec
  gra-audit --repo acme/api --mode goal --model gpt-5.5 --effort xhigh
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="${2:-}"; shift 2 ;;
    --branch) BRANCH="${2:-}"; shift 2 ;;
    --mode) MODE="${2:-}"; shift 2 ;;
    --model) MODEL="${2:-}"; shift 2 ;;
    --effort) EFFORT="${2:-}"; shift 2 ;;
    --depth) DEPTH="${2:-}"; shift 2 ;;
    --run-id) RUN_ID="${2:-}"; shift 2 ;;
    --runs-dir) RUNS_DIR="${2:-}"; shift 2 ;;
    --codex-json) CODEX_JSON="1"; shift ;;
    --network) NETWORK="1"; shift ;;
    --no-lock) USE_LOCK="0"; shift ;;
    --allow-invalid-report) ALLOW_INVALID_REPORT="1"; shift ;;
    --version) print_version; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if [[ -z "$REPO" ]]; then
  echo "--repo is required" >&2
  usage >&2
  exit 2
fi

if [[ -z "$RUN_ID" ]]; then
  RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$-$RANDOM"
fi

if [[ "$MODE" != "exec" && "$MODE" != "goal" && "$MODE" != "prepare" ]]; then
  echo "--mode must be exec, goal, or prepare" >&2
  exit 2
fi

for cmd in git gh codex python3; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd" >&2
    exit 1
  fi
done

slug_from_repo() {
  local r="$1"
  r="${r#https://github.com/}"
  r="${r#http://github.com/}"
  r="${r%.git}"
  r="${r//\//__}"
  r="${r//:/__}"
  printf '%s' "$r"
}

REPO_SLUG="$(slug_from_repo "$REPO")"
RUN_DIR="$RUNS_DIR/$REPO_SLUG/$RUN_ID"
REPO_DIR="$RUN_DIR/repo"
REPORT_DIR="$RUN_DIR/reports"
TARGET_REPO_DIR="repo"
REPORTS_DIR="reports"

read -r COMMAND_EVENT_STARTED_AT COMMAND_EVENT_STARTED_PERF < <(
  PYTHONPATH="$LAB_ROOT/lib" python3 - <<'PY'
from run_events import start_command_event

started_at, started_perf = start_command_event()
print(started_at, started_perf)
PY
)

mkdir -p "$RUNS_DIR" "$RUN_DIR" "$REPORT_DIR" "$RUN_DIR/prompts"

if [[ "$USE_LOCK" == "1" ]]; then
  LOCK_DIR="$RUNS_DIR/.locks"
  mkdir -p "$LOCK_DIR"
  if command -v flock >/dev/null 2>&1; then
    exec 9>"$LOCK_DIR/$REPO_SLUG.lock"
    if ! flock -n 9; then
      echo "Another audit appears to be running for $REPO. Lock: $LOCK_DIR/$REPO_SLUG.lock" >&2
      exit 12
    fi
  else
    LOCK_PATH="$LOCK_DIR/$REPO_SLUG.lockdir"
    if ! mkdir "$LOCK_PATH" 2>/dev/null; then
      echo "Another audit appears to be running for $REPO. Lock: $LOCK_PATH" >&2
      exit 12
    fi
    trap 'rmdir "$LOCK_PATH" 2>/dev/null || true' EXIT
  fi
fi

printf 'Run directory: %s\n' "$RUN_DIR"
printf 'Cloning %s ...\n' "$REPO"

CLONE_ARGS=("$REPO" "$REPO_DIR" -- --depth "$DEPTH")
if [[ -n "$BRANCH" ]]; then
  CLONE_ARGS=("$REPO" "$REPO_DIR" -- --branch "$BRANCH" --depth "$DEPTH")
fi

gh repo clone "${CLONE_ARGS[@]}"

COMMIT="$(git -C "$REPO_DIR" rev-parse HEAD)"
BRANCH_ACTUAL="$(git -C "$REPO_DIR" branch --show-current || true)"
if [[ -z "$BRANCH" ]]; then
  BRANCH="$BRANCH_ACTUAL"
fi
VISIBILITY="UNKNOWN"
if VIS_OUT="$(gh repo view "$REPO" --json visibility --jq .visibility 2>/dev/null)"; then
  VISIBILITY="$VIS_OUT"
fi

# Keep Codex in the run directory so the controlling AGENTS.md is the lab policy,
# not a potentially untrusted repository AGENTS.md.
cp "$LAB_ROOT/prompts/AGENTS.audit.md" "$RUN_DIR/AGENTS.md"
cp "$LAB_ROOT/templates/reports/findings.schema.json" "$RUN_DIR/findings.schema.json"
if [[ -f "$LAB_ROOT/templates/reports/targets.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/targets.schema.json" "$RUN_DIR/targets.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/scanner-index.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/scanner-index.schema.json" "$RUN_DIR/scanner-index.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/run-manifest.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/run-manifest.schema.json" "$RUN_DIR/run-manifest.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/validation.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/validation.schema.json" "$RUN_DIR/validation.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/chains.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/chains.schema.json" "$RUN_DIR/chains.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/proofs.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/proofs.schema.json" "$RUN_DIR/proofs.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/remediation-candidates.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/remediation-candidates.schema.json" "$RUN_DIR/remediation-candidates.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/patch-validation.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/patch-validation.schema.json" "$RUN_DIR/patch-validation.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/novelty.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/novelty.schema.json" "$RUN_DIR/novelty.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/traces.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/traces.schema.json" "$RUN_DIR/traces.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/evidence-graph.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/evidence-graph.schema.json" "$RUN_DIR/evidence-graph.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/benchmark.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/benchmark.schema.json" "$RUN_DIR/benchmark.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/workflow-profile.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/workflow-profile.schema.json" "$RUN_DIR/workflow-profile.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/workflow-execution.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/workflow-execution.schema.json" "$RUN_DIR/workflow-execution.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/imported-findings.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/imported-findings.schema.json" "$RUN_DIR/imported-findings.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/issue-ledger.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/issue-ledger.schema.json" "$RUN_DIR/issue-ledger.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/duplicate-decision.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/duplicate-decision.schema.json" "$RUN_DIR/duplicate-decision.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/run-state.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/run-state.schema.json" "$RUN_DIR/run-state.schema.json"
fi
if [[ -f "$LAB_ROOT/templates/reports/command-event.schema.json" ]]; then
  cp "$LAB_ROOT/templates/reports/command-event.schema.json" "$RUN_DIR/command-event.schema.json"
fi
if [[ -d "$LAB_ROOT/templates/taxonomies" ]]; then
  mkdir -p "$RUN_DIR/templates/taxonomies"
  cp "$LAB_ROOT"/templates/taxonomies/*.json "$RUN_DIR/templates/taxonomies/"
fi
if [[ -f "$LAB_ROOT/templates/taxonomy-aliases.json" ]]; then
  mkdir -p "$RUN_DIR/templates"
  cp "$LAB_ROOT/templates/taxonomy-aliases.json" "$RUN_DIR/templates/taxonomy-aliases.json"
fi
mkdir -p "$REPORT_DIR/issue-drafts" "$REPORT_DIR/duplicate-decisions" "$REPORT_DIR/scanner-results" "$REPORT_DIR/target-research" "$REPORT_DIR/variant-analysis" "$REPORT_DIR/proofs" "$REPORT_DIR/traces"

python3 - <<PYCODE
import json
from pathlib import Path
ctx = {
  "run_id": "$RUN_ID",
  "repo": "$REPO",
  "repo_slug": "$REPO_SLUG",
  "branch": "$BRANCH",
  "commit": "$COMMIT",
  "visibility": "$VISIBILITY",
  "run_dir": "$RUN_DIR",
  "repo_dir": "$REPO_DIR",
  "target_repo_dir": "$TARGET_REPO_DIR",
  "reports_dir": "$REPORTS_DIR",
  "network_allowed": "$NETWORK" == "1",
}
Path("$RUN_DIR/context.json").write_text(json.dumps(ctx, indent=2) + "\n", encoding="utf-8")
PYCODE

export RUN_ID REPO REPO_SLUG BRANCH COMMIT VISIBILITY RUN_DIR REPO_DIR TARGET_REPO_DIR REPORTS_DIR

EXEC_PROMPT="$RUN_DIR/prompt.exec.md"
GOAL_PROMPT="$RUN_DIR/prompt.goal.md"
python3 "$LAB_ROOT/lib/render_template.py" "$LAB_ROOT/prompts/exec/full-audit.prompt.md" "$EXEC_PROMPT"
python3 "$LAB_ROOT/lib/render_template.py" "$LAB_ROOT/prompts/goal/full-audit.goal.md" "$GOAL_PROMPT"

mkdir -p "$RUN_DIR/prompts/exec" "$RUN_DIR/prompts/goal"
for tmpl in "$LAB_ROOT"/prompts/exec/*.prompt.md; do
  name="$(basename "$tmpl")"
  python3 "$LAB_ROOT/lib/render_template.py" "$tmpl" "$RUN_DIR/prompts/exec/$name"
done
for tmpl in "$LAB_ROOT"/prompts/goal/*.goal.md; do
  name="$(basename "$tmpl")"
  python3 "$LAB_ROOT/lib/render_template.py" "$tmpl" "$RUN_DIR/prompts/goal/$name"
done

NETWORK_VALUE="false"
if [[ "$NETWORK" == "1" ]]; then
  NETWORK_VALUE="true"
fi

write_run_manifest() {
  local execution_phase="$1"
  local codex_status="${2:-}"
  local validation_status="${3:-}"
  local final_status="${4:-}"
  python3 "$LAB_ROOT/lib/run_manifest.py" \
    --lab-root "$LAB_ROOT" \
    --run-dir "$RUN_DIR" \
    --command-name "gra-audit" \
    --mode "$MODE" \
    --model "$MODEL" \
    --effort "$EFFORT" \
    --depth "$DEPTH" \
    --network-allowed "$NETWORK_VALUE" \
    --codex-json "$CODEX_JSON" \
    --allow-invalid-report "$ALLOW_INVALID_REPORT" \
    --execution-phase "$execution_phase" \
    --codex-status "$codex_status" \
    --validation-status "$validation_status" \
    --final-status "$final_status"
}

write_command_event() {
  local event_exit_code="$1"
  local event_phase="$2"
  if PYTHONPATH="$LAB_ROOT/lib" python3 - "$RUN_DIR" "$event_phase" "$event_exit_code" "$COMMAND_EVENT_STARTED_AT" "$COMMAND_EVENT_STARTED_PERF" "$MODEL" "$EFFORT" "$NETWORK_VALUE" <<'PY'
import sys
from pathlib import Path

from run_events import append_command_event

run_dir = Path(sys.argv[1])
phase = sys.argv[2]
exit_code = int(sys.argv[3])
started_at = sys.argv[4]
started_perf = float(sys.argv[5])
model = sys.argv[6]
effort = sys.argv[7]
network_allowed = sys.argv[8] == "true"

outputs_by_phase = {
    "prepare": [
        "prompt.exec.md",
        "prompt.goal.md",
        "prompts",
        "run-manifest.json",
    ],
    "goal": [
        "prompt.exec.md",
        "prompt.goal.md",
        "prompts",
        "run-manifest.json",
    ],
    "audit": [
        "codex-final.md",
        "codex-events.jsonl",
        "codex-stderr.txt",
        "codex-transcript.txt",
        "taxonomy-preflight.txt",
        "report-validation.txt",
        "run-summary.txt",
        "run-manifest.json",
        "reports/findings.json",
        "reports/FINDINGS.md",
    ],
}
append_command_event(
    run_dir,
    command="gra-audit",
    phase=phase,
    started_at=started_at,
    started_perf=started_perf,
    exit_code=exit_code,
    model=model,
    effort=effort,
    network_allowed=network_allowed,
    sandbox_profile="workspace-write",
    input_artifact_paths=[run_dir / "context.json"],
    output_artifact_paths=[run_dir / item for item in outputs_by_phase.get(phase, [])],
)
PY
  then
    return "$event_exit_code"
  fi
  if [[ "$event_exit_code" -eq 0 ]]; then
    return 1
  fi
  return "$event_exit_code"
}

write_run_summary() {
  cat > "$RUN_DIR/run-summary.txt" <<EOF_SUMMARY
run_id=$RUN_ID
repo=$REPO
branch=$BRANCH
commit=$COMMIT
visibility=$VISIBILITY
mode=$MODE
model=$MODEL
effort=$EFFORT
codex_status=$CODEX_STATUS
validation_status=$VALIDATION_STATUS
taxonomy_preflight_status=$TAXONOMY_PREFLIGHT_STATUS
allow_invalid_report=$ALLOW_INVALID_REPORT
final_status=$FINAL_STATUS
repo_dir=$REPO_DIR
reports_dir=$REPORT_DIR
EOF_SUMMARY
}

if [[ "$MODE" == "prepare" ]]; then
  write_run_manifest "prepared"
  cat <<EOF_PREPARE

Prepared audit run directory without executing Codex.

Audit run directory:
  $RUN_DIR

Target repository:
  $REPO_DIR

Rendered prompts:
  $RUN_DIR/prompts/

Suggested staged agentic workflow:
  gra-recon --run "$RUN_DIR" --model "$MODEL" --effort "$EFFORT"
  gra-targets --run "$RUN_DIR" --generate --model "$MODEL" --effort "$EFFORT"
  gra-targets --run "$RUN_DIR" --list
  gra-research --run "$RUN_DIR" --target TGT-001 --model "$MODEL" --effort "$EFFORT"
  gra-validate-report --run "$RUN_DIR"
  gra-dashboard --run "$RUN_DIR"

For a supervised deep dive, use:
  gra-research --run "$RUN_DIR" --target TGT-001 --mode goal --model "$MODEL" --effort "$EFFORT"
EOF_PREPARE
  EVENT_STATUS="0"
  set +e
  write_command_event 0 "prepare"
  EVENT_STATUS="$?"
  set -e
  write_run_manifest "prepared"
  exit "$EVENT_STATUS"
fi

if [[ "$MODE" == "goal" ]]; then
  write_run_manifest "goal-prepared"
  cat <<EOF2

Prepared interactive /goal run.

Audit run directory:
  $RUN_DIR

Target repository:
  $REPO_DIR

Goal prompt:
  $GOAL_PROMPT

Additional rendered prompts:
  $RUN_DIR/prompts/

Start Codex from the audit run directory:
  codex --cd "$RUN_DIR" --skip-git-repo-check --model "$MODEL" --enable goals --sandbox workspace-write --ask-for-approval on-request -c 'model_reasoning_effort="$EFFORT"' -c 'web_search="disabled"' -c 'sandbox_workspace_write.network_access=$NETWORK_VALUE'

Then paste the contents of:
  $GOAL_PROMPT

When Codex finishes, validate with:
  gra-validate-report --run "$RUN_DIR"

Then inspect:
  $REPORT_DIR/FINDINGS.md
  $REPORT_DIR/findings.json
EOF2
  EVENT_STATUS="0"
  set +e
  write_command_event 0 "goal"
  EVENT_STATUS="$?"
  set -e
  write_run_manifest "goal-prepared"
  exit "$EVENT_STATUS"
fi

printf 'Running Codex non-interactively from run directory...\n'

CODEX_ARGS=(
  exec
  --cd "$RUN_DIR"
  --skip-git-repo-check
  --model "$MODEL"
  --sandbox workspace-write
  --color never
  --output-last-message "$RUN_DIR/codex-final.md"
  -c 'approval_policy="never"'
  -c "model_reasoning_effort=\"$EFFORT\""
  -c 'web_search="disabled"'
  -c "sandbox_workspace_write.network_access=$NETWORK_VALUE"
)

set +e
if [[ "$CODEX_JSON" == "1" ]]; then
  codex "${CODEX_ARGS[@]}" --json - < "$EXEC_PROMPT" > "$RUN_DIR/codex-events.jsonl" 2> "$RUN_DIR/codex-stderr.txt"
  CODEX_STATUS=$?
else
  codex "${CODEX_ARGS[@]}" - < "$EXEC_PROMPT" 2>&1 | tee "$RUN_DIR/codex-transcript.txt"
  CODEX_STATUS=${PIPESTATUS[0]}
fi
set -e

TAXONOMY_PREFLIGHT_STATUS="not-run"
if [[ -f "$REPORT_DIR/findings.json" || -f "$REPORT_DIR/targets.json" ]]; then
  set +e
  "$LAB_ROOT/bin/gra-taxonomy-preflight" --run "$RUN_DIR" --fix > "$RUN_DIR/taxonomy-preflight.txt" 2>&1
  TAXONOMY_PREFLIGHT_STATUS=$?
  set -e
fi

VALIDATION_STATUS="not-run"
if [[ -f "$REPORT_DIR/findings.json" ]]; then
  set +e
  "$LAB_ROOT/bin/gra-validate-report" --run "$RUN_DIR" > "$RUN_DIR/report-validation.txt" 2>&1
  VALIDATION_STATUS=$?
  set -e
else
  VALIDATION_STATUS="missing-findings-json"
fi

FINAL_STATUS="$CODEX_STATUS"
if [[ "$CODEX_STATUS" -eq 0 && "$TAXONOMY_PREFLIGHT_STATUS" != "0" && "$TAXONOMY_PREFLIGHT_STATUS" != "not-run" ]]; then
  if [[ "$ALLOW_INVALID_REPORT" == "1" ]]; then
    FINAL_STATUS="0"
  elif [[ "$TAXONOMY_PREFLIGHT_STATUS" =~ ^[0-9]+$ ]]; then
    FINAL_STATUS="$TAXONOMY_PREFLIGHT_STATUS"
  else
    FINAL_STATUS="1"
  fi
fi
if [[ "$CODEX_STATUS" -eq 0 && "$VALIDATION_STATUS" != "0" ]]; then
  if [[ "$ALLOW_INVALID_REPORT" == "1" ]]; then
    FINAL_STATUS="0"
  elif [[ "$VALIDATION_STATUS" =~ ^[0-9]+$ ]]; then
    FINAL_STATUS="$VALIDATION_STATUS"
  else
    FINAL_STATUS="1"
  fi
fi

write_run_summary
write_run_manifest "completed" "$CODEX_STATUS" "$VALIDATION_STATUS" "$FINAL_STATUS"
EVENT_STATUS="$FINAL_STATUS"
set +e
write_command_event "$FINAL_STATUS" "audit"
EVENT_STATUS="$?"
set -e
if [[ "$EVENT_STATUS" != "$FINAL_STATUS" ]]; then
  FINAL_STATUS="$EVENT_STATUS"
  write_run_summary
fi
write_run_manifest "completed" "$CODEX_STATUS" "$VALIDATION_STATUS" "$FINAL_STATUS"

printf '\nRun complete. Codex status: %s\n' "$CODEX_STATUS"
printf 'Reports: %s\n' "$REPORT_DIR"
printf 'Taxonomy preflight: %s\n' "$TAXONOMY_PREFLIGHT_STATUS"
printf 'Validation: %s\n' "$VALIDATION_STATUS"
if [[ "$TAXONOMY_PREFLIGHT_STATUS" != "0" && "$TAXONOMY_PREFLIGHT_STATUS" != "not-run" ]]; then
  printf 'Taxonomy preflight failed. See: %s\n' "$RUN_DIR/taxonomy-preflight.txt" >&2
fi
if [[ ! -f "$REPORT_DIR/findings.json" ]]; then
  printf 'Warning: findings.json was not produced. Inspect codex output and rerun if needed.\n' >&2
  printf 'Missing report path: %s\n' "$REPORT_DIR/findings.json" >&2
elif [[ "$VALIDATION_STATUS" != "0" ]]; then
  printf 'Report validation failed. See: %s\n' "$RUN_DIR/report-validation.txt" >&2
fi
if [[ "$CODEX_STATUS" -eq 0 && "$VALIDATION_STATUS" != "0" ]]; then
  if [[ "$ALLOW_INVALID_REPORT" == "1" ]]; then
    printf 'Continuing despite invalid or missing report because --allow-invalid-report was set.\n' >&2
  else
    printf 'Failing audit because Codex succeeded but report validation did not pass. Use --allow-invalid-report only when this is intentional.\n' >&2
  fi
elif [[ "$CODEX_STATUS" -eq 0 && "$TAXONOMY_PREFLIGHT_STATUS" != "0" && "$TAXONOMY_PREFLIGHT_STATUS" != "not-run" ]]; then
  if [[ "$ALLOW_INVALID_REPORT" == "1" ]]; then
    printf 'Continuing despite taxonomy preflight errors because --allow-invalid-report was set.\n' >&2
  else
    printf 'Failing audit because Codex succeeded but taxonomy preflight did not pass.\n' >&2
  fi
fi
printf 'Final status: %s\n' "$FINAL_STATUS"

exit "$FINAL_STATUS"

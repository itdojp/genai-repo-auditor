import hashlib
import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from version import auditor_version
from report_safety import ReportSafetyError  # noqa: E402
from duplicate_decisions import (  # noqa: E402
    decision_for as duplicate_decision_for,
    rel_to_run as duplicate_decision_rel_to_run,
    verify_ledger_decisions as verify_duplicate_decisions_for_ledger,
    write_duplicate_decision,
)
from publication.policy import (  # noqa: E402
    DEFAULT_LABELS,
    SEVERITY_RANK,
    advanced_validation_errors,
    finding_selection_reason,
    load_advanced_artifacts,
    normalize_labels,
    issue_title,
    plan_visibility,
    select_findings,
)
from publication.planning import (  # noqa: E402
    build_publication_plan,
    finding_key,
    plan_entry_key,
    verify_plan_against_findings,
)
from publication.rendering import sha256_text, stable_fingerprint  # noqa: E402
from novelty_ledger import (  # noqa: E402
    novelty_by_finding_id,
)
from issue_ledger import (  # noqa: E402
    base_entry as ledger_base_entry,
    default_ledger_path,
    load_ledger,
    mark_dry_run as ledger_mark_dry_run,
    mark_published as ledger_mark_published,
    merge_current_entries,
    plan_source as ledger_plan_source,
    published_entry as ledger_published_entry,
    published_entry_by_finding_id as ledger_published_entry_by_finding_id,
    utc_now as ledger_utc_now,
    write_ledger,
)

PLAN_REL_PATH = Path("reports") / "issue-publication-plan.json"

def run(cmd: List[str], *, check: bool = True, capture: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=check, text=True, stdout=subprocess.PIPE if capture else None, stderr=subprocess.PIPE if capture else None)


def load_json(path: Path) -> Dict[str, Any]:
    return json.loads(path.read_text(encoding="utf-8"))


def load_context(run_dir: Path) -> Dict[str, Any]:
    p = run_dir / "context.json"
    return load_json(p) if p.exists() else {}


def load_findings(run_dir: Path) -> Dict[str, Any]:
    candidates = [
        run_dir / "reports" / "findings.json",
        run_dir / "repo" / ".genai-audit" / "reports" / "findings.json",
    ]
    for p in candidates:
        if p.exists():
            return load_json(p)
    raise FileNotFoundError(f"findings.json not found under {run_dir}")


def sha256_file(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def default_plan_path(run_dir: Path) -> Path:
    return run_dir / PLAN_REL_PATH


def gh_repo_visibility(repo: str) -> str:
    try:
        cp = run(["gh", "repo", "view", repo, "--json", "visibility", "--jq", ".visibility"], check=True)
        return cp.stdout.strip().upper() or "UNKNOWN"
    except Exception:
        return "UNKNOWN"


def issue_exists(repo: str, fingerprint: str) -> Optional[str]:
    marker = f"genai-repo-auditor:fingerprint={fingerprint}"
    try:
        cp = run([
            "gh", "issue", "list",
            "-R", repo,
            "--state", "open",
            "--search", f"{marker} in:body",
            "--json", "number,title,url",
            "--jq", ".[0].url // ''",
        ], check=True)
        return cp.stdout.strip() or None
    except subprocess.CalledProcessError:
        return None


def ensure_label(repo: str, name: str, color: str = "ededed", desc: str = "GenAI Repo Auditor label") -> None:
    subprocess.run([
        "gh", "label", "create", name,
        "-R", repo,
        "--color", color,
        "--description", desc,
        "--force",
    ], check=False)


def create_default_labels(repo: str) -> None:
    for name, (color, desc) in DEFAULT_LABELS.items():
        ensure_label(repo, name, color, desc)


def write_plan(plan_path: Path, plan: Dict[str, Any]) -> None:
    plan_path.parent.mkdir(parents=True, exist_ok=True)
    plan_path.write_text(json.dumps(plan, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def load_plan(plan_path: Path) -> Dict[str, Any]:
    plan = load_json(plan_path)
    if not isinstance(plan.get("selected_findings"), list):
        raise ValueError("issue publication plan must contain selected_findings array")
    for index, entry in enumerate(plan["selected_findings"]):
        if not isinstance(entry, dict):
            raise ValueError(f"selected_findings[{index}] must be an object")
    return plan


def plan_hash(plan_path: Path) -> str:
    return sha256_file(plan_path)


def print_plan_summary(plan_path: Optional[Path], plan: Dict[str, Any], *, prefix: str = "Plan") -> None:
    if plan_path is None:
        print(prefix)
    else:
        print(f"{prefix}: {plan_path}")
    for entry in plan.get("selected_findings") or []:
        print(f"- {entry.get('id', 'SEC-UNKNOWN')}: issue_body_sha256={entry.get('issue_body_sha256', '')}")
        advanced = entry.get("advanced_validation") if isinstance(entry.get("advanced_validation"), dict) else {}
        chains = advanced.get("chains") if isinstance(advanced.get("chains"), dict) else {}
        validation = advanced.get("adversarial_validation") if isinstance(advanced.get("adversarial_validation"), dict) else {}
        proof = advanced.get("safe_local_proof") if isinstance(advanced.get("safe_local_proof"), dict) else {}
        remediation = entry.get("remediation_candidate") if isinstance(entry.get("remediation_candidate"), dict) else {}
        chain_membership = entry.get("chain_membership") or []
        print(
            "  advanced_validation: "
            f"chain_membership={chain_membership or []}, "
            f"chains_matched={chains.get('matched') or []}, "
            f"adversarial_validation_exists={bool(validation.get('exists'))}, "
            f"safe_local_proof_exists={bool(proof.get('exists'))}, "
            f"proof_not_applicable={bool(proof.get('not_applicable'))}"
        )
        owner_routing = entry.get("owner_routing") if isinstance(entry.get("owner_routing"), dict) else {}
        if owner_routing:
            print(
                "  owner_routing: "
                f"component={owner_routing.get('component') or ''}, "
                f"owner_hint={owner_routing.get('owner_hint') or ''}, "
                f"owner_source={owner_routing.get('owner_source') or ''}"
            )
        print(
            "  remediation_candidate: "
            f"artifact_present={bool(remediation.get('artifact_present'))}, "
            f"exists={bool(remediation.get('exists'))}, "
            f"candidates={[item.get('id') for item in remediation.get('candidates') or [] if isinstance(item, dict)]}, "
            f"patch_validation_statuses="
            f"{[result.get('final_status') for item in remediation.get('candidates') or [] if isinstance(item, dict) for result in ((item.get('patch_validation') or {}).get('results') or []) if isinstance(result, dict)]}"
        )
        novelty = entry.get("novelty") if isinstance(entry.get("novelty"), dict) else {}
        print(
            "  novelty: "
            f"artifact_present={bool(novelty.get('artifact_present'))}, "
            f"status={novelty.get('status') or 'not-run'}, "
            f"suppresses_publication={bool(novelty.get('suppresses_publication'))}, "
            f"match_reasons={novelty.get('match_reasons') or []}"
        )
        for warning in advanced.get("warnings") or []:
            print(f"  WARNING: {warning}")
        for warning in remediation.get("warnings") or []:
            print(f"  WARNING: {warning}")


def print_dry_run_preview_summary(preview_plan_path: Path, plan: Dict[str, Any]) -> None:
    print("Dry-run preview only; no issue publication plan was written.")
    print(f"Preview plan path if promoted with --plan: {preview_plan_path}")
    print_plan_summary(preview_plan_path, plan, prefix="Preview issue publication entries")



def ledger_entry_from_plan_entry(
    entry: Dict[str, Any],
    body: str,
    *,
    publication_status: str,
    run_dir: Path,
    plan_path: Optional[Path],
    plan_sha256: Optional[str],
) -> Dict[str, Any]:
    return ledger_base_entry(
        finding_id=str(entry.get("id") or "SEC-UNKNOWN"),
        fingerprint=str(entry.get("fingerprint") or ""),
        title=str(entry.get("title") or ""),
        labels=[str(label) for label in entry.get("labels") or []],
        body_hash=str(entry.get("issue_body_sha256") or sha256_text(body)),
        publication_status=publication_status,
        source_plan=ledger_plan_source(plan_path, run_dir),
        plan_sha256=plan_sha256,
    )


def build_ledger_entries(
    *,
    repo: str,
    findings: Iterable[Dict[str, Any]],
    selected_entries: Iterable[Dict[str, Any]],
    selected_bodies: Dict[str, str],
    run_dir: Path,
    min_severity: str,
    statuses: Iterable[str],
    novelty_entries: Optional[Dict[str, Dict[str, Any]]],
    plan_path: Optional[Path],
    plan_sha256: Optional[str],
    overrides: Optional[Dict[str, Dict[str, Any]]] = None,
) -> List[Dict[str, Any]]:
    overrides = overrides or {}
    selected_by_key: Dict[str, Tuple[Dict[str, Any], str]] = {}
    for entry in selected_entries:
        if not isinstance(entry, dict):
            continue
        selected_by_key[plan_entry_key(entry)] = (entry, selected_bodies.get(plan_entry_key(entry), ""))

    entries: List[Dict[str, Any]] = []
    for finding in findings:
        if not isinstance(finding, dict):
            continue
        finding_id = str(finding.get("id") or "SEC-UNKNOWN")
        fingerprint = stable_fingerprint(repo, finding)
        key = f"{finding_id}\0{fingerprint}"
        if key in overrides:
            entries.append(dict(overrides[key]))
            continue
        planned = selected_by_key.get(key)
        if planned:
            entry, body = planned
            entries.append(
                ledger_entry_from_plan_entry(
                    entry,
                    body,
                    publication_status="pending",
                    run_dir=run_dir,
                    plan_path=plan_path,
                    plan_sha256=plan_sha256,
                )
            )
        else:
            entries.append(
                ledger_base_entry(
                    finding_id=finding_id,
                    fingerprint=fingerprint,
                    title=issue_title(finding),
                    labels=normalize_labels(finding),
                    body_hash=None,
                    publication_status="not-selected",
                    selection_reason=finding_selection_reason(
                        finding,
                        min_severity,
                        statuses,
                        repo=repo,
                        novelty_entries=novelty_entries,
                    ),
                    source_plan=ledger_plan_source(plan_path, run_dir),
                    plan_sha256=plan_sha256,
                )
            )
    return entries


def write_issue_ledger_snapshot(
    *,
    run_dir: Path,
    repo: str,
    run_id: str,
    commit: str,
    findings: Iterable[Dict[str, Any]],
    selected_entries: Iterable[Dict[str, Any]],
    selected_bodies: Dict[str, str],
    min_severity: str,
    statuses: Iterable[str],
    novelty_entries: Optional[Dict[str, Dict[str, Any]]],
    plan_path: Optional[Path],
    plan_sha256: Optional[str],
    plan_written: bool,
    publication_plan_status: str,
    overrides: Optional[Dict[str, Dict[str, Any]]] = None,
) -> Dict[str, Any]:
    ledger_path = default_ledger_path(run_dir)
    existing = load_ledger(ledger_path, run_id=run_id, repo=repo, commit=commit)
    current_entries = build_ledger_entries(
        repo=repo,
        findings=findings,
        selected_entries=selected_entries,
        selected_bodies=selected_bodies,
        run_dir=run_dir,
        min_severity=min_severity,
        statuses=statuses,
        novelty_entries=novelty_entries,
        plan_path=plan_path,
        plan_sha256=plan_sha256,
        overrides=overrides,
    )
    ledger = merge_current_entries(
        existing=existing,
        current_entries=current_entries,
        run_id=run_id,
        repo=repo,
        commit=commit,
        plan_written=plan_written,
        publication_plan_status=publication_plan_status,
    )
    write_ledger(ledger_path, ledger)
    print(f"Wrote issue ledger: {ledger_path}")
    return ledger


def record_duplicate_decision(
    *,
    run_dir: Path,
    run_id: str,
    repo: str,
    commit: str,
    finding: Dict[str, Any],
    fingerprint: str,
    exact_match_url: Optional[str] = None,
    exact_match_source: Optional[str] = None,
) -> Tuple[str, str]:
    decision = duplicate_decision_for(
        run_id=run_id,
        repo=repo,
        commit=commit,
        finding=finding,
        fingerprint=fingerprint,
        exact_match_url=exact_match_url,
        exact_match_source=exact_match_source,
    )
    path = write_duplicate_decision(run_dir, decision)
    rel_path = duplicate_decision_rel_to_run(run_dir, path)
    print(f"Wrote duplicate decision: {rel_path}")
    return rel_path, str(decision.get("decision") or "")


def verify_ledger_against_github(repo: str, ledger: Dict[str, Any]) -> List[str]:
    drifts: List[str] = []
    for entry in ledger.get("findings") or []:
        if not isinstance(entry, dict) or not entry.get("url"):
            continue
        if str(entry.get("publication_status") or "") not in {"published", "duplicate"}:
            continue
        fingerprint = str(entry.get("fingerprint") or "")
        finding_id = str(entry.get("finding_id") or "SEC-UNKNOWN")
        if not fingerprint:
            drifts.append(f"{finding_id}: published ledger entry has no fingerprint")
            continue
        existing_url = issue_exists(repo, fingerprint)
        if not existing_url:
            drifts.append(f"{finding_id}: no open GitHub issue found for ledger fingerprint {fingerprint}")
        elif existing_url != entry.get("url"):
            drifts.append(f"{finding_id}: ledger url {entry.get('url')} differs from GitHub search result {existing_url}")
    return drifts



def main() -> int:
    parser = argparse.ArgumentParser(description="Create GitHub Issues from GenAI Repo Auditor findings.json")
    parser.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    parser.add_argument("--run", required=True, help="Run directory, e.g. runs/OWNER__REPO/RUN_ID")
    parser.add_argument("--repo", help="Override target repo OWNER/REPO")
    parser.add_argument("--min-severity", choices=list(SEVERITY_RANK), default="High")
    parser.add_argument("--statuses", default="Confirmed,Probable", help="Comma-separated statuses to publish")
    parser.add_argument("--dry-run", action="store_true", help="Preview issue creation. Default unless --apply is set.")
    parser.add_argument("--apply", action="store_true", help="Actually create issues")
    parser.add_argument("--plan", action="store_true", help="Write an immutable issue publication plan without creating issues")
    parser.add_argument("--apply-plan", help="Apply a previously reviewed issue-publication-plan.json")
    parser.add_argument("--replan", action="store_true", help="Refresh the plan when current findings or issue drafts changed; does not publish")
    parser.add_argument("--verify-ledger", action="store_true", help="Verify reports/issue-ledger.json against open GitHub issues and exit without publishing")
    parser.add_argument("--allow-public", action="store_true", help="Allow publishing issues to public repositories")
    parser.add_argument("--create-labels", action="store_true", help="Create/update common labels before creating issues")
    parser.add_argument("--assignee", help="Optional assignee, e.g. @me")
    parser.add_argument("--max-issues", type=int, default=50, help="Safety limit")
    parser.add_argument(
        "--require-advanced-validation",
        action="store_true",
        help="Fail when selected High/Critical findings lack related chain, proof, or adversarial validation artifacts",
    )
    args = parser.parse_args()

    if args.plan and args.apply:
        parser.error("--plan cannot be combined with --apply")
    if args.plan and args.apply_plan:
        parser.error("--plan cannot be combined with --apply-plan")
    if args.verify_ledger and (args.plan or args.apply or args.apply_plan or args.replan or args.dry_run):
        parser.error("--verify-ledger cannot be combined with plan, dry-run, or apply options")

    run_dir = Path(args.run).resolve()
    context = load_context(run_dir)
    data = load_findings(run_dir)
    repo = args.repo or data.get("repo") or context.get("repo")
    if not repo:
        print("Repo not specified and not found in findings.json/context.json", file=sys.stderr)
        return 2

    run_id = str(data.get("run_id") or context.get("run_id") or run_dir.name)
    commit = str(data.get("commit") or context.get("commit") or "")
    statuses = {s.strip() for s in args.statuses.split(",") if s.strip()}
    dry_run = args.dry_run or (not args.apply and not args.apply_plan)

    generated_at = str(data.get("generated_at") or context.get("generated_at") or "")
    findings = data.get("findings") or []
    all_findings = [f for f in findings if isinstance(f, dict)]
    novelty_entries = novelty_by_finding_id(run_dir)
    selected = select_findings(
        repo=repo,
        findings=all_findings,
        min_severity=args.min_severity,
        statuses=statuses,
        novelty_entries=novelty_entries,
    )
    if args.verify_ledger:
        ledger_path = default_ledger_path(run_dir)
        if not ledger_path.exists():
            print(f"ERROR: issue ledger not found: {ledger_path}", file=sys.stderr)
            return 2
        try:
            ledger = load_ledger(ledger_path, run_id=run_id, repo=repo, commit=commit)
        except (OSError, ValueError, json.JSONDecodeError) as exc:
            print(f"ERROR: could not read issue ledger: {exc}", file=sys.stderr)
            return 2
        drifts = verify_ledger_against_github(repo, ledger)
        drifts.extend(verify_duplicate_decisions_for_ledger(run_dir, ledger))
        if drifts:
            print("Issue ledger drift detected:", file=sys.stderr)
            for drift in drifts:
                print(f"- {drift}", file=sys.stderr)
            return 4
        print(f"Issue ledger verified: {ledger_path}")
        return 0
    if len(selected) > args.max_issues:
        print(f"Refusing to create {len(selected)} issues; exceeds --max-issues={args.max_issues}.", file=sys.stderr)
        return 4
    advanced_artifacts = load_advanced_artifacts(run_dir)

    if args.plan:
        try:
            plan, _bodies = build_publication_plan(
                repo=repo,
                run_id=run_id,
                commit=commit,
                visibility=plan_visibility(data, context),
                findings=selected,
                run_dir=run_dir,
                generated_at=generated_at,
                advanced_artifacts=advanced_artifacts,
                novelty_entries=novelty_entries,
            )
        except ReportSafetyError as exc:
            print(f"ERROR: {exc}", file=sys.stderr)
            return 2
        requirement_errors = advanced_validation_errors(plan.get("selected_findings") or [])
        if args.require_advanced_validation and requirement_errors:
            print("Advanced validation requirements failed:", file=sys.stderr)
            for error in requirement_errors:
                print(f"- {error}", file=sys.stderr)
            return 4
        plan_path = default_plan_path(run_dir)
        write_plan(plan_path, plan)
        plan_sha256 = plan_hash(plan_path)
        print_plan_summary(plan_path, plan, prefix="Wrote issue publication plan")
        write_issue_ledger_snapshot(
            run_dir=run_dir,
            repo=repo,
            run_id=run_id,
            commit=commit,
            findings=all_findings,
            selected_entries=plan.get("selected_findings") or [],
            selected_bodies=_bodies,
            min_severity=args.min_severity,
            statuses=statuses,
            novelty_entries=novelty_entries,
            plan_path=plan_path,
            plan_sha256=plan_sha256,
            plan_written=True,
            publication_plan_status="written",
        )
        return 0

    selected_plan_entries: Optional[List[Dict[str, Any]]] = None
    plan_bodies: Dict[str, str] = {}
    plan_path: Optional[Path] = None
    plan_sha256: Optional[str] = None
    if args.apply_plan:
        plan_path = Path(args.apply_plan)
        if not plan_path.is_absolute():
            plan_path = (Path.cwd() / plan_path).resolve()
        if args.replan:
            try:
                refreshed, _bodies = build_publication_plan(
                    repo=repo,
                    run_id=run_id,
                    commit=commit,
                    visibility=plan_visibility(data, context),
                    findings=selected,
                    run_dir=run_dir,
                    generated_at=generated_at,
                    advanced_artifacts=advanced_artifacts,
                    novelty_entries=novelty_entries,
                )
                requirement_errors = advanced_validation_errors(refreshed.get("selected_findings") or [])
                if args.require_advanced_validation and requirement_errors:
                    print("Advanced validation requirements failed:", file=sys.stderr)
                    for error in requirement_errors:
                        print(f"- {error}", file=sys.stderr)
                    return 4
                write_plan(plan_path, refreshed)
                refreshed_sha256 = plan_hash(plan_path)
                print_plan_summary(plan_path, refreshed, prefix="Rewrote issue publication plan")
                write_issue_ledger_snapshot(
                    run_dir=run_dir,
                    repo=repo,
                    run_id=run_id,
                    commit=commit,
                    findings=all_findings,
                    selected_entries=refreshed.get("selected_findings") or [],
                    selected_bodies=_bodies,
                    min_severity=args.min_severity,
                    statuses=statuses,
                    novelty_entries=novelty_entries,
                    plan_path=plan_path,
                    plan_sha256=refreshed_sha256,
                    plan_written=True,
                    publication_plan_status="rewritten",
                )
            except ReportSafetyError as exc:
                print(f"ERROR: {exc}", file=sys.stderr)
                return 2
            print("Review the refreshed issue publication plan before applying.", file=sys.stderr)
            return 0
        try:
            plan = load_plan(plan_path)
            selected_plan_entries, plan_bodies, plan_errors = verify_plan_against_findings(
                plan=plan,
                repo=repo,
                run_id=run_id,
                commit=commit,
                current_findings=all_findings,
                run_dir=run_dir,
                advanced_artifacts=advanced_artifacts,
                novelty_entries=novelty_entries,
            )
        except (OSError, ValueError, json.JSONDecodeError, ReportSafetyError) as exc:
            print(f"ERROR: could not read or verify issue publication plan: {exc}", file=sys.stderr)
            return 2
        if plan_errors:
            print("Issue publication plan verification failed:", file=sys.stderr)
            for error in plan_errors:
                print(f"- {error}", file=sys.stderr)
            print("Refresh the plan with --plan or --apply-plan ... --replan, review it, then apply again.", file=sys.stderr)
            return 4
        if selected_plan_entries is not None and len(selected_plan_entries) > args.max_issues:
            print(f"Refusing to create {len(selected_plan_entries)} issues; exceeds --max-issues={args.max_issues}.", file=sys.stderr)
            return 4
        plan_sha256 = plan_hash(plan_path)
        print_plan_summary(plan_path, plan, prefix="Verified issue publication plan")
        requirement_errors = advanced_validation_errors(selected_plan_entries or [])
        if args.require_advanced_validation and requirement_errors:
            print("Advanced validation requirements failed:", file=sys.stderr)
            for error in requirement_errors:
                print(f"- {error}", file=sys.stderr)
            return 4
        if args.dry_run:
            dry_run = True
            print("Dry-run preview only; verified issue publication plan was not applied.")

    visibility = gh_repo_visibility(repo) if not dry_run else "NOT_CHECKED"
    if not dry_run and visibility in {"PUBLIC", "UNKNOWN", ""} and not args.allow_public:
        print(f"Refusing to create security issues for repo {repo} with visibility={visibility}. Use --allow-public only when disclosure policy permits.", file=sys.stderr)
        return 3

    if args.create_labels and not dry_run:
        create_default_labels(repo)

    plan_verified = bool(plan_path and plan_sha256 and args.apply_plan)
    if args.apply_plan:
        publication_plan_status = "verified-existing-plan-preview" if dry_run else "verified-existing-plan-applied"
    elif dry_run:
        publication_plan_status = "not-written-preview"
    else:
        publication_plan_status = "not-written-direct-apply"

    result = {
        "repo": repo,
        "run_id": run_id,
        "commit": commit,
        "visibility": visibility,
        "dry_run": dry_run,
        "preview_only": dry_run,
        "plan_written": False,
        "plan_verified": plan_verified,
        "publication_plan_status": publication_plan_status,
        "plan_path": str(plan_path) if plan_path else None,
        "preview_plan_path": str(default_plan_path(run_dir)) if dry_run and plan_path is None else None,
        "plan_sha256": plan_sha256,
        "ledger_path": str(default_ledger_path(run_dir)),
        "duplicate_decisions_path": str(run_dir / "reports" / "duplicate-decisions"),
        "duplicate_decisions": [],
        "created": [],
        "skipped": [],
    }

    issue_entries: List[Tuple[Dict[str, Any], str]] = []
    if selected_plan_entries is not None:
        issue_entries = [(entry, plan_bodies.get(plan_entry_key(entry), "")) for entry in selected_plan_entries]
    else:
        try:
            preview_plan, preview_bodies = build_publication_plan(
                repo=repo,
                run_id=run_id,
                commit=commit,
                visibility=plan_visibility(data, context),
                findings=selected,
                run_dir=run_dir,
                generated_at=generated_at,
                advanced_artifacts=advanced_artifacts,
                novelty_entries=novelty_entries,
            )
        except ReportSafetyError as exc:
            print(f"ERROR: {exc}", file=sys.stderr)
            return 2
        requirement_errors = advanced_validation_errors(preview_plan.get("selected_findings") or [])
        if args.require_advanced_validation and requirement_errors:
            print("Advanced validation requirements failed:", file=sys.stderr)
            for error in requirement_errors:
                print(f"- {error}", file=sys.stderr)
            return 4
        if dry_run:
            print_dry_run_preview_summary(default_plan_path(run_dir), preview_plan)
        else:
            print_plan_summary(None, preview_plan, prefix="Direct apply transient issue selection; no issue publication plan was written")
        issue_entries = [(entry, preview_bodies.get(plan_entry_key(entry), "")) for entry in preview_plan["selected_findings"]]

    findings_by_key = {
        finding_key(str(finding.get("id") or "SEC-UNKNOWN"), stable_fingerprint(repo, finding)): finding
        for finding in all_findings
        if isinstance(finding, dict)
    }

    try:
        existing_ledger = load_ledger(default_ledger_path(run_dir), run_id=run_id, repo=repo, commit=commit)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(f"ERROR: could not read issue ledger: {exc}", file=sys.stderr)
        return 2
    ledger_overrides: Dict[str, Dict[str, Any]] = {}

    for entry, body in issue_entries:
        fingerprint = str(entry["fingerprint"])
        finding_id = str(entry.get("id", "SEC-UNKNOWN"))
        title = str(entry["title"])
        labels = list(entry.get("labels") or [])
        body_hash = str(entry.get("issue_body_sha256") or sha256_text(body))
        ledger_key = plan_entry_key(entry)
        original_finding = findings_by_key.get(ledger_key) or {"id": finding_id}
        ledger_entry = ledger_entry_from_plan_entry(
            entry,
            body,
            publication_status="pending",
            run_dir=run_dir,
            plan_path=plan_path,
            plan_sha256=plan_sha256,
        )

        existing_from_ledger = None if dry_run else ledger_published_entry(existing_ledger, finding_id=finding_id, fingerprint=fingerprint)
        if not dry_run and not existing_from_ledger:
            existing_from_ledger = ledger_published_entry_by_finding_id(existing_ledger, finding_id=finding_id)
            if existing_from_ledger:
                previous_fingerprint = str(existing_from_ledger.get("fingerprint") or "")
                ledger_entry["previous_fingerprint"] = previous_fingerprint
                ledger_entry.setdefault("drift", [])
                ledger_entry["drift"] = list(ledger_entry.get("drift") or []) + [
                    "current fingerprint differs from published ledger fingerprint"
                ]
                ledger_overrides[ledger_key] = ledger_mark_published(
                    ledger_entry,
                    url=str(existing_from_ledger.get("url") or ""),
                    published_at=str(existing_from_ledger.get("published_at") or "") or ledger_utc_now(),
                    duplicate_detected=(
                        bool(existing_from_ledger.get("duplicate_detected"))
                        or str(existing_from_ledger.get("publication_status") or "") == "duplicate"
                    ),
                    state=str(existing_from_ledger.get("state") or "open"),
                )
        if existing_from_ledger:
            decision_file, decision_value = record_duplicate_decision(
                run_dir=run_dir,
                run_id=run_id,
                repo=repo,
                commit=commit,
                finding=original_finding,
                fingerprint=fingerprint,
                exact_match_url=str(existing_from_ledger.get("url") or ""),
                exact_match_source="issue-ledger",
            )
            ledger_overrides.setdefault(ledger_key, ledger_mark_published(
                ledger_entry,
                url=str(existing_from_ledger.get("url") or ""),
                published_at=str(existing_from_ledger.get("published_at") or "") or ledger_utc_now(),
                duplicate_detected=(
                    bool(existing_from_ledger.get("duplicate_detected"))
                    or str(existing_from_ledger.get("publication_status") or "") == "duplicate"
                ),
                state=str(existing_from_ledger.get("state") or "open"),
            ))
            ledger_overrides[ledger_key]["duplicate_decision_file"] = decision_file
            result["duplicate_decisions"].append({"id": finding_id, "path": decision_file, "decision": decision_value})
            result["skipped"].append({
                "id": finding_id,
                "reason": "ledger",
                "url": existing_from_ledger.get("url"),
                "fingerprint": fingerprint,
            })
            print(f"SKIP ledger {finding_id}: {existing_from_ledger.get('url')}")
            continue

        existing = None if dry_run else issue_exists(repo, fingerprint)
        if existing:
            decision_file, decision_value = record_duplicate_decision(
                run_dir=run_dir,
                run_id=run_id,
                repo=repo,
                commit=commit,
                finding=original_finding,
                fingerprint=fingerprint,
                exact_match_url=existing,
                exact_match_source="github-fingerprint-search",
            )
            result["skipped"].append({"id": finding_id, "reason": "duplicate", "url": existing, "fingerprint": fingerprint})
            ledger_overrides[ledger_key] = ledger_mark_published(ledger_entry, url=existing, duplicate_detected=True)
            ledger_overrides[ledger_key]["duplicate_decision_file"] = decision_file
            result["duplicate_decisions"].append({"id": finding_id, "path": decision_file, "decision": decision_value})
            print(f"SKIP duplicate {finding_id}: {existing}")
            continue

        decision_file, decision_value = record_duplicate_decision(
            run_dir=run_dir,
            run_id=run_id,
            repo=repo,
            commit=commit,
            finding=original_finding,
            fingerprint=fingerprint,
        )
        ledger_entry["duplicate_decision_file"] = decision_file
        result["duplicate_decisions"].append({"id": finding_id, "path": decision_file, "decision": decision_value})

        if dry_run:
            print("---")
            print(f"DRY RUN: would create issue for {finding_id}")
            print(f"Title: {title}")
            print(f"Labels: {', '.join(labels)}")
            print(f"Fingerprint: {fingerprint}")
            print(f"Issue body SHA256: {body_hash}")
            result["created"].append({"id": finding_id, "dry_run": True, "title": title, "fingerprint": fingerprint, "issue_body_sha256": body_hash})
            ledger_overrides[ledger_key] = ledger_mark_dry_run(ledger_entry)
            continue

        tmp_dir = run_dir / "reports" / ".issue-body-tmp"
        tmp_dir.mkdir(parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile("w", encoding="utf-8", suffix=".md", dir=tmp_dir, delete=False) as tmp:
            tmp.write(body)
            tmp_path = tmp.name
        try:
            if args.create_labels:
                for label in labels:
                    if label not in DEFAULT_LABELS:
                        ensure_label(repo, label, "ededed", "GenAI Repo Auditor label")
            cmd = ["gh", "issue", "create", "-R", repo, "--title", title, "--body-file", tmp_path]
            for label in labels:
                cmd.extend(["--label", label])
            if args.assignee:
                cmd.extend(["--assignee", args.assignee])
            cp = run(cmd, check=True)
            url = cp.stdout.strip()
            print(f"CREATED {finding_id}: {url}")
            result["created"].append({"id": finding_id, "url": url, "title": title, "fingerprint": fingerprint})
            ledger_overrides[ledger_key] = ledger_mark_published(ledger_entry, url=url, published_at=ledger_utc_now())
        finally:
            with contextlib.suppress(OSError):
                os.unlink(tmp_path)
            with contextlib.suppress(OSError):
                tmp_dir.rmdir()

    write_issue_ledger_snapshot(
        run_dir=run_dir,
        repo=repo,
        run_id=run_id,
        commit=commit,
        findings=all_findings,
        selected_entries=[entry for entry, _body in issue_entries],
        selected_bodies={plan_entry_key(entry): body for entry, body in issue_entries},
        min_severity=args.min_severity,
        statuses=statuses,
        novelty_entries=novelty_entries,
        plan_path=plan_path,
        plan_sha256=plan_sha256,
        plan_written=False,
        publication_plan_status=publication_plan_status,
        overrides=ledger_overrides,
    )

    output_path = run_dir / "issues-created.json"
    output_path.write_text(json.dumps(result, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    print(f"Wrote {output_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

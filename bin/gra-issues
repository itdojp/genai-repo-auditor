#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from version import auditor_version
from report_safety import ReportSafetyError, safe_issue_body_path  # noqa: E402

SEVERITY_RANK = {"Critical": 5, "High": 4, "Medium": 3, "Low": 2, "Informational": 1}
DEFAULT_LABELS: Dict[str, Tuple[str, str]] = {
    "security": ("d73a4a", "Security-related issue"),
    "genai-audit": ("5319e7", "Generated from local GenAI Repo Auditor"),
    "severity-critical": ("b60205", "Critical security severity"),
    "severity-high": ("d93f0b", "High security severity"),
    "severity-medium": ("fbca04", "Medium security severity"),
    "severity-low": ("0e8a16", "Low security severity"),
    "severity-informational": ("1d76db", "Informational security severity"),
    "status-confirmed": ("b60205", "Confirmed finding"),
    "status-probable": ("d93f0b", "Probable finding"),
    "status-potential": ("fbca04", "Potential finding"),
    "status-needs-human-review": ("5319e7", "Needs human review"),
}
PLAN_REL_PATH = Path("reports") / "issue-publication-plan.json"


def run(cmd: List[str], *, check: bool = True, capture: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=check, text=True, stdout=subprocess.PIPE if capture else None, stderr=subprocess.PIPE if capture else None)


def load_json(path: Path) -> Dict[str, Any]:
    return json.loads(path.read_text(encoding="utf-8"))


def load_context(run_dir: Path) -> Dict[str, Any]:
    p = run_dir / "context.json"
    return load_json(p) if p.exists() else {}


def load_findings(run_dir: Path) -> Dict[str, Any]:
    candidates = [
        run_dir / "reports" / "findings.json",
        run_dir / "repo" / ".genai-audit" / "reports" / "findings.json",
    ]
    for p in candidates:
        if p.exists():
            return load_json(p)
    raise FileNotFoundError(f"findings.json not found under {run_dir}")


def sha256_text(value: str) -> str:
    return hashlib.sha256(value.encode("utf-8")).hexdigest()


def sha256_file(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def default_plan_path(run_dir: Path) -> Path:
    return run_dir / PLAN_REL_PATH


def slug(s: str, *, max_len: int = 50) -> str:
    out = re.sub(r"[^a-z0-9]+", "-", s.lower()).strip("-")
    return out[:max_len] or "unknown"


def loc_file_line(loc: Any) -> Tuple[str, Optional[Any], Optional[Any]]:
    if not isinstance(loc, dict):
        return str(loc), None, None
    file_ = loc.get("file") or loc.get("path") or ""
    line = loc.get("line") or loc.get("start_line")
    end = loc.get("end_line")
    return str(file_), line, end


def stable_fingerprint(repo: str, finding: Dict[str, Any]) -> str:
    existing = str(finding.get("fingerprint") or "").strip()
    if existing and existing.lower() not in {"n/a", "none", "unknown"}:
        return existing
    locs = finding.get("affected_locations") or []
    loc_str = ";".join(f"{loc_file_line(x)[0]}:{loc_file_line(x)[1] or ''}" for x in locs)
    raw = "|".join([
        repo,
        str(finding.get("category", "")),
        str(finding.get("title", "")),
        loc_str,
        str(finding.get("entry_point", "")),
        str(finding.get("trust_boundary", "")),
        str(finding.get("call_path") or finding.get("source_to_sink") or ""),
        str(finding.get("root_cause", "")),
    ])
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()[:24]


def render_locations(locs: Iterable[Any]) -> str:
    lines = []
    for loc in locs:
        file_, line, end = loc_file_line(loc)
        if line and end and str(end) != str(line):
            lines.append(f"- `{file_}:{line}-{end}`")
        elif line:
            lines.append(f"- `{file_}:{line}`")
        elif file_:
            lines.append(f"- `{file_}`")
    return "\n".join(lines) if lines else "- Not specified"


def render_body(repo: str, run_id: str, commit: str, finding: Dict[str, Any], fingerprint: str, run_dir: Path) -> str:
    issue_body_file = str(finding.get("issue_body_file") or "")
    if issue_body_file:
        p = safe_issue_body_path(run_dir, issue_body_file)
        body = p.read_text(encoding="utf-8")
        if "genai-repo-auditor:fingerprint=" not in body and "gra-fingerprint:" not in body:
            body += f"\n\n<!-- genai-repo-auditor:fingerprint={fingerprint} -->\n"
        return body

    title = str(finding.get("title") or "Security finding")
    call_path = finding.get("call_path") or finding.get("source_to_sink") or "Not specified"
    body = f"""# {title}

<!-- genai-repo-auditor:fingerprint={fingerprint} -->

## Summary

{finding.get('root_cause') or finding.get('evidence') or 'See audit report.'}

## Severity / confidence / status

- Severity: {finding.get('severity', 'Unknown')}
- Confidence: {finding.get('confidence', 'Unknown')}
- Status: {finding.get('status', 'Unknown')}
- Category: {finding.get('category', 'Unknown')}

## Affected code

{render_locations(finding.get('affected_locations') or [])}

## Entry point

{finding.get('entry_point', 'Not specified')}

## Trust boundary

{finding.get('trust_boundary', 'Not specified')}

## Call path / source-to-sink

{call_path}

## Evidence

{finding.get('evidence', 'See audit report.')}

## Impact

{finding.get('impact', 'Not specified')}

## Minimal remediation

{finding.get('minimal_remediation', 'Not specified')}

## Regression test

{finding.get('regression_test_idea', 'Not specified')}

## Audit metadata

- Repository: `{repo}`
- Run ID: `{run_id}`
- Commit: `{commit}`
- Finding ID: `{finding.get('id', 'Unknown')}`
"""
    return body


def gh_repo_visibility(repo: str) -> str:
    try:
        cp = run(["gh", "repo", "view", repo, "--json", "visibility", "--jq", ".visibility"], check=True)
        return cp.stdout.strip().upper() or "UNKNOWN"
    except Exception:
        return "UNKNOWN"


def issue_exists(repo: str, fingerprint: str) -> Optional[str]:
    marker = f"genai-repo-auditor:fingerprint={fingerprint}"
    try:
        cp = run([
            "gh", "issue", "list",
            "-R", repo,
            "--state", "open",
            "--search", f"{marker} in:body",
            "--json", "number,title,url",
            "--jq", ".[0].url // ''",
        ], check=True)
        return cp.stdout.strip() or None
    except subprocess.CalledProcessError:
        return None


def ensure_label(repo: str, name: str, color: str = "ededed", desc: str = "GenAI Repo Auditor label") -> None:
    subprocess.run([
        "gh", "label", "create", name,
        "-R", repo,
        "--color", color,
        "--description", desc,
        "--force",
    ], check=False)


def create_default_labels(repo: str) -> None:
    for name, (color, desc) in DEFAULT_LABELS.items():
        ensure_label(repo, name, color, desc)


def should_include(finding: Dict[str, Any], min_severity: str, statuses: Iterable[str]) -> bool:
    if finding.get("issue_recommended") is False:
        return False
    severity = finding.get("severity", "Informational")
    status = finding.get("status", "")
    return SEVERITY_RANK.get(severity, 0) >= SEVERITY_RANK[min_severity] and status in set(statuses)


def normalize_labels(finding: Dict[str, Any]) -> List[str]:
    labels = ["security", "genai-audit"]
    severity = str(finding.get("severity", "")).lower()
    if severity:
        labels.append(f"severity-{slug(severity)}")
    status = str(finding.get("status", "")).lower()
    if status:
        labels.append(f"status-{slug(status)}")
    category = str(finding.get("category", "")).strip()
    if category:
        labels.append(f"category-{slug(category)}")
    for label in finding.get("labels") or []:
        label = str(label).strip()
        if label and label not in labels:
            labels.append(label)
    return labels


def issue_title(finding: Dict[str, Any]) -> str:
    return str(finding.get("issue_title") or f"[Security][{finding.get('severity','Unknown')}] {finding.get('title','Security finding')}")


def plan_visibility(data: Dict[str, Any], context: Dict[str, Any]) -> str:
    return str(data.get("visibility") or context.get("visibility") or "UNKNOWN").upper()


def plan_finding_entry(repo: str, run_id: str, commit: str, finding: Dict[str, Any], run_dir: Path) -> Tuple[Dict[str, Any], str]:
    fingerprint = stable_fingerprint(repo, finding)
    body = render_body(repo, run_id, commit, finding, fingerprint, run_dir)
    issue_body_file = str(finding.get("issue_body_file") or "")
    entry: Dict[str, Any] = {
        "id": str(finding.get("id", "SEC-UNKNOWN")),
        "fingerprint": fingerprint,
        "title": issue_title(finding),
        "issue_body_sha256": sha256_text(body),
        "issue_body_file": issue_body_file or None,
        "labels": normalize_labels(finding),
        "public_disclosure_risk": str(finding.get("public_disclosure_risk") or "Unknown"),
    }
    return entry, body


def build_publication_plan(
    *,
    repo: str,
    run_id: str,
    commit: str,
    visibility: str,
    findings: Iterable[Dict[str, Any]],
    run_dir: Path,
    generated_at: str,
) -> Tuple[Dict[str, Any], Dict[str, str]]:
    selected_findings: List[Dict[str, Any]] = []
    bodies: Dict[str, str] = {}
    for finding in findings:
        entry, body = plan_finding_entry(repo, run_id, commit, finding, run_dir)
        selected_findings.append(entry)
        bodies[entry["id"]] = body
    plan = {
        "schema_version": "1",
        "run_id": run_id,
        "repo": repo,
        "commit": commit,
        "created_at": generated_at,
        "visibility": visibility,
        "selected_findings": selected_findings,
    }
    return plan, bodies


def write_plan(plan_path: Path, plan: Dict[str, Any]) -> None:
    plan_path.parent.mkdir(parents=True, exist_ok=True)
    plan_path.write_text(json.dumps(plan, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def load_plan(plan_path: Path) -> Dict[str, Any]:
    plan = load_json(plan_path)
    if not isinstance(plan.get("selected_findings"), list):
        raise ValueError("issue publication plan must contain selected_findings array")
    return plan


def plan_hash(plan_path: Path) -> str:
    return sha256_file(plan_path)


def print_plan_summary(plan_path: Path, plan: Dict[str, Any], *, prefix: str = "Plan") -> None:
    print(f"{prefix}: {plan_path}")
    for entry in plan.get("selected_findings") or []:
        print(f"- {entry.get('id', 'SEC-UNKNOWN')}: issue_body_sha256={entry.get('issue_body_sha256', '')}")


def verify_plan_against_findings(
    *,
    plan: Dict[str, Any],
    repo: str,
    run_id: str,
    commit: str,
    current_findings: Iterable[Dict[str, Any]],
    run_dir: Path,
) -> Tuple[List[Dict[str, Any]], Dict[str, str], List[str]]:
    findings_by_id = {str(finding.get("id", "SEC-UNKNOWN")): finding for finding in current_findings}
    selected: List[Dict[str, Any]] = []
    bodies: Dict[str, str] = {}
    errors: List[str] = []

    if str(plan.get("repo") or "") != repo:
        errors.append(f"repo mismatch: plan={plan.get('repo')!r} current={repo!r}")
    if str(plan.get("run_id") or "") != run_id:
        errors.append(f"run_id mismatch: plan={plan.get('run_id')!r} current={run_id!r}")
    if str(plan.get("commit") or "") != commit:
        errors.append(f"commit mismatch: plan={plan.get('commit')!r} current={commit!r}")

    for planned in plan.get("selected_findings") or []:
        finding_id = str(planned.get("id") or "")
        finding = findings_by_id.get(finding_id)
        if finding is None:
            errors.append(f"{finding_id or 'SEC-UNKNOWN'}: selected finding no longer exists")
            continue
        current_entry, body = plan_finding_entry(repo, run_id, commit, finding, run_dir)
        for field in ["fingerprint", "title", "issue_body_sha256", "issue_body_file", "public_disclosure_risk"]:
            if planned.get(field) != current_entry.get(field):
                errors.append(f"{finding_id}: {field} changed after plan creation")
        if list(planned.get("labels") or []) != current_entry["labels"]:
            errors.append(f"{finding_id}: labels changed after plan creation")
        selected.append(current_entry)
        bodies[finding_id] = body
    return selected, bodies, errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Create GitHub Issues from GenAI Repo Auditor findings.json")
    parser.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    parser.add_argument("--run", required=True, help="Run directory, e.g. runs/OWNER__REPO/RUN_ID")
    parser.add_argument("--repo", help="Override target repo OWNER/REPO")
    parser.add_argument("--min-severity", choices=list(SEVERITY_RANK), default="High")
    parser.add_argument("--statuses", default="Confirmed,Probable", help="Comma-separated statuses to publish")
    parser.add_argument("--dry-run", action="store_true", help="Preview issue creation. Default unless --apply is set.")
    parser.add_argument("--apply", action="store_true", help="Actually create issues")
    parser.add_argument("--plan", action="store_true", help="Write an immutable issue publication plan without creating issues")
    parser.add_argument("--apply-plan", help="Apply a previously reviewed issue-publication-plan.json")
    parser.add_argument("--replan", action="store_true", help="Refresh the plan when current findings or issue drafts changed; does not publish")
    parser.add_argument("--allow-public", action="store_true", help="Allow publishing issues to public repositories")
    parser.add_argument("--create-labels", action="store_true", help="Create/update common labels before creating issues")
    parser.add_argument("--assignee", help="Optional assignee, e.g. @me")
    parser.add_argument("--max-issues", type=int, default=50, help="Safety limit")
    args = parser.parse_args()

    if args.plan and args.apply:
        parser.error("--plan cannot be combined with --apply")
    if args.plan and args.apply_plan:
        parser.error("--plan cannot be combined with --apply-plan")

    run_dir = Path(args.run).resolve()
    context = load_context(run_dir)
    data = load_findings(run_dir)
    repo = args.repo or data.get("repo") or context.get("repo")
    if not repo:
        print("Repo not specified and not found in findings.json/context.json", file=sys.stderr)
        return 2

    run_id = str(data.get("run_id") or context.get("run_id") or run_dir.name)
    commit = str(data.get("commit") or context.get("commit") or "")
    statuses = {s.strip() for s in args.statuses.split(",") if s.strip()}
    dry_run = args.dry_run or (not args.apply and not args.apply_plan)

    generated_at = str(data.get("generated_at") or context.get("generated_at") or "")
    findings = data.get("findings") or []
    selected = [f for f in findings if isinstance(f, dict) and should_include(f, args.min_severity, statuses)]
    if len(selected) > args.max_issues:
        print(f"Refusing to create {len(selected)} issues; exceeds --max-issues={args.max_issues}.", file=sys.stderr)
        return 4

    if args.plan:
        try:
            plan, _bodies = build_publication_plan(
                repo=repo,
                run_id=run_id,
                commit=commit,
                visibility=plan_visibility(data, context),
                findings=selected,
                run_dir=run_dir,
                generated_at=generated_at,
            )
        except ReportSafetyError as exc:
            print(f"ERROR: {exc}", file=sys.stderr)
            return 2
        plan_path = default_plan_path(run_dir)
        write_plan(plan_path, plan)
        print_plan_summary(plan_path, plan, prefix="Wrote issue publication plan")
        return 0

    selected_plan_entries: Optional[List[Dict[str, Any]]] = None
    plan_bodies: Dict[str, str] = {}
    plan_path: Optional[Path] = None
    plan_sha256: Optional[str] = None
    if args.apply_plan:
        plan_path = Path(args.apply_plan)
        if not plan_path.is_absolute():
            plan_path = (Path.cwd() / plan_path).resolve()
        try:
            plan = load_plan(plan_path)
            selected_plan_entries, plan_bodies, plan_errors = verify_plan_against_findings(
                plan=plan,
                repo=repo,
                run_id=run_id,
                commit=commit,
                current_findings=[f for f in findings if isinstance(f, dict)],
                run_dir=run_dir,
            )
        except (OSError, ValueError, json.JSONDecodeError, ReportSafetyError) as exc:
            print(f"ERROR: could not read or verify issue publication plan: {exc}", file=sys.stderr)
            return 2
        if plan_errors:
            if args.replan:
                try:
                    refreshed, _bodies = build_publication_plan(
                        repo=repo,
                        run_id=run_id,
                        commit=commit,
                        visibility=plan_visibility(data, context),
                        findings=selected,
                        run_dir=run_dir,
                        generated_at=generated_at,
                    )
                    write_plan(plan_path, refreshed)
                    print_plan_summary(plan_path, refreshed, prefix="Rewrote issue publication plan")
                except ReportSafetyError as exc:
                    print(f"ERROR: {exc}", file=sys.stderr)
                    return 2
                print("Issue publication plan changed. Review the refreshed plan before applying.", file=sys.stderr)
                return 4
            print("Issue publication plan verification failed:", file=sys.stderr)
            for error in plan_errors:
                print(f"- {error}", file=sys.stderr)
            print("Refresh the plan with --plan or --apply-plan ... --replan, review it, then apply again.", file=sys.stderr)
            return 4
        if selected_plan_entries is not None and len(selected_plan_entries) > args.max_issues:
            print(f"Refusing to create {len(selected_plan_entries)} issues; exceeds --max-issues={args.max_issues}.", file=sys.stderr)
            return 4
        plan_sha256 = plan_hash(plan_path)
        print_plan_summary(plan_path, plan, prefix="Verified issue publication plan")
        if args.dry_run:
            dry_run = True

    visibility = gh_repo_visibility(repo) if not dry_run else "NOT_CHECKED"
    if not dry_run and visibility in {"PUBLIC", "UNKNOWN", ""} and not args.allow_public:
        print(f"Refusing to create security issues for repo {repo} with visibility={visibility}. Use --allow-public only when disclosure policy permits.", file=sys.stderr)
        return 3

    if args.create_labels and not dry_run:
        create_default_labels(repo)

    result = {
        "repo": repo,
        "run_id": run_id,
        "commit": commit,
        "visibility": visibility,
        "dry_run": dry_run,
        "plan_path": str(plan_path) if plan_path else str(default_plan_path(run_dir)),
        "plan_sha256": plan_sha256,
        "created": [],
        "skipped": [],
    }

    issue_entries: List[Tuple[Dict[str, Any], str]] = []
    if selected_plan_entries is not None:
        issue_entries = [(entry, plan_bodies.get(str(entry.get("id", "")), "")) for entry in selected_plan_entries]
    else:
        try:
            preview_plan, preview_bodies = build_publication_plan(
                repo=repo,
                run_id=run_id,
                commit=commit,
                visibility=plan_visibility(data, context),
                findings=selected,
                run_dir=run_dir,
                generated_at=generated_at,
            )
        except ReportSafetyError as exc:
            print(f"ERROR: {exc}", file=sys.stderr)
            return 2
        print_plan_summary(default_plan_path(run_dir), preview_plan)
        issue_entries = [(entry, preview_bodies.get(str(entry.get("id", "")), "")) for entry in preview_plan["selected_findings"]]

    for entry, body in issue_entries:
        fingerprint = str(entry["fingerprint"])
        finding_id = str(entry.get("id", "SEC-UNKNOWN"))
        title = str(entry["title"])
        labels = list(entry.get("labels") or [])
        body_hash = str(entry.get("issue_body_sha256") or sha256_text(body))

        existing = None if dry_run else issue_exists(repo, fingerprint)
        if existing:
            result["skipped"].append({"id": finding_id, "reason": "duplicate", "url": existing, "fingerprint": fingerprint})
            print(f"SKIP duplicate {finding_id}: {existing}")
            continue

        if dry_run:
            print("---")
            print(f"DRY RUN: would create issue for {finding_id}")
            print(f"Title: {title}")
            print(f"Labels: {', '.join(labels)}")
            print(f"Fingerprint: {fingerprint}")
            print(f"Issue body SHA256: {body_hash}")
            result["created"].append({"id": finding_id, "dry_run": True, "title": title, "fingerprint": fingerprint, "issue_body_sha256": body_hash})
            continue

        with tempfile.NamedTemporaryFile("w", encoding="utf-8", suffix=".md", delete=False) as tmp:
            tmp.write(body)
            tmp_path = tmp.name
        try:
            if args.create_labels:
                for label in labels:
                    if label not in DEFAULT_LABELS:
                        ensure_label(repo, label, "ededed", "GenAI Repo Auditor label")
            cmd = ["gh", "issue", "create", "-R", repo, "--title", title, "--body-file", tmp_path]
            for label in labels:
                cmd.extend(["--label", label])
            if args.assignee:
                cmd.extend(["--assignee", args.assignee])
            cp = run(cmd, check=True)
            url = cp.stdout.strip()
            print(f"CREATED {finding_id}: {url}")
            result["created"].append({"id": finding_id, "url": url, "title": title, "fingerprint": fingerprint})
        finally:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass

    output_path = run_dir / "issues-created.json"
    output_path.write_text(json.dumps(result, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    print(f"Wrote {output_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

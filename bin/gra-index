#!/usr/bin/env python3
import argparse
import json
import sys
from pathlib import Path
from typing import Any, Dict, List

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / "lib"))
from version import auditor_version
from posture_artifacts import posture_index_summary

SEVERITIES = ["Critical", "High", "Medium", "Low", "Informational"]
STATUSES = ["Confirmed", "Probable", "Potential", "Needs human review", "Informational", "Invalid"]


def load_json(path: Path) -> Dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def main() -> int:
    parser = argparse.ArgumentParser(description="Create index of GenAI Repo Auditor runs")
    parser.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    parser.add_argument("--runs-dir", default="runs")
    args = parser.parse_args()

    runs_dir = Path(args.runs_dir).resolve()
    items: List[Dict[str, Any]] = []
    for findings_path in runs_dir.glob("*/*/reports/findings.json"):
        run_dir = findings_path.parent.parent
        data = load_json(findings_path)
        findings = data.get("findings") or []
        counts = {sev: 0 for sev in SEVERITIES}
        statuses = {st: 0 for st in STATUSES}
        for f in findings:
            if not isinstance(f, dict):
                continue
            sev = f.get("severity")
            st = f.get("status")
            if sev in counts:
                counts[sev] += 1
            if st in statuses:
                statuses[st] += 1
        posture = posture_index_summary(run_dir)
        items.append({
            "run_dir": str(run_dir),
            "repo": data.get("repo"),
            "run_id": data.get("run_id") or run_dir.name,
            "commit": data.get("commit"),
            "generated_at": data.get("generated_at"),
            "finding_count": len(findings),
            "severity_counts": counts,
            "status_counts": statuses,
            "posture": posture,
            "posture_artifact_count": posture["posture_artifact_count"],
            "agent_surface_count": posture["agent_surface_count"],
            "scorecard_check_count": posture["scorecard_check_count"],
            "provenance_workflow_count": posture["provenance_workflow_count"],
            "dependency_component_count": posture["dependency_component_count"],
            "dependency_vulnerability_count": posture["dependency_vulnerability_count"],
        })

    items.sort(key=lambda x: (str(x.get("repo")), str(x.get("run_id"))))
    out_json = runs_dir / "index.json"
    out_json.write_text(json.dumps({"runs": items}, indent=2) + "\n", encoding="utf-8")

    lines = [
        "# GenAI Repo Auditor Run Index",
        "",
        (
            "| Repo | Run ID | Findings | Critical | High | Medium | "
            "Posture artifacts | Agent surfaces | Scorecard checks | Provenance workflows | Components | Vulnerabilities | Run dir |"
        ),
        "|---|---|---:|---:|---:|---:|---:|---:|---:|---:|---:|---:|---|",
    ]
    for item in items:
        c = item["severity_counts"]
        posture = item["posture"]
        lines.append(
            f"| {item.get('repo') or ''} | {item.get('run_id') or ''} | {item.get('finding_count', 0)} | "
            f"{c.get('Critical', 0)} | {c.get('High', 0)} | {c.get('Medium', 0)} | "
            f"{posture.get('posture_artifact_count', 0)} | {posture.get('agent_surface_count', 0)} | "
            f"{posture.get('scorecard_check_count', 0)} | {posture.get('provenance_workflow_count', 0)} | "
            f"{posture.get('dependency_component_count', 0)} | {posture.get('dependency_vulnerability_count', 0)} | "
            f"`{item.get('run_dir')}` |"
        )
    out_md = runs_dir / "index.md"
    out_md.write_text("\n".join(lines) + "\n", encoding="utf-8")

    print(f"Wrote {out_json}")
    print(f"Wrote {out_md}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import shutil
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import load_context, load_json, utc_now, write_json
from dependency_posture import append_dependency_posture_targets, should_ingest_dependencies, write_dependency_artifacts
from scanner_normalize import normalize_scanner_file
from scorecard_posture import append_scorecard_posture_targets, write_scorecard_posture_artifacts


def main() -> int:
    p = argparse.ArgumentParser(description='Ingest scanner output into a GenAI Repo Auditor run')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--tool', required=True, help='Scanner/tool name, e.g. semgrep, gitleaks, trivy, codeql, checkov')
    p.add_argument('--file', required=True, help='Scanner result file to copy into the run')
    p.add_argument('--format', default='auto', help='Result format, e.g. json, sarif, text. Default: infer from extension')
    p.add_argument('--note', default='', help='Optional note')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    ctx = load_context(run_dir)
    src = Path(args.file).resolve()
    if not src.exists():
        print(f'file not found: {src}', file=sys.stderr)
        return 2

    fmt = args.format
    if fmt == 'auto':
        suffix = src.suffix.lower().lstrip('.')
        fmt = suffix or 'unknown'
    reports = run_dir / ctx.get('reports_dir', 'reports')
    dest_dir = reports / 'scanner-results'
    dest_dir.mkdir(parents=True, exist_ok=True)
    digest = hashlib.sha256(src.read_bytes()).hexdigest()[:12]
    safe_tool = ''.join(ch if ch.isalnum() or ch in '-_' else '-' for ch in args.tool.lower())
    dest = dest_dir / f'{safe_tool}-{digest}.{fmt}'
    shutil.copy2(src, dest)
    raw_result_ref = str(dest.relative_to(run_dir))

    normalized_dir = dest_dir / 'normalized'
    normalized_dir.mkdir(parents=True, exist_ok=True)
    normalized = normalize_scanner_file(tool=args.tool, raw_path=dest, raw_result_ref=raw_result_ref)
    normalized_path = normalized_dir / f'{safe_tool}-{digest}-leads.json'
    write_json(normalized_path, normalized)

    index_path = dest_dir / 'scanner-index.json'
    data = load_json(index_path, None)
    if not data:
        data = {
            'run_id': ctx.get('run_id', run_dir.name),
            'repo': ctx.get('repo', ''),
            'generated_at': utc_now(),
            'results': [],
        }
    entry = {
        'tool': args.tool,
        'path': raw_result_ref,
        'format': fmt,
        'imported_at': utc_now(),
        'sha256': digest,
        'raw_bytes': normalized.get('raw_bytes', 0),
        'normalized_path': str(normalized_path.relative_to(run_dir)),
        'normalized_leads_count': len(normalized.get('leads') or []),
        'normalization': normalized.get('normalization') or {},
        'note': args.note,
    }
    data.setdefault('results', []).append(entry)
    write_json(index_path, data)
    added_scorecard_targets = []
    if safe_tool in {'scorecard', 'openssf-scorecard', 'ossf-scorecard'}:
        write_scorecard_posture_artifacts(run_dir=run_dir, raw_path=dest, raw_result_ref=raw_result_ref)
        added_scorecard_targets = append_scorecard_posture_targets(run_dir)
    dependency_data = None
    if should_ingest_dependencies(safe_tool=safe_tool, fmt=fmt):
        dependency_data = write_dependency_artifacts(
            run_dir=run_dir,
            raw_path=dest,
            raw_result_ref=raw_result_ref,
            tool=args.tool,
            requested_format=fmt,
        )
    print(f'Ingested {src} -> {dest}')
    print(f'Normalized leads -> {normalized_path}')
    if safe_tool in {'scorecard', 'openssf-scorecard', 'ossf-scorecard'}:
        print(f'Wrote {reports / "supply-chain-posture.json"}')
        print(f'Wrote {reports / "supply-chain-posture.md"}')
        if added_scorecard_targets:
            print(f'Added {len(added_scorecard_targets)} scorecard-posture target(s)')
    if dependency_data is not None:
        print(f'Wrote {reports / "dependencies.json"}')
        print(f'Wrote {reports / "DEPENDENCY_RISK.md"}')
        added_dependency_targets = append_dependency_posture_targets(run_dir)
        if added_dependency_targets:
            print(f'Added {len(added_dependency_targets)} dependency-posture target(s)')
    print(f'Updated {index_path}')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())

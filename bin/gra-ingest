#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from scanner_ingest import build_scanner_ingest_plan, ingest_scanner_file, safe_tool_name
from run_events import EventWriteError, append_command_event, preflight_command_event, start_command_event


def main() -> int:
    p = argparse.ArgumentParser(description='Ingest scanner output into a GenAI Repo Auditor run')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--tool', required=True, help='Scanner/tool name, e.g. semgrep, gitleaks, trivy, codeql, checkov')
    p.add_argument('--file', required=True, help='Scanner result file to copy into the run')
    p.add_argument('--format', default='auto', help='Result format, e.g. json, sarif, text. Default: infer from extension')
    p.add_argument('--note', default='', help='Optional note')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    safe_tool = safe_tool_name(args.tool)
    event_subject_id = safe_tool[:128]
    if not event_subject_id:
        event_subject_id = 'unknown-tool'
    elif not (event_subject_id[0].isalnum() or event_subject_id[0] == '_'):
        event_subject_id = f'tool-{hashlib.sha256(args.tool.encode("utf-8", errors="replace")).hexdigest()[:12]}'
    input_artifacts = [run_dir / 'context.json']
    output_artifacts: list[Path] = []

    def finish(exit_code: int, *, error_category: str | None = None) -> int:
        append_command_event(
            run_dir,
            command='gra-ingest',
            phase='ingest',
            subject_id=event_subject_id,
            started_at=started_at,
            started_perf=started_perf,
            exit_code=exit_code,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            error_category=error_category,
            failure_mode='warn' if exit_code != 0 else 'block',
        )
        return exit_code

    src = Path(args.file).resolve()
    if not src.exists():
        print(f'file not found: {src}', file=sys.stderr)
        return finish(2, error_category='input_validation')
    try:
        plan = build_scanner_ingest_plan(
            run_dir,
            tool=args.tool,
            source=src,
            requested_format=args.format,
        )
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=plan.output_paths,
        )
    except (EventWriteError, OSError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    result = ingest_scanner_file(plan, note=args.note)
    output_artifacts.extend(result.output_paths)
    reports = plan.index_path.parent.parent
    print(f'Ingested {src} -> {plan.destination}')
    print(f'Normalized leads -> {plan.normalized_path}')
    if result.added_scorecard_targets:
        print(f'Added {len(result.added_scorecard_targets)} scorecard-posture target(s)')
    if result.added_dependency_targets:
        print(f'Added {len(result.added_dependency_targets)} dependency-posture target(s)')
    if safe_tool in {'scorecard', 'openssf-scorecard', 'ossf-scorecard'}:
        print(f'Wrote {reports / "supply-chain-posture.json"}')
        print(f'Wrote {reports / "supply-chain-posture.md"}')
    if (reports / 'dependencies.json') in result.output_paths:
        print(f'Wrote {reports / "dependencies.json"}')
        print(f'Wrote {reports / "DEPENDENCY_RISK.md"}')
    print(f'Updated {plan.index_path}')
    return finish(0)


if __name__ == '__main__':
    raise SystemExit(main())

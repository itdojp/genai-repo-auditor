#!/usr/bin/env python3
from __future__ import annotations

import argparse
import html
import json
import sys
from collections import Counter
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import load_context, load_json, utc_now
from run_events import (
    EventWriteError,
    append_command_event,
    local_artifact_paths,
    preflight_command_event,
    reports_dir,
    start_command_event,
)

SEVERITIES = ['Critical', 'High', 'Medium', 'Low', 'Informational']
STATUSES = ['Confirmed', 'Probable', 'Potential', 'Needs human review', 'Informational', 'Invalid']
ASSESSMENT_FIELDS = [
    ('bug_existence', 'Bug existence'),
    ('attacker_reachability', 'Attacker reachability'),
    ('boundary_crossing', 'Boundary crossing'),
    ('impact_assessment', 'Impact assessment'),
]
_failure_event: tuple[Path, str, float, list[Path], list[Path]] | None = None


def h(x) -> str:
    return html.escape('' if x is None else str(x))


def main() -> int:
    global _failure_event
    _failure_event = None
    p = argparse.ArgumentParser(description='Generate a local HTML dashboard for a GenAI Repo Auditor run')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--out', help='Output HTML file. Default: reports/dashboard.html')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    ctx = load_context(run_dir)
    try:
        reports = reports_dir(run_dir)
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    out = Path(args.out).resolve() if args.out else reports / 'dashboard.html'
    input_artifacts = [run_dir / 'context.json', reports]
    output_artifacts = local_artifact_paths(run_dir, [out])
    try:
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            event_fields={
                'command': 'gra-dashboard',
                'phase': 'dashboard',
                'started_at': started_at,
                'started_perf': started_perf,
                'exit_code': 0,
            },
            reserve_file=False,
        )
    except EventWriteError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    _failure_event = (run_dir, started_at, started_perf, input_artifacts, output_artifacts)
    findings_data = load_json(reports / 'findings.json', {}) or {}
    findings = [f for f in findings_data.get('findings', []) if isinstance(f, dict)]
    targets_data = load_json(reports / 'targets.json', {}) or {}
    targets = [t for t in targets_data.get('targets', []) if isinstance(t, dict)]
    scanner_index = load_json(reports / 'scanner-results' / 'scanner-index.json', {}) or {}
    scanner_results = scanner_index.get('results') or []
    supply_chain_posture = load_json(reports / 'supply-chain-posture.json', {}) or {}
    supply_chain_checks = [c for c in supply_chain_posture.get('checks') or [] if isinstance(c, dict)]
    dependencies_data = load_json(reports / 'dependencies.json', {}) or {}
    dependency_components = [c for c in dependencies_data.get('components') or [] if isinstance(c, dict)]
    dependency_vulnerabilities = [v for v in dependencies_data.get('vulnerabilities') or [] if isinstance(v, dict)]
    metrics_data = load_json(reports / 'metrics.json', {}) or {}
    metrics_present = isinstance(metrics_data, dict) and bool(metrics_data)
    benchmark_data = load_json(reports / 'benchmark.json', {}) or {}
    benchmark_present = isinstance(benchmark_data, dict) and bool(benchmark_data)
    evidence_graph_data = load_json(reports / 'evidence-graph.json', {}) or {}
    evidence_graph_present = isinstance(evidence_graph_data, dict) and bool(evidence_graph_data)
    gapfill_data = load_json(reports / 'gapfill-targets.json', {}) or {}
    gapfill_present = isinstance(gapfill_data, dict) and bool(gapfill_data)
    remediation_data = load_json(reports / 'remediation' / 'remediation-candidates.json', {}) or {}
    remediation_present = isinstance(remediation_data, dict) and bool(remediation_data)
    imported_findings_data = load_json(reports / 'imported-findings.json', {}) or {}
    imported_findings_present = isinstance(imported_findings_data, dict) and bool(imported_findings_data)
    novelty_data = load_json(reports / 'known-findings.json', {}) or {}
    novelty_present = isinstance(novelty_data, dict) and bool(novelty_data)

    sev_counts = Counter(f.get('severity', 'Unknown') for f in findings)
    status_counts = Counter(f.get('status', 'Unknown') for f in findings)
    assessment_counts = {
        field: Counter(f.get(field, 'Not assessed') for f in findings)
        for field, _label in ASSESSMENT_FIELDS
    }
    target_status_counts = Counter(t.get('status', 'unknown') for t in targets)
    supply_chain_risk_counts = Counter(c.get('risk', 'informational') for c in supply_chain_checks)
    dependency_scope_counts = Counter(c.get('scope', 'unknown') for c in dependency_components)
    dependency_vuln_severity_counts = Counter(v.get('severity', 'Unknown') for v in dependency_vulnerabilities)
    taxonomy_counts = Counter()
    for item in findings + targets:
        for ref in item.get('taxonomies') or []:
            if isinstance(ref, dict):
                taxonomy_counts[f"{ref.get('name', 'Unknown')}::{ref.get('id', 'UNKNOWN')}"] += 1

    rows = []
    for f in findings:
        locs = f.get('affected_locations') or []
        loc_text = ', '.join(f"{loc.get('file','')}:{loc.get('line','')}" for loc in locs if isinstance(loc, dict))
        assessment_cells = ''.join(f"<td>{h(f.get(field, 'Not assessed'))}</td>" for field, _label in ASSESSMENT_FIELDS)
        rows.append(
            f"<tr><td>{h(f.get('id'))}</td><td>{h(f.get('severity'))}</td><td>{h(f.get('confidence'))}</td>"
            f"<td>{h(f.get('status'))}</td>{assessment_cells}<td>{h(f.get('category'))}</td>"
            f"<td>{h(f.get('title'))}</td><td>{h(loc_text)}</td></tr>"
        )

    target_rows = []
    for t in sorted(targets, key=lambda x: (-int(x.get('priority') or 0), str(x.get('id')))):
        target_rows.append(f"<tr><td>{h(t.get('id'))}</td><td>{h(t.get('risk'))}</td><td>{h(t.get('priority'))}</td><td>{h(t.get('status'))}</td><td>{h(t.get('category'))}</td><td>{h(t.get('title'))}</td></tr>")

    gapfill_section = (
        "<h2>Gapfill current and cumulative queue</h2>"
        "<p>No gapfill artifact found. Run <code>gra-gapfill --run RUN_DIR --generate</code> "
        "to produce <code>gapfill-targets.json</code>.</p>"
    )
    if gapfill_present:
        current_run = gapfill_data.get('current_run') if isinstance(gapfill_data.get('current_run'), dict) else {}
        cumulative = gapfill_data.get('cumulative') if isinstance(gapfill_data.get('cumulative'), dict) else {}
        gapfill_cards = [
            ('Current candidates', current_run.get('candidate_count', gapfill_data.get('candidate_count', 0))),
            ('Current generated/reused', current_run.get('generated_target_count', gapfill_data.get('generated_target_count', 0))),
            ('Current new targets', current_run.get('new_target_count', 0)),
            ('Current reused targets', current_run.get('reused_target_count', 0)),
            ('Cumulative generated', cumulative.get('generated_target_count', 0)),
            ('Cumulative reviewed', cumulative.get('reviewed_target_count', 0)),
        ]
        candidate_rows = []
        for item in gapfill_data.get('candidates') or []:
            if isinstance(item, dict):
                candidate_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('source_target_id'))}</td>"
                    f"<td>{h(item.get('gapfill_target_id'))}</td>"
                    f"<td>{h(item.get('gapfill_target_status'))}</td>"
                    f"<td>{h(item.get('priority'))}</td>"
                    f"<td>{h(item.get('relationship'))}</td>"
                    f"<td>{h(item.get('gapfill_reason'))}</td>"
                    "</tr>"
                )
        next_rows = []
        for item in gapfill_data.get('next_targets') or []:
            if isinstance(item, dict):
                next_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('priority'))}</td>"
                    f"<td>{h(item.get('target_id'))}</td>"
                    f"<td>{h(item.get('source_target_id'))}</td>"
                    f"<td>{h(item.get('status'))}</td>"
                    f"<td>{h(item.get('relationship'))}</td>"
                    f"<td>{h(item.get('gapfill_reason'))}</td>"
                    "</tr>"
                )
        candidate_body = ''.join(candidate_rows) or '<tr><td colspan="6">No current gapfill candidates.</td></tr>'
        next_body = ''.join(next_rows) or '<tr><td colspan="6">No queued gapfill targets.</td></tr>'
        gapfill_section = (
            "<h2>Gapfill current and cumulative queue</h2>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in gapfill_cards)
            + "</div>"
            "<h3>Current source-to-gapfill relationships</h3>"
            "<table><thead><tr><th>Source target</th><th>Gapfill target</th><th>Gapfill status</th><th>Priority</th><th>Relationship</th><th>Reason</th></tr></thead>"
            f"<tbody>{candidate_body}</tbody></table>"
            "<h3>Next gapfill targets</h3>"
            "<table><thead><tr><th>Priority</th><th>Gapfill target</th><th>Source target</th><th>Status</th><th>Relationship</th><th>Reason</th></tr></thead>"
            f"<tbody>{next_body}</tbody></table>"
        )

    remediation_section = (
        "<h2>Remediation candidates</h2>"
        "<p>No remediation candidate artifact found. Run "
        "<code>gra-remediate --run RUN_DIR --finding SEC-001 --mode goal</code> "
        "to prepare draft-only candidate patches for human review.</p>"
    )
    if remediation_present:
        candidate_rows = []
        for item in remediation_data.get('candidates') or []:
            if isinstance(item, dict):
                candidate_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('id'))}</td>"
                    f"<td>{h(item.get('finding_id'))}</td>"
                    f"<td>{h(item.get('status'))}</td>"
                    f"<td>{h(item.get('requires_human_review'))}</td>"
                    f"<td>{h(item.get('patch_file'))}</td>"
                    f"<td>{h(item.get('summary'))}</td>"
                    "</tr>"
                )
        candidate_body = ''.join(candidate_rows) or '<tr><td colspan="6">No remediation candidates.</td></tr>'
        remediation_section = (
            "<h2>Remediation candidates</h2>"
            "<p>Draft-only local remediation artifacts. Full diffs stay under "
            "<code>reports/remediation/</code>; review "
            "<a href='remediation/REMEDIATION_CANDIDATES.md'>REMEDIATION_CANDIDATES.md</a> locally before applying anything.</p>"
            "<table><thead><tr><th>ID</th><th>Finding</th><th>Status</th><th>Human review</th><th>Patch file</th><th>Summary</th></tr></thead>"
            f"<tbody>{candidate_body}</tbody></table>"
        )

    imported_findings_section = (
        "<h2>External finding imports</h2>"
        "<p>No imported finding artifact found. Run "
        "<code>gra-import-findings --run RUN_DIR --file external-findings.json</code> "
        "to normalize vendor-neutral external findings into review-only local artifacts.</p>"
    )
    if imported_findings_present:
        import_summary = imported_findings_data.get('summary') if isinstance(imported_findings_data.get('summary'), dict) else {}
        import_cards = [
            ('Source', imported_findings_data.get('source', '')),
            ('Valid findings', import_summary.get('valid_count', 0)),
            ('Rejected leads', import_summary.get('rejected_count', 0)),
            ('Appended', import_summary.get('appended_count', 0)),
            ('Duplicate skipped', import_summary.get('duplicate_skipped_count', 0)),
        ]
        import_rows = []
        for item in imported_findings_data.get('findings') or []:
            if isinstance(item, dict):
                import_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('import_id'))}</td>"
                    f"<td>{h(item.get('external_id'))}</td>"
                    f"<td>{h(item.get('severity'))}</td>"
                    f"<td>{h(item.get('confidence'))}</td>"
                    f"<td>{h(item.get('status'))}</td>"
                    f"<td>{h(item.get('append_status'))}</td>"
                    f"<td>{h(item.get('title'))}</td>"
                    "</tr>"
                )
        rejected_rows = []
        for item in imported_findings_data.get('rejected_findings') or []:
            if isinstance(item, dict):
                rejected_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('index'))}</td>"
                    f"<td>{h(item.get('external_id'))}</td>"
                    f"<td>{h(item.get('title'))}</td>"
                    f"<td>{h('; '.join(str(reason) for reason in item.get('reasons') or []))}</td>"
                    "</tr>"
                )
        import_body = ''.join(import_rows) or '<tr><td colspan="7">No normalized imported findings.</td></tr>'
        rejected_body = ''.join(rejected_rows) or '<tr><td colspan="4">No rejected imported leads.</td></tr>'
        imported_findings_section = (
            "<h2>External finding imports</h2>"
            "<p>Vendor-neutral local import artifact. Imported findings are review-only by default and appended findings "
            "use <code>issue_recommended=false</code> until explicitly reviewed. "
            "<a href='imported-findings.json'>imported-findings.json</a> / <a href='IMPORTED_FINDINGS.md'>IMPORTED_FINDINGS.md</a></p>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in import_cards)
            + "</div>"
            "<h3>Normalized imports</h3>"
            "<table><thead><tr><th>Import ID</th><th>External ID</th><th>Severity</th><th>Confidence</th><th>Status</th><th>Append status</th><th>Title</th></tr></thead>"
            f"<tbody>{import_body}</tbody></table>"
            "<h3>Rejected leads</h3>"
            "<table><thead><tr><th>Index</th><th>External ID</th><th>Title</th><th>Reasons</th></tr></thead>"
            f"<tbody>{rejected_body}</tbody></table>"
        )

    novelty_section = (
        "<h2>Known findings / novelty</h2>"
        "<p>No novelty ledger found. Run <code>gra-novelty --run RUN_DIR</code> "
        "to classify current findings as new, duplicate, better-example, accepted-risk, regression, invalid-known, or needs-human-review.</p>"
    )
    if novelty_present:
        novelty_summary = novelty_data.get('summary') if isinstance(novelty_data.get('summary'), dict) else {}
        novelty_counts = novelty_summary.get('status_counts') if isinstance(novelty_summary.get('status_counts'), dict) else {}
        novelty_cards = [
            ('Findings classified', novelty_summary.get('finding_count', 0)),
            ('Suppressed by default', novelty_summary.get('suppressed_publication_count', 0)),
            ('New', novelty_counts.get('new', 0)),
            ('Duplicate', novelty_counts.get('duplicate', 0)),
            ('Better examples', novelty_counts.get('better-example', 0)),
            ('Accepted risks', novelty_counts.get('accepted-risk', 0)),
            ('Regressions', novelty_counts.get('regression', 0)),
        ]
        novelty_rows = []
        for item in novelty_data.get('findings') or []:
            if isinstance(item, dict):
                match = item.get('match') if isinstance(item.get('match'), dict) else {}
                novelty_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('finding_id'))}</td>"
                    f"<td>{h(item.get('novelty_status'))}</td>"
                    f"<td>{h(item.get('issue_recommended'))}</td>"
                    f"<td>{h(', '.join(str(reason) for reason in match.get('reasons') or []))}</td>"
                    "</tr>"
                )
        novelty_body = ''.join(novelty_rows) or '<tr><td colspan="4">No novelty records.</td></tr>'
        novelty_section = (
            "<h2>Known findings / novelty</h2>"
            "<p>Local-only novelty ledger. It stores hashes and fingerprints, not raw evidence or issue bodies. "
            "<a href='known-findings.json'>known-findings.json</a> / <a href='NOVELTY.md'>NOVELTY.md</a></p>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in novelty_cards)
            + "</div>"
            "<table><thead><tr><th>Finding</th><th>Novelty</th><th>Issue recommended</th><th>Match reasons</th></tr></thead>"
            f"<tbody>{novelty_body}</tbody></table>"
        )

    scanner_rows = []
    for r in scanner_results:
        if isinstance(r, dict):
            scanner_rows.append(f"<tr><td>{h(r.get('tool'))}</td><td>{h(r.get('format'))}</td><td>{h(r.get('path'))}</td><td>{h(r.get('imported_at'))}</td><td>{h(r.get('note'))}</td></tr>")

    supply_chain_rows = []
    for c in sorted(supply_chain_checks, key=lambda item: (str(item.get('risk')), str(item.get('name')))):
        supply_chain_rows.append(
            "<tr>"
            f"<td>{h(c.get('name'))}</td>"
            f"<td>{h(c.get('score_display') or c.get('score'))}</td>"
            f"<td>{h(c.get('scorecard_risk'))}</td>"
            f"<td>{h(c.get('risk'))}</td>"
            f"<td>{h(c.get('reason'))}</td>"
            f"<td>{h(c.get('remediation'))}</td>"
            f"<td>{h(c.get('target_recommended'))}</td>"
            "</tr>"
        )

    dependency_vuln_rows = []
    severity_order = {'Critical': 0, 'High': 1, 'Medium': 2, 'Low': 3, 'Informational': 4, 'Unknown': 5}
    for v in sorted(dependency_vulnerabilities, key=lambda item: (severity_order.get(str(item.get('severity')), 9), str(item.get('id')), str(item.get('component'))))[:20]:
        paths = v.get('dependency_paths') or []
        path_text = '; '.join(' -> '.join(str(part) for part in path) for path in paths if isinstance(path, list))
        dependency_vuln_rows.append(
            "<tr>"
            f"<td>{h(v.get('id'))}</td>"
            f"<td>{h(v.get('severity'))}</td>"
            f"<td>{h(v.get('component'))}</td>"
            f"<td>{h(v.get('fixed_version') or 'not provided')}</td>"
            f"<td>{h(v.get('source'))}</td>"
            f"<td>{h(path_text or 'not provided')}</td>"
            "</tr>"
        )

    taxonomy_rows = []
    for key, count in sorted(taxonomy_counts.items()):
        name, _, identifier = key.partition('::')
        taxonomy_rows.append(f"<tr><td>{h(name)}</td><td>{h(identifier)}</td><td>{count}</td></tr>")

    if metrics_present:
        observability = metrics_data.get('observability') if isinstance(metrics_data.get('observability'), dict) else {}
        artifacts_metrics = metrics_data.get('artifacts') if isinstance(metrics_data.get('artifacts'), dict) else {}
        scanner_readiness = metrics_data.get('scanner_readiness') if isinstance(metrics_data.get('scanner_readiness'), dict) else {}
        workflow_execution = metrics_data.get('workflow_execution') if isinstance(metrics_data.get('workflow_execution'), dict) else {}
        metric_cards = [
            ('Findings', metrics_data.get('findings', {}).get('total', 0)),
            ('Validations', metrics_data.get('adversarial_validation', {}).get('total', 0)),
            ('Downgrade/invalidate rate', metrics_data.get('adversarial_validation', {}).get('downgrade_or_invalidate_rate', 0)),
            ('Chains', metrics_data.get('chains', {}).get('total', 0)),
            ('Proofs', metrics_data.get('proofs', {}).get('total', 0)),
            ('Gapfill targets', metrics_data.get('gapfill', {}).get('targets_generated', 0)),
            ('Traces', metrics_data.get('traces', {}).get('total', 0)),
            ('Issue plan warnings', metrics_data.get('issue_publication_plan', {}).get('warning_count', 0)),
            ('Duplicate decisions', metrics_data.get('duplicate_decisions', {}).get('total', 0)),
            ('Exact duplicate matches', metrics_data.get('duplicate_decisions', {}).get('exact_match_count', 0)),
            ('Command events', observability.get('total_events', 0)),
            ('Command failures', observability.get('failure_count', 0)),
            ('Explicit retries', observability.get('retry_count', 0)),
            ('Produced artifact refs', (observability.get('artifact_production') or {}).get('output_ref_count', 0)),
            ('Producer coverage %', (observability.get('producer_coverage') or {}).get('coverage_percent', 0)),
            ('Validation retries', observability.get('validation_retry_count', 0)),
            ('Taxonomy normalizations', observability.get('taxonomy_normalization_count', 0)),
            ('Scanner readiness reports', scanner_readiness.get('report_count', 0)),
            ('Provider failures observed', workflow_execution.get('provider_failure_count', 0)),
            ('Active provider failures', workflow_execution.get('active_provider_failure_count', 0)),
            ('Recovered provider-failure stages', workflow_execution.get('recovered_provider_failure_count', 0)),
            ('Retryable provider failures', workflow_execution.get('retryable_provider_failure_count', 0)),
            ('Provider resume recommendations', workflow_execution.get('resume_recommended_count', 0)),
            ('Latest status artifacts', artifacts_metrics.get('latest_status_artifact_count', 0)),
            ('Archive artifacts', artifacts_metrics.get('archive_artifact_count', 0)),
            ('Manifest hygiene warnings', artifacts_metrics.get('manifest_hygiene_warnings', 0)),
        ]
        duration_rows = []
        for event in (observability.get('slow_subjects') or observability.get('execution_durations') or [])[:10]:
            if isinstance(event, dict):
                duration_rows.append(
                    "<tr>"
                    f"<td>{h(event.get('subject_id') or event.get('target_id'))}</td>"
                    f"<td>{h(event.get('command'))}</td>"
                    f"<td>{h(event.get('phase'))}</td>"
                    f"<td>{h(event.get('status'))}</td>"
                    f"<td>{h(event.get('duration_ms'))}</td>"
                    f"<td>{h(event.get('exit_code'))}</td>"
                    "</tr>"
                )

        def metric_count_rows(values) -> str:
            if not isinstance(values, dict):
                return ""
            rows = []
            def sort_key(item):
                try:
                    count = int(item[1] or 0)
                except (TypeError, ValueError):
                    count = 0
                return (-count, str(item[0]))
            for key, value in sorted(values.items(), key=sort_key):
                rows.append(f"<tr><td>{h(key)}</td><td>{h(value)}</td></tr>")
            return ''.join(rows)

        duration_body = ''.join(duration_rows) or '<tr><td colspan="6">No command events.</td></tr>'
        retry_rows = metric_count_rows(observability.get('validation_retries_by_target'))
        retry_body = retry_rows or '<tr><td colspan="2">No validation retries.</td></tr>'
        rerun_rows = metric_count_rows(observability.get('reruns_by_target'))
        rerun_body = rerun_rows or '<tr><td colspan="2">No command reruns.</td></tr>'
        failure_rows = metric_count_rows(observability.get('failures_by_target'))
        failure_body = failure_rows or '<tr><td colspan="2">No command failures.</td></tr>'
        worker_rows = metric_count_rows((observability.get('configuration') or {}).get('by_worker_profile'))
        worker_body = worker_rows or '<tr><td colspan="2">No worker profile metadata.</td></tr>'
        sandbox_rows = metric_count_rows((observability.get('configuration') or {}).get('by_sandbox_profile'))
        sandbox_body = sandbox_rows or '<tr><td colspan="2">No sandbox profile metadata.</td></tr>'
        scanner_phase_rows = metric_count_rows((observability.get('stage_groups') or {}).get('scanner_phases'))
        scanner_phase_body = scanner_phase_rows or '<tr><td colspan="2">No scanner phases observed.</td></tr>'
        scanner_readiness_state_rows = metric_count_rows(scanner_readiness.get('by_state'))
        scanner_readiness_state_body = scanner_readiness_state_rows or '<tr><td colspan="2">No scanner readiness reports.</td></tr>'
        scanner_readiness_reason_rows = metric_count_rows(scanner_readiness.get('by_reason'))
        scanner_readiness_reason_body = scanner_readiness_reason_rows or '<tr><td colspan="2">No scanner readiness reasons.</td></tr>'
        provider_failure_rows = metric_count_rows(workflow_execution.get('provider_failures_by_class'))
        provider_failure_body = provider_failure_rows or '<tr><td colspan="2">No classified provider failures.</td></tr>'
        remediation_phase_rows = metric_count_rows((observability.get('stage_groups') or {}).get('remediation_phases'))
        remediation_phase_body = remediation_phase_rows or '<tr><td colspan="2">No remediation phases observed.</td></tr>'
        issue_phase_rows = metric_count_rows((observability.get('stage_groups') or {}).get('issue_publication_phases'))
        issue_phase_body = issue_phase_rows or '<tr><td colspan="2">No Issue publication phases observed.</td></tr>'
        normalization_rows = metric_count_rows(observability.get('taxonomy_normalizations_by_target'))
        normalization_body = normalization_rows or '<tr><td colspan="2">No taxonomy normalizations.</td></tr>'
        retention_rows = metric_count_rows(artifacts_metrics.get('manifest_by_retention'))
        retention_body = retention_rows or '<tr><td colspan="2">No manifest retention data.</td></tr>'
        metrics_section = (
            "<h2>Advanced workflow metrics</h2>"
            "<p>Local-only counts generated by <code>gra-metrics</code>. "
            "<a href='metrics.json'>metrics.json</a> / <a href='METRICS.md'>METRICS.md</a></p>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in metric_cards)
            + "</div>"
            "<h3>Slow command subjects</h3>"
            "<table><thead><tr><th>Subject</th><th>Command</th><th>Phase</th><th>Status</th><th>Duration ms</th><th>Exit code</th></tr></thead>"
            f"<tbody>{duration_body}</tbody></table>"
            "<h3>High retry / rerun targets</h3>"
            "<table><thead><tr><th>Target</th><th>Validation retries</th></tr></thead>"
            f"<tbody>{retry_body}</tbody></table>"
            "<table><thead><tr><th>Target</th><th>Command reruns</th></tr></thead>"
            f"<tbody>{rerun_body}</tbody></table>"
            "<h3>Failures and normalizations by target</h3>"
            "<table><thead><tr><th>Target</th><th>Failures</th></tr></thead>"
            f"<tbody>{failure_body}</tbody></table>"
            "<table><thead><tr><th>Target</th><th>Taxonomy normalizations</th></tr></thead>"
            f"<tbody>{normalization_body}</tbody></table>"
            "<h3>Execution configuration</h3>"
            "<table><thead><tr><th>Worker profile</th><th>Events</th></tr></thead>"
            f"<tbody>{worker_body}</tbody></table>"
            "<table><thead><tr><th>Sandbox profile</th><th>Events</th></tr></thead>"
            f"<tbody>{sandbox_body}</tbody></table>"
            "<h3>Workflow stage groups</h3>"
            "<table><thead><tr><th>Scanner phase</th><th>Events</th></tr></thead>"
            f"<tbody>{scanner_phase_body}</tbody></table>"
            "<h3>Scanner execution readiness</h3>"
            "<p>Bounded state and reason-code counts only; local paths, environment values, and runtime output are excluded.</p>"
            "<table><thead><tr><th>State</th><th>Reports</th></tr></thead>"
            f"<tbody>{scanner_readiness_state_body}</tbody></table>"
            "<table><thead><tr><th>Reason code</th><th>Reports</th></tr></thead>"
            f"<tbody>{scanner_readiness_reason_body}</tbody></table>"
            "<h3>Provider failure guidance</h3>"
            "<p>Provider-neutral bounded counts only. Raw provider responses, stderr, prompts, headers, tokens, account/request IDs, and retry guarantees are excluded.</p>"
            "<table><thead><tr><th>Provider failure class</th><th>Failures observed</th></tr></thead>"
            f"<tbody>{provider_failure_body}</tbody></table>"
            "<table><thead><tr><th>Remediation phase</th><th>Events</th></tr></thead>"
            f"<tbody>{remediation_phase_body}</tbody></table>"
            "<table><thead><tr><th>Issue publication phase</th><th>Events</th></tr></thead>"
            f"<tbody>{issue_phase_body}</tbody></table>"
            "<h3>Artifact retention</h3>"
            "<p>Latest status artifacts are the canonical handoff set; archive artifacts are retained for reproducibility but excluded from active validation targets.</p>"
            "<table><thead><tr><th>Retention</th><th>Artifacts</th></tr></thead>"
            f"<tbody>{retention_body}</tbody></table>"
        )
    else:
        metrics_section = (
            "<h2>Advanced workflow metrics</h2>"
            "<p>No metrics report found. Run <code>gra-metrics --run RUN_DIR</code> "
            "to generate local-only counts for advanced workflow artifacts.</p>"
        )

    benchmark_section = (
        "<h2>Dogfood benchmark</h2>"
        "<p>No benchmark report found. Run <code>gra-benchmark --run RUN_DIR</code> "
        "to score local v0.4 workflow quality gates.</p>"
    )
    if benchmark_present:
        benchmark_summary = benchmark_data.get('summary') if isinstance(benchmark_data.get('summary'), dict) else {}
        benchmark_metrics = benchmark_data.get('metrics') if isinstance(benchmark_data.get('metrics'), dict) else {}
        benchmark_metric_summary = benchmark_metrics.get('summary') if isinstance(benchmark_metrics.get('summary'), dict) else {}
        benchmark_cards = [
            ('Overall status', benchmark_summary.get('overall_status', '')),
            ('Passed gates', benchmark_summary.get('passed', 0)),
            ('Warnings', benchmark_summary.get('warnings', 0)),
            ('Failed gates', benchmark_summary.get('failed', 0)),
            ('Metric source', benchmark_metrics.get('source', '')),
            ('Chains', benchmark_metric_summary.get('chain_count', 0)),
            ('Issue plan warnings', benchmark_metric_summary.get('issue_plan_warning_count', 0)),
        ]
        gate_rows = []
        for item in benchmark_data.get('quality_gates') or []:
            if isinstance(item, dict):
                gate_rows.append(
                    "<tr>"
                    f"<td>{h(item.get('title'))}</td>"
                    f"<td>{h(item.get('status'))}</td>"
                    f"<td>{h(item.get('value'))}</td>"
                    f"<td>{h(item.get('threshold'))}</td>"
                    "</tr>"
                )
        gate_body = ''.join(gate_rows) or '<tr><td colspan="4">No benchmark gates recorded.</td></tr>'
        benchmark_section = (
            "<h2>Dogfood benchmark</h2>"
            "<p>Local-only v0.4 quality gates. "
            "<a href='benchmark.json'>benchmark.json</a> / <a href='BENCHMARK.md'>BENCHMARK.md</a></p>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in benchmark_cards)
            + "</div>"
            "<table><thead><tr><th>Gate</th><th>Status</th><th>Value</th><th>Threshold</th></tr></thead>"
            f"<tbody>{gate_body}</tbody></table>"
        )

    evidence_graph_section = (
        "<h2>Evidence graph</h2>"
        "<p>No evidence graph found. Run <code>gra-evidence-graph --run RUN_DIR</code> "
        "to link findings, targets, scanner leads, chains, proofs, validation, remediation, issue plans, and metrics.</p>"
    )
    if evidence_graph_present:
        graph_summary = evidence_graph_data.get('summary') if isinstance(evidence_graph_data.get('summary'), dict) else {}
        graph_cards = [
            ('Nodes', graph_summary.get('node_count', 0)),
            ('Edges', graph_summary.get('edge_count', 0)),
            ('High/Critical issue findings', graph_summary.get('high_critical_issue_recommended_findings', 0)),
            ('With supporting evidence', graph_summary.get('high_critical_with_supporting_evidence', 0)),
            ('With challenging evidence', graph_summary.get('high_critical_with_challenging_evidence', 0)),
        ]
        def graph_count_rows(values) -> str:
            if not isinstance(values, dict):
                return ""
            rows = []
            for key, value in sorted(values.items()):
                rows.append(f"<tr><td>{h(key)}</td><td>{h(value)}</td></tr>")
            return ''.join(rows)

        node_count_rows = graph_count_rows(graph_summary.get('node_counts'))
        edge_count_rows = graph_count_rows(graph_summary.get('edge_counts'))
        node_count_body = node_count_rows or '<tr><td colspan="2">No nodes.</td></tr>'
        edge_count_body = edge_count_rows or '<tr><td colspan="2">No edges.</td></tr>'
        evidence_graph_section = (
            "<h2>Evidence graph</h2>"
            "<p>Local-only artifact graph with bounded summaries only. "
            "<a href='evidence-graph.json'>evidence-graph.json</a> / <a href='EVIDENCE_GRAPH.md'>EVIDENCE_GRAPH.md</a></p>"
            "<div class='cards'>"
            + ''.join(f"<div class='card'><strong>{h(label)}</strong><br>{h(value)}</div>" for label, value in graph_cards)
            + "</div>"
            "<h3>Nodes by type</h3>"
            "<table><thead><tr><th>Type</th><th>Count</th></tr></thead>"
            f"<tbody>{node_count_body}</tbody></table>"
            "<h3>Edges by type</h3>"
            "<table><thead><tr><th>Type</th><th>Count</th></tr></thead>"
            f"<tbody>{edge_count_body}</tbody></table>"
        )

    css = """
    body { font-family: system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif; margin: 32px; }
    table { border-collapse: collapse; width: 100%; margin: 16px 0 32px; }
    th, td { border: 1px solid #ddd; padding: 8px; vertical-align: top; }
    th { background: #f5f5f5; text-align: left; }
    code { background: #f6f8fa; padding: 2px 4px; border-radius: 3px; }
    .cards { display: flex; gap: 16px; flex-wrap: wrap; }
    .card { border: 1px solid #ddd; border-radius: 8px; padding: 12px 16px; min-width: 180px; }
    .muted { color: #666; }
    """
    def counts_table(counts, keys):
        return ''.join(f"<div class='card'><strong>{h(k)}</strong><br>{counts.get(k,0)}</div>" for k in keys)

    html_text = f"""<!doctype html>
<html><head><meta charset='utf-8'><title>GenAI Repo Auditor Dashboard</title><style>{css}</style></head>
<body>
<h1>GenAI Repo Auditor Dashboard</h1>
<p class='muted'>Generated at {h(utc_now())}</p>
<h2>Run</h2>
<ul>
<li>Repository: <code>{h(ctx.get('repo'))}</code></li>
<li>Run ID: <code>{h(ctx.get('run_id', run_dir.name))}</code></li>
<li>Commit: <code>{h(ctx.get('commit'))}</code></li>
<li>Run directory: <code>{h(run_dir)}</code></li>
</ul>
{metrics_section}
{benchmark_section}
{evidence_graph_section}
<h2>Findings by severity</h2><div class='cards'>{counts_table(sev_counts, SEVERITIES)}</div>
<h2>Findings by status</h2><div class='cards'>{counts_table(status_counts, STATUSES)}</div>
<h2>Finding assessment dimensions</h2>
{''.join(f"<h3>{h(label)}</h3><div class='cards'>{counts_table(assessment_counts[field], ['Confirmed', 'Probable', 'Potential', 'Invalid', 'Not assessed'])}</div>" for field, label in ASSESSMENT_FIELDS)}
<h2>Target status</h2><div class='cards'>{''.join(f"<div class='card'><strong>{h(k)}</strong><br>{v}</div>" for k, v in sorted(target_status_counts.items()))}</div>
{gapfill_section}
{remediation_section}
{imported_findings_section}
{novelty_section}
<h2>Taxonomies</h2>
<table><thead><tr><th>Taxonomy</th><th>ID</th><th>Count</th></tr></thead><tbody>{''.join(taxonomy_rows) or '<tr><td colspan="3">No taxonomy mappings.</td></tr>'}</tbody></table>
<h2>Findings</h2>
<table><thead><tr><th>ID</th><th>Severity</th><th>Confidence</th><th>Status</th><th>Bug existence</th><th>Attacker reachability</th><th>Boundary crossing</th><th>Impact assessment</th><th>Category</th><th>Title</th><th>Locations</th></tr></thead><tbody>{''.join(rows) or '<tr><td colspan="11">No findings.</td></tr>'}</tbody></table>
<h2>Targets</h2>
<table><thead><tr><th>ID</th><th>Risk</th><th>Priority</th><th>Status</th><th>Category</th><th>Title</th></tr></thead><tbody>{''.join(target_rows) or '<tr><td colspan="6">No targets.</td></tr>'}</tbody></table>
<h2>Supply-chain posture</h2>
<p>Status: <code>{h(supply_chain_posture.get('status') or 'not ingested')}</code>; overall Scorecard score: <code>{h(supply_chain_posture.get('overall_score') if supply_chain_posture else '')}</code></p>
<p>{h(supply_chain_posture.get('summary') or 'No OpenSSF Scorecard posture artifact ingested.')}</p>
<div class='cards'>{''.join(f"<div class='card'><strong>{h(k)}</strong><br>{v}</div>" for k, v in sorted(supply_chain_risk_counts.items())) or "<div class='card'><strong>Checks</strong><br>0</div>"}</div>
<table><thead><tr><th>Check</th><th>Score</th><th>Scorecard risk</th><th>Assessed risk</th><th>Reason</th><th>Remediation</th><th>Target?</th></tr></thead><tbody>{''.join(supply_chain_rows) or '<tr><td colspan="7">No Scorecard posture checks ingested.</td></tr>'}</tbody></table>
<h2>Dependency risk</h2>
<p>Status: <code>{h(dependencies_data.get('status') or 'not ingested')}</code>; components: <code>{h(dependencies_data.get('component_count') if dependencies_data else 0)}</code>; vulnerabilities: <code>{h(dependencies_data.get('vulnerability_count') if dependencies_data else 0)}</code></p>
<p>{h(dependencies_data.get('summary') or 'No SBOM/dependency graph artifact ingested.')}</p>
<h3>Dependency scopes</h3><div class='cards'>{''.join(f"<div class='card'><strong>{h(k)}</strong><br>{v}</div>" for k, v in sorted(dependency_scope_counts.items())) or "<div class='card'><strong>Components</strong><br>0</div>"}</div>
<h3>Dependency vulnerabilities</h3><div class='cards'>{''.join(f"<div class='card'><strong>{h(k)}</strong><br>{v}</div>" for k, v in sorted(dependency_vuln_severity_counts.items())) or "<div class='card'><strong>Vulnerabilities</strong><br>0</div>"}</div>
<table><thead><tr><th>ID</th><th>Severity</th><th>Component</th><th>Fixed version</th><th>Source</th><th>Dependency paths</th></tr></thead><tbody>{''.join(dependency_vuln_rows) or '<tr><td colspan="6">No dependency vulnerability records ingested.</td></tr>'}</tbody></table>
<h2>Scanner results</h2>
<table><thead><tr><th>Tool</th><th>Format</th><th>Path</th><th>Imported at</th><th>Note</th></tr></thead><tbody>{''.join(scanner_rows) or '<tr><td colspan="5">No scanner results ingested.</td></tr>'}</tbody></table>
</body></html>"""
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(html_text, encoding='utf-8')
    print(f'Wrote {out}')
    append_command_event(
        run_dir,
        command='gra-dashboard',
        phase='dashboard',
        started_at=started_at,
        started_perf=started_perf,
        exit_code=0,
        input_artifact_paths=input_artifacts,
        output_artifact_paths=output_artifacts,
    )
    _failure_event = None
    return 0


def run_cli() -> int:
    try:
        return main()
    except Exception as exc:  # noqa: BLE001 - convert post-preflight failures into structured events.
        if _failure_event is not None:
            run_dir, started_at, started_perf, input_artifacts, output_artifacts = _failure_event
            append_command_event(
                run_dir,
                command='gra-dashboard',
                phase='dashboard',
                started_at=started_at,
                started_perf=started_perf,
                exit_code=2,
                input_artifact_paths=input_artifacts,
                output_artifact_paths=[path for path in output_artifacts if path.is_file() and not path.is_symlink()],
                error_category='reporting_failure',
                failure_mode='warn',
            )
        print(str(exc), file=sys.stderr)
        return 2


if __name__ == '__main__':
    raise SystemExit(run_cli())

#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

LAB_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(LAB_ROOT / 'lib'))
from version import auditor_version
from gralib import load_context, load_json, utc_now, write_json
from run_events import (
    EventWriteError,
    append_command_event,
    local_artifact_paths,
    preflight_command_event,
    reports_dir,
    start_command_event,
)

LEVEL_MAP = {
    'Critical': 'error',
    'High': 'error',
    'Medium': 'warning',
    'Low': 'note',
    'Informational': 'note',
}
ASSESSMENT_FIELDS = [
    'bug_existence',
    'attacker_reachability',
    'boundary_crossing',
    'impact_assessment',
]
_failure_event: tuple[Path, str, float, list[Path], list[Path]] | None = None


def main() -> int:
    global _failure_event
    _failure_event = None
    p = argparse.ArgumentParser(description='Convert findings.json to SARIF 2.1.0')
    p.add_argument('--version', action='version', version=f'%(prog)s {auditor_version(LAB_ROOT)}')
    p.add_argument('--run', required=True, help='Run directory')
    p.add_argument('--out', help='Output SARIF file. Default: reports/findings.sarif')
    args = p.parse_args()

    run_dir = Path(args.run).resolve()
    started_at, started_perf = start_command_event()
    ctx = load_context(run_dir)
    try:
        reports = reports_dir(run_dir)
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    findings_path = reports / 'findings.json'
    out = Path(args.out).resolve() if args.out else reports / 'findings.sarif'
    input_artifacts = [run_dir / 'context.json', findings_path]
    output_artifacts = local_artifact_paths(run_dir, [out])
    try:
        preflight_command_event(
            run_dir,
            input_artifact_paths=input_artifacts,
            output_artifact_paths=output_artifacts,
            event_fields={
                'command': 'gra-sarif',
                'phase': 'sarif',
                'started_at': started_at,
                'started_perf': started_perf,
                'exit_code': 0,
            },
            reserve_file=False,
        )
    except EventWriteError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    _failure_event = (run_dir, started_at, started_perf, input_artifacts, output_artifacts)
    findings_data = load_json(findings_path, {}) or {}
    findings = [f for f in findings_data.get('findings', []) if isinstance(f, dict)]
    rules = []
    results = []
    seen_rules = set()
    for f in findings:
        rule_id = str(f.get('id') or f.get('fingerprint') or 'SEC-UNKNOWN')
        cwe_ids = [str(x) for x in f.get('cwe') or [] if str(x).startswith('CWE-')]
        taxonomy_refs = [x for x in f.get('taxonomies') or [] if isinstance(x, dict)]
        for ref in taxonomy_refs:
            if ref.get('name') == 'CWE Subset' and str(ref.get('id', '')).startswith('CWE-'):
                cwe_ids.append(str(ref.get('id')))
        taxonomy_tags = sorted({*(cwe_ids), *(f"{ref.get('name')}:{ref.get('id')}" for ref in taxonomy_refs if ref.get('name') and ref.get('id'))})
        if rule_id not in seen_rules:
            seen_rules.add(rule_id)
            assessment_properties = {field: f.get(field) for field in ASSESSMENT_FIELDS if field in f}
            rules.append({
                'id': rule_id,
                'name': f.get('title') or rule_id,
                'shortDescription': {'text': f.get('title') or rule_id},
                'fullDescription': {'text': f.get('root_cause') or f.get('evidence') or ''},
                'help': {'text': f.get('minimal_remediation') or ''},
                'properties': {
                    'severity': f.get('severity'),
                    'confidence': f.get('confidence'),
                    'status': f.get('status'),
                    'category': f.get('category'),
                    'fingerprint': f.get('fingerprint'),
                    **assessment_properties,
                    'chain_membership': f.get('chain_membership') or [],
                    'cwe': sorted(set(cwe_ids)),
                    'taxonomies': taxonomy_refs,
                    'tags': taxonomy_tags,
                },
            })
        locs = []
        for loc in f.get('affected_locations') or []:
            if not isinstance(loc, dict) or not loc.get('file'):
                continue
            region = {}
            if isinstance(loc.get('line'), int):
                region['startLine'] = loc['line']
            if isinstance(loc.get('end_line'), int):
                region['endLine'] = loc['end_line']
            locs.append({'physicalLocation': {'artifactLocation': {'uri': loc['file']}, 'region': region}})
        if not locs:
            locs = [{'physicalLocation': {'artifactLocation': {'uri': 'repo/'}}}]
        results.append({
            'ruleId': rule_id,
            'level': LEVEL_MAP.get(str(f.get('severity')), 'warning'),
            'message': {'text': f.get('evidence') or f.get('title') or rule_id},
            'locations': locs,
            'partialFingerprints': {'genaiRepoAuditor': str(f.get('fingerprint') or rule_id)},
            'properties': {
                'impact': f.get('impact'),
                **{field: f.get(field) for field in ASSESSMENT_FIELDS if field in f},
                'chain_membership': f.get('chain_membership') or [],
                'assessment_notes': f.get('assessment_notes') or {},
                'entry_point': f.get('entry_point'),
                'trust_boundary': f.get('trust_boundary'),
                'source_to_sink': f.get('source_to_sink'),
                'validation_status': f.get('validation_status'),
                'taxonomies': taxonomy_refs,
                'run_id': ctx.get('run_id', run_dir.name),
                'repo': ctx.get('repo'),
                'commit': ctx.get('commit'),
            },
        })

    sarif = {
        '$schema': 'https://json.schemastore.org/sarif-2.1.0.json',
        'version': '2.1.0',
        'runs': [{
            'tool': {
                'driver': {
                    'name': 'genai-repo-auditor',
                    'informationUri': 'https://github.com/itdojp/genai-repo-auditor',
                    'rules': rules,
                }
            },
            'invocations': [{
                'executionSuccessful': True,
                'endTimeUtc': utc_now(),
                'properties': {'run_id': ctx.get('run_id', run_dir.name), 'repo': ctx.get('repo'), 'commit': ctx.get('commit')},
            }],
            'results': results,
        }],
    }
    write_json(out, sarif)
    print(f'Wrote {out}')
    append_command_event(
        run_dir,
        command='gra-sarif',
        phase='sarif',
        started_at=started_at,
        started_perf=started_perf,
        exit_code=0,
        input_artifact_paths=input_artifacts,
        output_artifact_paths=output_artifacts,
    )
    _failure_event = None
    return 0


def run_cli() -> int:
    try:
        return main()
    except Exception as exc:  # noqa: BLE001 - convert post-preflight failures into structured events.
        if _failure_event is not None:
            run_dir, started_at, started_perf, input_artifacts, output_artifacts = _failure_event
            append_command_event(
                run_dir,
                command='gra-sarif',
                phase='sarif',
                started_at=started_at,
                started_perf=started_perf,
                exit_code=2,
                input_artifact_paths=input_artifacts,
                output_artifact_paths=[path for path in output_artifacts if path.is_file() and not path.is_symlink()],
                error_category='reporting_failure',
                failure_mode='warn',
            )
        print(str(exc), file=sys.stderr)
        return 2


if __name__ == '__main__':
    raise SystemExit(run_cli())

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenAI Repo Auditor efficacy benchmark corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "corpus_version", "description", "public_safe", "default_suite", "cases"],
  "properties": {
    "schema_version": {"const": "1"},
    "corpus_id": {"const": "genai-repo-auditor-synthetic-core"},
    "corpus_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\+sha256\\.[a-f0-9]{64}$"},
    "description": {"type": "string", "minLength": 1, "maxLength": 300},
    "public_safe": {"const": true},
    "default_suite": {"const": "core"},
    "cases": {
      "type": "array",
      "minItems": 20,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "case_version", "classification", "category", "suites", "manifest", "manifest_sha256"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,47}/[a-z][a-z0-9-]{1,63}$"},
          "case_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\+sha256\\.[a-f0-9]{64}$"},
          "classification": {"enum": ["positive", "negative_control"]},
          "category": {"enum": ["python-web", "github-actions", "ai-agent-mcp", "dependency-supply-chain", "execution-boundaries", "webhook-trust", "secrets-logging"]},
          "suites": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["core", "appsec", "automation", "agentic", "supply-chain"]}},
          "manifest": {"type": "string", "pattern": "^cases/[a-z][a-z0-9-]{1,47}/[a-z][a-z0-9-]{1,63}/case\\.json$"},
          "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
